{
  "name": "theseus-founder-portal",
  "version": "0.1.0",
  "private": true,
  "main": "dist-desktop/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "worker:ingest": "tsx --tsconfig tsconfig.json src/worker/dequeue-ingest.ts",
    "desktop:build-ts": "tsc -p desktop/tsconfig.json",
    "desktop:dev": "tsx desktop/dev.ts",
    "desktop:build": "npm run build && npm run desktop:build-ts",
    "desktop:start": "npm run desktop:build && electron .",
    "desktop:icons": "node scripts/generate_icons.js",
    "desktop:dist": "npm run desktop:build && electron-builder --config electron-builder.yml",
    "desktop:dist-mac": "npm run desktop:build && electron-builder --mac --config electron-builder.yml",
    "desktop:dist-win": "npm run desktop:build && electron-builder --win --config electron-builder.yml"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "ioredis": "^5.6.0",
    "lucide-react": "^0.383.0",
    "next": "^16.0.0",
    "openai": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^11.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.0.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "png2icons": "^2.0.1",
    "prisma": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
