# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
.venv-*/
*.egg-info/
dist/
build/
.eggs/

# Node / Next.js
node_modules/
.next/
out/
.vercel/
**/.vercel/

# Environment files — NEVER commit anything that could hold a secret.
# Templates (.env.*.template) ARE intentionally committed — they're
# blank scaffolds the operator fills in locally.
#
# CRITICAL: sync.sh runs `git add -A`, so anything not matched here gets
# pushed to the remote. Polymarket private keys / Kalshi PEMs / DB URLs
# in any of these files would constitute a leak event.
.env
.env.local
.env.*.local
.env.live
.env.production
.env.staging
.env.development
.env.local.*
# Belt-and-braces: any future variant
.env.*
# … except templates, which are blank-by-design and commit-safe.
!.env.example
!.env.*.example
!.env.template
!.env.*.template

# IDE
.vscode/
.idea/
*.swp
*.swo

# Database
*.db
*.sqlite
*.sqlite3

# Logs
*.log
.claude_code_runs/
.codex_runs/

# Local encrypted credential recovery archives. These are created by
# scripts/sync-to-github.sh when it rotates the Supabase DB password.
.theseus-secrets/

# PEM / wallet / SSH key shapes — never tracked, anywhere in the tree.
# scripts/hooks/pre-commit.sh and sync.sh enforce the same patterns at
# the diff level; these globs are the file-name belt for the diff regex
# braces.
*.pem
*.key
*.p12
*.pfx
*.cer
*.keystore
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.wallet

# Model files (too large for git)
*.bin
*.pt
*.onnx

# ... but DO commit the compact sculpture meshes. These are tiny (60–110 KB
# each, total ~500 KB for six), baked by scripts/process-sculptures.ts
# from raw STL photogrammetry (which is NOT committed — those are
# hundreds of MB). The Codex fetches them at runtime from /sculptures/
# to render rotating amber ASCII busts. Without this negation pattern
# the `*.bin` rule above sweeps them up and Vercel deploys without them,
# producing 404s on every sculpture URL.
!theseus-codex/public/sculptures/*.mesh.bin

# Large media files (exceed GitHub's 100 MB limit; keep locally only)
*.m4a
*.mp3
*.wav
*.flac
*.aac
*.ogg
*.mp4
*.mov
*.avi
*.mkv
*.webm
Podcast talks/

# Experiment results (regenerable)
noosphere/noosphere_data/
# Local runtime ledger and blob store for Noosphere when run from the repo
# root; never committed — pure per-session state. Keep the curated
# contradiction exemplar seed file tracked; all other runtime data stays local.
noosphere_data/*
!noosphere_data/noosphere_config.json
!noosphere_data/coherence/
noosphere_data/coherence/*
!noosphere_data/coherence/contradiction_exemplars.jsonl

# Prisma
theseus-codex/prisma/*.db

# Reference-only materials (starting-material snapshots, original prototypes).
# Kept on disk for provenance but never tracked by git.
reference/

# Raw STL sculpture scans (hundreds of MB each). We keep source meshes
# in-repo for local processing, but never commit them; only the compact
# generated `.mesh.bin` outputs under `public/sculptures/` are tracked.
theseus-codex/assets/sculptures/raw-stl/

# macOS auto-saved screenshots (never commit)
Screenshot *.png
Screenshot *.jpg
Screenshot *.jpeg

# macOS Finder duplicate of theseus-codex (e.g. "theseus-codex 2", " 3")
theseus-codex [0-9]*/
.vercel

# Theseus-template extraction output.
#
# `scripts/build_template.sh` writes a tenant-installable copy of the
# repo to `../theseus-template/` (sibling) by default. If the operator
# instead aims it at the in-repo `theseus-template/` directory, ignore
# the build noise (.git/, node_modules/, etc.) but keep the tracked
# payload files (`scripts/bootstrap.sh`, the README, the CI workflow)
# so they survive across rebuilds.
theseus-template/*
!theseus-template/scripts/
!theseus-template/scripts/bootstrap.sh
!theseus-template/README.md
!theseus-template/.github/
!theseus-template/.github/workflows/
!theseus-template/.github/workflows/template_ci.yml
# Anything else inside the directory is build output.
theseus-template/.git/
theseus-template/node_modules/
theseus-template/dist/
theseus-template/build/
