# theseus-codex is a standalone nested project with its own git history.
# It was previously recorded as an orphan gitlink (no .gitmodules URL), which
# caused `fatal: No url found for submodule path 'theseus-codex'` on every
# CI checkout. Keep it local-only.
theseus-codex/
