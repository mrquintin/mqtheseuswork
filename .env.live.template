# Round 11 — live trading activation env file.
#
# WORKFLOW:
#   1. Copy this file to .env.live (which is git-ignored — verify .gitignore
#      lists .env.live before saving any real values).
#   2. Fill in EVERY value that is currently empty.
#   3. Leave FORECASTS_LIVE_TRADING_ENABLED=false until you have completed the
#      operator rehearsal documented in coding_prompts/OPERATOR_REHEARSAL.md
#      (generated by Round 11 prompt 04).
#   4. Run ./run_prompts.sh — the runner verifies this file is fully populated
#      and refuses to proceed if anything sensitive is missing.
#
# DO NOT commit .env.live. DO NOT paste its contents into chat.
# DO rotate any value that ever leaves your machine.

# ─── Database ──────────────────────────────────────────────────────────────
# Production Postgres. Supabase / Neon / Railway are fine. Local Postgres
# works too if you'll keep it running 24/7.
DATABASE_URL=

# ─── Structured response notifications ────────────────────────────────────
# Sender address for founder notification emails generated by the public structured-response form.
THESEUS_NOTIFY_FROM=notify@theseus.local
# Founder Alpha recipient override; replace this fake .invalid placeholder with the actual founder Alpha email before enabling mail.
FOUNDER_ALPHA_EMAIL=founder-alpha@example.invalid
# Resend API key for response notification delivery; leave empty to use SMTP or the development no-provider logger.
RESEND_API_KEY=
# SMTP hostname for response notification delivery when Resend is not configured.
SMTP_HOST=
# SMTP port for response notification delivery, usually 587 for STARTTLS or 465 for implicit TLS.
SMTP_PORT=
# SMTP username for response notification delivery when SMTP is selected.
SMTP_USER=
# SMTP password for response notification delivery when SMTP is selected.
SMTP_PASS=

# ─── Anthropic ─────────────────────────────────────────────────────────────
# Your existing key. Used by Haiku 4.5 for opinion + forecast generation.
ANTHROPIC_API_KEY=

# ─── Polymarket ────────────────────────────────────────────────────────────
# Read-only Gamma API (public, no auth needed; default value already correct).
POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
# Live trading: 64-character hex private key from your DEDICATED Polymarket
# wallet (NOT your main wallet). 0x prefix optional; Round 10's adapter
# accepts both. Leave empty until you are ready for live trading.
POLYMARKET_PRIVATE_KEY=
# Comma-separated category filter. Empty = all categories.
FORECASTS_POLYMARKET_CATEGORIES=politics,geopolitics,economics

# ─── Kalshi ────────────────────────────────────────────────────────────────
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=
# Multi-line PEM with newlines as literal \n. The config dataclass expands.
KALSHI_API_PRIVATE_KEY=
# Demo environment for the rehearsal — separate API key from your real one.
# (Verify the current demo base URL in Kalshi docs before populating.)
KALSHI_DEMO_API_BASE=
KALSHI_DEMO_API_KEY_ID=
KALSHI_DEMO_API_PRIVATE_KEY=
FORECASTS_KALSHI_CATEGORIES=politics,economics

# ─── Alpaca (equities) ─────────────────────────────────────────────────────
# Paper trading defaults to https://paper-api.alpaca.markets. Switch the
# base URL to https://api.alpaca.markets only after the equity-track live
# rehearsal and operator sign-off (the eight-gate contract still applies).
ALPACA_API_BASE=https://paper-api.alpaca.markets
ALPACA_DATA_BASE=https://data.alpaca.markets
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
# Keep TRUE until the equity-track live rehearsal is complete.
ALPACA_IS_PAPER=true
# Optional CSV symbol filter (empty = ingest every tradeable US equity / ETF).
EQUITIES_ACCEPTED_SYMBOLS=

# ─── Equities trading mode + ceilings ──────────────────────────────────────
# Equities-specific live flag. SEPARATE from the prediction-market
# FORECASTS_LIVE_TRADING_ENABLED so the operator can authorize live equity
# trading on its own schedule. KEEP false until rehearsal is complete.
EQUITIES_LIVE_TRADING_ENABLED=false
# Which broker the live equity engine routes orders to.
#   ALPACA    — recommended. Publishes a supported retail trading API.
#   ROBINHOOD — unofficial. See the Robinhood block below before flipping
#               EQUITIES_LIVE_TRADING_ENABLED=true while this is selected.
EQUITIES_PRIMARY_BROKER=ALPACA
# Per-order stake ceiling in USD for the equities track. Empty falls back
# to FORECASTS_MAX_STAKE_USD so a single founder authorization gates both.
EQUITIES_MAX_STAKE_USD=
# Daily loss ceiling for the equities track. Empty falls back to
# FORECASTS_MAX_DAILY_LOSS_USD.
EQUITIES_MAX_DAILY_LOSS_USD=

# ─── Robinhood (OPTIONAL, OFF BY DEFAULT) ──────────────────────────────────
# Robinhood does NOT publish a supported public retail trading API. This
# adapter relies on the unofficial `robin_stocks` library, installable via
# the `robinhood` optional extra: `pip install -e ./noosphere[robinhood]`.
# Robinhood may detect, throttle, or close accounts that automate trading.
# The eight-gate safety contract still applies — this is not a bypass.
#
# Leave ROBINHOOD_ENABLED=false unless you have read the warnings in
# theseus-codex/src/components/operator/EquityBetsPanel.tsx and accepted
# the risks. The operator console renders a yellow banner whenever this
# adapter is enabled.
ROBINHOOD_ENABLED=false
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
# TOTP secret (base32) from your authenticator app — required because
# Robinhood enforces MFA on every login. Treat as you would a private key.
ROBINHOOD_MFA_SEED=
# Per-device id Robinhood assigns the first time you log in from a new
# browser / device. Re-using the same token avoids new-device challenges.
ROBINHOOD_DEVICE_TOKEN=
ROBINHOOD_REQUEST_TIMEOUT_S=20
# Pinned robin_stocks release. Robinhood breaks the library on app
# updates, so leaving a known-good pin is intentional.
ROBINHOOD_PIP_CHOICE=robin_stocks==3.4.0

# ─── Tenancy ───────────────────────────────────────────────────────────────
# The organization id Forecasts writes its rows under. Use the same org id
# Currents writes under (you can read it from the Currents seed fixtures).
FORECASTS_INGEST_ORG_ID=

# ─── Trading mode + ceilings ───────────────────────────────────────────────
# KEEP false until rehearsal is complete. Round 11 prompt 04 generates
# OPERATOR_REHEARSAL.md walking you through enabling this safely.
FORECASTS_LIVE_TRADING_ENABLED=false
# Per-bet stake ceiling in USD. Start at 5. Scale up only after 30 resolved
# live bets show mean Brier < 0.20.
FORECASTS_MAX_STAKE_USD=5
# Daily loss ceiling. If this is hit, kill switch auto-engages.
FORECASTS_MAX_DAILY_LOSS_USD=20
# Auto kill-switch on losses. Should be < FORECASTS_MAX_DAILY_LOSS_USD so
# the kill switch fires before the absolute ceiling.
FORECASTS_KILL_SWITCH_AUTO_THRESHOLD_USD=15
# Paper bankroll for the simulator. Independent of live capital.
FORECASTS_PAPER_INITIAL_BALANCE_USD=10000

# ─── Budget guards (LLM token spend) ───────────────────────────────────────
FORECASTS_BUDGET_HOURLY_PROMPT_TOKENS=1500000
FORECASTS_BUDGET_HOURLY_COMPLETION_TOKENS=400000

# ─── Scheduler intervals (seconds) ─────────────────────────────────────────
FORECASTS_INGEST_INTERVAL_S=900
FORECASTS_GENERATE_INTERVAL_S=600
FORECASTS_RESOLUTION_POLL_INTERVAL_S=300
FORECASTS_PAPER_BET_DRAIN_INTERVAL_S=60

# ─── Operator surface ──────────────────────────────────────────────────────
# Random 32-byte hex; used to HMAC operator routes. Generate with:
#     openssl rand -hex 32
FORECASTS_OPERATOR_SECRET=

# ─── Mode selector ─────────────────────────────────────────────────────────
# Selects which subset of env vars is required at boot. Valid values:
#   algorithms-only  — algorithm runtime + visibility surface (default).
#   synthesizer      — adds the synthesizer-engine vars below.
#   full             — adds every Round-19 surface.
#   live-trading     — adds the live-trading block above.
THESEUS_MODE=algorithms-only

# ─── Algorithm runtime budgets (Round 19 prompt 03) ────────────────────────
ALGORITHMS_BUDGET_HOURLY_PROMPT_TOKENS=1500000
ALGORITHMS_BUDGET_HOURLY_COMPLETION_TOKENS=400000
# Seconds between algorithm runtime ticks. Default 60.
ALGORITHMS_TICK_INTERVAL_S=60
# Per-fire token ceiling for a single algorithm invocation.
ALGORITHMS_MAX_TOKENS_PER_FIRE=20000

# ─── Synthesizer budgets (Round 19 prompt 10) ──────────────────────────────
SYNTHESIZER_BUDGET_HOURLY_PROMPT_TOKENS=1500000
SYNTHESIZER_BUDGET_HOURLY_COMPLETION_TOKENS=400000

# ─── Cluster pre-filter (Round 19 prompt 07) ───────────────────────────────
# Embedding cosine threshold for joining a cluster (0..1).
CLUSTER_JOIN_THRESHOLD=0.75
MIN_CLUSTER_SIZE=3
CROSS_CLUSTER_SAMPLE_FRACTION=0.05
CROSS_CLUSTER_RANDOM_FRACTION=0.01
CLUSTER_DRIFT_THRESHOLD=0.15

# ─── Contradiction geometry (Round 19 prompt 06) ───────────────────────────
CONTRADICTION_THRESHOLD=0.7

# ─── Dialectic live recording (Round 19 prompt 14) ─────────────────────────
DIALECTIC_LIVE_CONTRADICTION_THRESHOLD=0.6
DIALECTIC_LIVE_LATENCY_TARGET_S=3.0
DIALECTIC_AUDIO_RETENTION_DAYS=30

# ─── Knowledge graph reasoner (Round 19 prompt 13) ─────────────────────────
GRAPH_REASONER_MAX_TOKENS_PER_EDGE=2000

# ─── Memo dispatch (Round 19 prompt 11) ────────────────────────────────────
# HUMAN | AUTO_PAPER | AUTO_LIVE. AUTO_LIVE requires live-trading mode.
MEMO_DISPATCH_DEFAULT_MODE=HUMAN

# ─── Live trading additions (Round 18) ─────────────────────────────────────
# Mean-Brier threshold below which an algorithm may auto-paper.
AUTO_PAPER_REQUIRES_CALIBRATION_THRESHOLD=0.2
