# Round 11 — live trading activation env file.
#
# WORKFLOW:
#   1. Copy this file to .env.live (which is git-ignored — verify .gitignore
#      lists .env.live before saving any real values).
#   2. Fill in EVERY value that is currently empty.
#   3. Leave FORECASTS_LIVE_TRADING_ENABLED=false until you have completed the
#      operator rehearsal documented in coding_prompts/OPERATOR_REHEARSAL.md
#      (generated by Round 11 prompt 04).
#   4. Run ./run_prompts.sh — the runner verifies this file is fully populated
#      and refuses to proceed if anything sensitive is missing.
#
# DO NOT commit .env.live. DO NOT paste its contents into chat.
# DO rotate any value that ever leaves your machine.

# ─── Database ──────────────────────────────────────────────────────────────
# Production Postgres. Supabase / Neon / Railway are fine. Local Postgres
# works too if you'll keep it running 24/7.
DATABASE_URL=

# ─── Anthropic ─────────────────────────────────────────────────────────────
# Your existing key. Used by Haiku 4.5 for opinion + forecast generation.
ANTHROPIC_API_KEY=

# ─── Polymarket ────────────────────────────────────────────────────────────
# Read-only Gamma API (public, no auth needed; default value already correct).
POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
# Live trading: 64-character hex private key from your DEDICATED Polymarket
# wallet (NOT your main wallet). 0x prefix optional; Round 10's adapter
# accepts both. Leave empty until you are ready for live trading.
POLYMARKET_PRIVATE_KEY=
# Comma-separated category filter. Empty = all categories.
FORECASTS_POLYMARKET_CATEGORIES=politics,geopolitics,economics

# ─── Kalshi ────────────────────────────────────────────────────────────────
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=
# Multi-line PEM with newlines as literal \n. The config dataclass expands.
KALSHI_API_PRIVATE_KEY=
# Demo environment for the rehearsal — separate API key from your real one.
# (Verify the current demo base URL in Kalshi docs before populating.)
KALSHI_DEMO_API_BASE=
KALSHI_DEMO_API_KEY_ID=
KALSHI_DEMO_API_PRIVATE_KEY=
FORECASTS_KALSHI_CATEGORIES=politics,economics

# ─── Tenancy ───────────────────────────────────────────────────────────────
# The organization id Forecasts writes its rows under. Use the same org id
# Currents writes under (you can read it from the Currents seed fixtures).
FORECASTS_INGEST_ORG_ID=

# ─── Trading mode + ceilings ───────────────────────────────────────────────
# KEEP false until rehearsal is complete. Round 11 prompt 04 generates
# OPERATOR_REHEARSAL.md walking you through enabling this safely.
FORECASTS_LIVE_TRADING_ENABLED=false
# Per-bet stake ceiling in USD. Start at 5. Scale up only after 30 resolved
# live bets show mean Brier < 0.20.
FORECASTS_MAX_STAKE_USD=5
# Daily loss ceiling. If this is hit, kill switch auto-engages.
FORECASTS_MAX_DAILY_LOSS_USD=20
# Auto kill-switch on losses. Should be < FORECASTS_MAX_DAILY_LOSS_USD so
# the kill switch fires before the absolute ceiling.
FORECASTS_KILL_SWITCH_AUTO_THRESHOLD_USD=15
# Paper bankroll for the simulator. Independent of live capital.
FORECASTS_PAPER_INITIAL_BALANCE_USD=10000

# ─── Budget guards (LLM token spend) ───────────────────────────────────────
FORECASTS_BUDGET_HOURLY_PROMPT_TOKENS=1500000
FORECASTS_BUDGET_HOURLY_COMPLETION_TOKENS=400000

# ─── Scheduler intervals (seconds) ─────────────────────────────────────────
FORECASTS_INGEST_INTERVAL_S=900
FORECASTS_GENERATE_INTERVAL_S=600
FORECASTS_RESOLUTION_POLL_INTERVAL_S=300
FORECASTS_PAPER_BET_DRAIN_INTERVAL_S=60

# ─── Operator surface ──────────────────────────────────────────────────────
# Random 32-byte hex; used to HMAC operator routes. Generate with:
#     openssl rand -hex 32
FORECASTS_OPERATOR_SECRET=
