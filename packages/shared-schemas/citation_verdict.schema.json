{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theseus.dev/schemas/citation_verdict.schema.json",
  "title": "CitationVerdict",
  "description": "Citation-chain verdict ledger row. The Python NLI judge in noosphere/literature/citation_chain.py is canonical for the verdict label; this schema is the wire-shape the codex reads back into VerdictPill rendering and stores in the CitationVerdict table.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "citation_kind",
    "citation_id",
    "source_id",
    "relation",
    "relation_holds",
    "confidence",
    "excerpt_used",
    "stated_claim",
    "cascade_weight",
    "model_version",
    "computed_at"
  ],
  "properties": {
    "citation_kind": {
      "type": "string",
      "enum": ["opinion", "forecast", "conclusion_source"]
    },
    "citation_id": { "type": "string", "minLength": 1 },
    "source_id": { "type": "string", "minLength": 1 },
    "relation": {
      "type": "string",
      "enum": ["supports", "contradicts", "qualifies", "mentions"]
    },
    "relation_holds": {
      "type": "string",
      "enum": ["entails", "contradicts", "neutral", "ambiguous"]
    },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "excerpt_used": { "type": "string" },
    "stated_claim": { "type": "string" },
    "cascade_weight": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "model_version": { "type": "string" },
    "computed_at": { "type": "string", "format": "date-time" },
    "overridden_by": {
      "type": ["string", "null"],
      "default": null
    },
    "override_reason": {
      "type": ["string", "null"],
      "default": null
    }
  }
}
