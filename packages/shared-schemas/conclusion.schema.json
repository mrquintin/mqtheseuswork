{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theseus.dev/schemas/conclusion.schema.json",
  "title": "Conclusion",
  "description": "Cross-language payload shape for a Conclusion record. Database-backed (Prisma owns the canonical TS row type via `Prisma.Conclusion`); this schema describes the JSON wire-form shipped between noosphere and codex (e.g. CLI exports, store sync) and is what runtime validators check on either side. Field names are snake_case to match the Pydantic side; the TS adapters translate to/from camelCase at the Prisma boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "text", "confidence"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "text": { "type": "string" },
    "reasoning": { "type": "string", "default": "" },
    "rationale": { "type": "string", "default": "" },
    "kind": {
      "type": "string",
      "enum": ["firm", "tentative", "exploratory", "retracted"],
      "default": "firm"
    },
    "confidence_tier": {
      "type": "string",
      "enum": ["high", "moderate", "low", "speculative"],
      "default": "moderate"
    },
    "principles_used": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "claims_used": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "supporting_principle_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "evidence_chain_claim_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "dissent_claim_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "disciplines": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "freshness": {
      "type": "string",
      "enum": ["fresh", "aging", "stale"],
      "default": "fresh"
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "superseded_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "default": null
    },
    "last_validated_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "default": null
    }
  }
}
