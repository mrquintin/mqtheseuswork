// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`TranscriptPage > snapshots a fixture transcript with timestamps, speakers, and chunk anchors 1`] = `"<main class="transcript-shell"><header class="transcript-header"><div><a href="/upload/upload_fixture" class="mono transcript-backlink">Upload source</a><h1>Dorkesh-style fixture</h1><p class="mono transcript-meta">Michael Quintin / May 1, 2026 / Source: transcript</p><p class="mono transcript-status-row"><span class="badge badge-ingested">ingested</span><span class="mono transcript-status-note">3 chunks</span></p></div><div class="transcript-toolbar"><div data-testid="publish-toolbar">Publish to</div><div class="transcript-public-toggle"><span class="mono">Private</span><button data-testid="publish-toggle" type="button">Toggle upload_fixture</button></div></div></header><div class="transcript-grid"><article class="transcript-primary" aria-label="Raw transcript"><div class="transcript-reader-toolbar"><label class="transcript-reader-search"><span class="mono">Search transcript</span><input aria-label="Search transcript" placeholder="Filter by word or phrase" type="search" value=""/></label><span class="mono transcript-reader-count">3 chunks</span></div><section class="transcript-chunk" data-testid="transcript-chunk-chunk-a" id="chunk-chunk-a"><div class="transcript-chunk-grid"><div class="transcript-time-slot"><a class="mono transcript-time" href="/transcripts/upload_fixture?anchor=chunk-chunk-a">[00:12]</a><button aria-label="Copy link to chunk 1" class="mono transcript-chunk-copy" type="button">copy link</button></div><p class="transcript-body"><strong class="transcript-speaker">Michael: </strong>Conversation archives should behave like podcasts with durable citations.</p></div></section><section class="transcript-chunk" data-testid="transcript-chunk-chunk-b" id="chunk-chunk-b"><div class="transcript-chunk-grid"><div class="transcript-time-slot"><a class="mono transcript-time" href="/transcripts/upload_fixture?anchor=chunk-chunk-b">[01:30]</a><button aria-label="Copy link to chunk 2" class="mono transcript-chunk-copy" type="button">copy link</button></div><p class="transcript-body"><strong class="transcript-speaker">Ada: </strong>The summary should invite reading without replacing the raw transcript.</p></div></section><section class="transcript-chunk" data-testid="transcript-chunk-chunk-c" id="chunk-chunk-c"><div class="transcript-chunk-grid"><div class="transcript-time-slot"><span class="mono transcript-chunk-index">[3]</span><button aria-label="Copy link to chunk 3" class="mono transcript-chunk-copy" type="button">copy link</button></div><p class="transcript-body">Stable chunk ids make Oracle citations land on the exact line.</p></div></section></article><aside class="transcript-side-rail" aria-label="Transcript navigation"><section class="portal-card transcript-blurb-card" aria-labelledby="transcript-blurb-title"><h2 class="mono" id="transcript-blurb-title">Blurb</h2><p>This fixture captures a short conversation about turning raw founder dialogue into an inspectable transcript surface.</p></section><nav class="portal-card transcript-section-nav" aria-label="Transcript sections"><h2 class="mono">Sections</h2><ul><li><a href="/transcripts/upload_fixture?anchor=chunk-chunk-a">Conversation Archive</a></li><li><a href="/transcripts/upload_fixture?anchor=chunk-chunk-c">Citation Contract</a></li></ul></nav><section class="portal-card transcript-related-rail" aria-label="What the firm thinks about this"><div class="transcript-related-panel"><h2 class="mono">What the firm thinks about this</h2><div class="transcript-related-list"><a href="/conclusions/conclusion-123456" class="transcript-related-card"><span class="mono">[C:conclusi] / firm</span><strong>Recorded reasoning is valuable when later readers can inspect the source line.</strong><em>knowledge</em></a></div></div></section></aside></div><section class="transcript-analysis" aria-label="Transcript analysis"><p class="mono transcript-analysis-kicker">Analysis (secondary)</p><div class="transcript-insight-grid"><section aria-labelledby="conversation-geometry-title" class="portal-card conversation-geometry"><div class="conversation-geometry-header"><div><p class="mono conversation-geometry-kicker">Conversation geometry</p><h2 id="conversation-geometry-title">Harvest table</h2><p>3 voices / 2 handoffs / 30 words</p></div><div class="conversation-geometry-tabs" role="tablist" aria-label="Conversation geometry views"><button aria-pressed="true" class="conversation-tab" type="button"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-network" aria-hidden="true"><rect x="16" y="16" width="6" height="6" rx="1"></rect><rect x="2" y="16" width="6" height="6" rx="1"></rect><rect x="9" y="2" width="6" height="6" rx="1"></rect><path d="M5 16v-3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3"></path><path d="M12 12V8"></path></svg>Map</button><button aria-pressed="false" class="conversation-tab" type="button"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-table2" aria-hidden="true"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"></path></svg>Weighting</button><button aria-pressed="false" class="conversation-tab" type="button"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-git-branch" aria-hidden="true"><line x1="6" x2="6" y1="3" y2="15"></line><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><path d="M18 9a9 9 0 0 1-9 9"></path></svg>Catalysts</button></div></div><div class="conversation-map-grid"><div class="conversation-map-frame" aria-label="Speaker handoff map"><svg class="conversation-map" role="img" viewBox="0 0 100 100"><title>Speaker objects connected by weighted handoff lines</title><line class="conversation-edge" stroke-width="5.300000000000001" x1="79.44486372867092" x2="50" y1="65" y2="20"></line><line class="conversation-edge" stroke-width="5.300000000000001" x1="20.55513627132909" x2="79.44486372867092" y1="65.00000000000001" y2="65"></line><a href="#chunk-chunk-c"><circle class="conversation-node" cx="50" cy="20" r="6.8"></circle><text class="conversation-node-label" x="50" y="32">Unattributed</text></a><a href="#chunk-chunk-b"><circle class="conversation-node" cx="79.44486372867092" cy="65" r="6.8"></circle><text class="conversation-node-label" x="79.44486372867092" y="77">Ada</text></a><a href="#chunk-chunk-a"><circle class="conversation-node" cx="20.55513627132909" cy="65.00000000000001" r="6.8"></circle><text class="conversation-node-label" x="20.55513627132909" y="77.00000000000001">Michael</text></a></svg></div><aside class="conversation-year-card conversation-year-card-locked"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-lock" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg><span class="mono">Year-end signal locked</span><p>2026 aggregates publish after the season closes, so the statistic cannot steer live conversations while the year is still open.</p></aside></div><div class="conversation-weighting" hidden="" role="table" aria-label="Speaker weighting"><div class="conversation-speaker-row" role="row"><div role="cell"><a class="conversation-speaker-name" href="#chunk-chunk-c">Unattributed</a><span class="mono">1 turns / 0 questions / 11 words per turn</span></div><div class="conversation-share" role="cell"><span class="mono">37%</span><div aria-hidden="true" class="conversation-share-bar"><span style="width:37%"></span></div></div><div class="conversation-term-row" role="cell">No repeated terms</div></div><div class="conversation-speaker-row" role="row"><div role="cell"><a class="conversation-speaker-name" href="#chunk-chunk-b">Ada</a><span class="mono">1 turns / 0 questions / 10 words per turn</span></div><div class="conversation-share" role="cell"><span class="mono">33%</span><div aria-hidden="true" class="conversation-share-bar"><span style="width:33%"></span></div></div><div class="conversation-term-row" role="cell">No repeated terms</div></div><div class="conversation-speaker-row" role="row"><div role="cell"><a class="conversation-speaker-name" href="#chunk-chunk-a">Michael</a><span class="mono">1 turns / 0 questions / 9 words per turn</span></div><div class="conversation-share" role="cell"><span class="mono">30%</span><div aria-hidden="true" class="conversation-share-bar"><span style="width:30%"></span></div></div><div class="conversation-term-row" role="cell">No repeated terms</div></div></div><div hidden=""><p class="conversation-geometry-note">Catalyst scores rank adjacent speaker handoffs by visible transcript cues, not definitive causality or hidden motive.</p><ol class="conversation-catalyst-list"><li class="conversation-catalyst"><div><span class="mono conversation-catalyst-kind">Neutral handoff / score 1</span><a href="/transcripts/upload_fixture?anchor=chunk-chunk-c">Ada -&gt; Unattributed</a></div><p><span class="mono">Source / Ada</span> <strong>The summary should invite reading without replacing the raw transcript.</strong></p><p><span class="mono">Target / Unattributed</span> Stable chunk ids make Oracle citations land on the exact line.</p><div class="conversation-term-row" aria-label="Shared terms"><span class="conversation-term">No shared terms</span></div></li><li class="conversation-catalyst"><div><span class="mono conversation-catalyst-kind">Neutral handoff / score 1</span><a href="/transcripts/upload_fixture?anchor=chunk-chunk-b">Michael -&gt; Ada</a></div><p><span class="mono">Source / Michael</span> <strong>Conversation archives should behave like podcasts with durable citations.</strong></p><p><span class="mono">Target / Ada</span> The summary should invite reading without replacing the raw transcript.</p><div class="conversation-term-row" aria-label="Shared terms"><span class="conversation-term">No shared terms</span></div></li></ol></div></section><section class="portal-card transcript-methodology-panel" aria-labelledby="transcript-methodology-title"><div class="transcript-methodology-head"><div><h2 class="mono" id="transcript-methodology-title">Methodology profiles</h2><p>Reasoning methods extracted from this source, separated from speaker identity and conclusions.</p></div><span class="mono">1 frame</span></div><ol class="transcript-methodology-list"><li class="transcript-methodology-card"><div class="transcript-methodology-card-head"><span class="mono">dialogic unfolding</span><span class="mono">72%</span></div><h3>Dialogic unfolding</h3><p class="transcript-methodology-summary">The transcript develops thought through questions and handoffs.</p><dl class="transcript-methodology-details"><div class="transcript-methodology-detail"><dt class="mono">Moves</dt><dd>Track which conversational move changed the direction of reasoning.</dd></div><div class="transcript-methodology-detail"><dt class="mono">Assumptions</dt><dd>Conversation can be an epistemic instrument.</dd></div><div class="transcript-methodology-detail"><dt class="mono">Transfers</dt><dd>truth-seeking dialogue</dd></div><div class="transcript-methodology-detail"><dt class="mono">Risks</dt><dd>Conversation energy can be mistaken for evidential progress.</dd></div></dl></li></ol></section></div></section></main>"`;
