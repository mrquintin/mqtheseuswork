// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`TranscriptPage > snapshots a fixture transcript with timestamps, speakers, and chunk anchors 1`] = `"<main class="transcript-shell"><header class="transcript-header"><div><a href="/upload/upload_fixture" class="mono transcript-backlink">Upload source</a><h1>Dorkesh-style fixture</h1><p class="mono transcript-meta">Michael Quintin / May 1, 2026 / Source: transcript / ingested</p></div><div class="transcript-toolbar"><div data-testid="publish-toolbar">Publish to</div><div class="transcript-public-toggle"><span class="mono">Private</span><button data-testid="publish-toggle" type="button">Toggle upload_fixture</button></div></div></header><section class="portal-card transcript-blurb-card" aria-labelledby="transcript-blurb-title"><h2 class="mono" id="transcript-blurb-title">Blurb</h2><p>This fixture captures a short conversation about turning raw founder dialogue into an inspectable transcript surface.</p><nav class="transcript-chip-row" aria-label="Transcript sections"><a class="transcript-chip" href="/transcripts/upload_fixture?anchor=chunk-chunk-a">Conversation Archive</a><a class="transcript-chip" href="/transcripts/upload_fixture?anchor=chunk-chunk-c">Citation Contract</a></nav></section><div class="transcript-grid"><article class="transcript-main" aria-label="Raw transcript"><section class="transcript-chunk" data-testid="transcript-chunk-chunk-a" id="chunk-chunk-a"><div class="transcript-chunk-grid"><div class="transcript-time-slot"><a class="mono transcript-time" href="/transcripts/upload_fixture?anchor=chunk-chunk-a">[00:12]</a></div><p class="transcript-body"><strong class="transcript-speaker">Michael: </strong>Conversation archives should behave like podcasts with durable citations.</p></div></section><section class="transcript-chunk" data-testid="transcript-chunk-chunk-b" id="chunk-chunk-b"><div class="transcript-chunk-grid"><div class="transcript-time-slot"><a class="mono transcript-time" href="/transcripts/upload_fixture?anchor=chunk-chunk-b">[01:30]</a></div><p class="transcript-body"><strong class="transcript-speaker">Ada: </strong>The summary should invite reading without replacing the raw transcript.</p></div></section><section class="transcript-chunk" data-testid="transcript-chunk-chunk-c" id="chunk-chunk-c"><div class="transcript-chunk-grid"><div class="transcript-time-slot"></div><p class="transcript-body">Stable chunk ids make Oracle citations land on the exact line.</p></div></section></article><aside class="portal-card transcript-related-rail" aria-label="What the firm thinks about this"><div class="transcript-related-panel"><h2 class="mono">What the firm thinks about this</h2><div class="transcript-related-list"><a href="/conclusions/conclusion-123456" class="transcript-related-card"><span class="mono">[C:conclusi] / firm</span><strong>Recorded reasoning is valuable when later readers can inspect the source line.</strong><em>knowledge</em></a></div></div></aside></div><details class="portal-card transcript-related-drawer"><summary class="mono">What the firm thinks about this</summary><div class="transcript-related-panel"><h2 class="mono">What the firm thinks about this</h2><div class="transcript-related-list"><a href="/conclusions/conclusion-123456" class="transcript-related-card"><span class="mono">[C:conclusi] / firm</span><strong>Recorded reasoning is valuable when later readers can inspect the source line.</strong><em>knowledge</em></a></div></div></details></main>"`;
