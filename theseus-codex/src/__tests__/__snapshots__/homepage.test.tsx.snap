exports[`PublicHomePage > snapshots the empty public homepage 1`] = `"<main style="min-height:100vh;position:relative"><header data-authed="false">Public header</header><div style="margin:0 auto;max-width:1120px;padding:3.75rem 2rem 6rem;position:relative;z-index:1"><section aria-labelledby="home-identity-title" id="about" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:2rem"><h1 class="mono" id="home-identity-title" style="color:var(--amber);font-size:clamp(1.65rem, 4vw, 3.1rem);font-weight:700;letter-spacing:0.16em;line-height:1.08;margin:0;text-transform:uppercase">THESEUS</h1><p style="color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, serif;font-size:clamp(1.2rem, 2.2vw, 1.7rem);line-height:1.32;margin:1rem 0 0;max-width:44rem">A working system for recording firm reasoning, testing it, and publishing reviewed perspectives.</p><p style="color:var(--parchment-dim);font-size:0.94rem;line-height:1.6;margin:0.7rem 0 0;max-width:42rem">This public surface shows reviewed articles and Currents opinions. The private workspace lives behind /login.</p><div style="align-items:center;display:flex;flex-wrap:wrap;gap:0.85rem;margin-top:1.45rem"><a href="/about" class="mono" style="background:var(--amber);border:1px solid var(--amber);border-radius:3px;color:var(--on-amber);display:inline-flex;font-size:0.68rem;font-weight:700;letter-spacing:0.2em;padding:0.72rem 1rem;text-decoration:none;text-transform:uppercase">About →</a><a href="/login" class="mono" style="color:var(--amber);display:inline-flex;font-size:0.68rem;letter-spacing:0.2em;padding:0.72rem 0;text-decoration:none;text-transform:uppercase">Founder login →</a></div></section><section aria-label="Inquiry search" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><section aria-labelledby="public-ask-heading" data-testid="public-ask-box" style="border:none;padding:0;background:transparent"><h2 class="mono" id="public-ask-heading" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;text-transform:uppercase;margin:0 0 0.85rem">ASK THE FIRM</h2><form style="display:flex;gap:0.5rem;flex-wrap:wrap"><label for="public-ask-input" class="visually-hidden" style="position:absolute;left:-10000px">Ask the firm</label><input id="public-ask-input" type="search" placeholder="Ask anything the firm has reasoned about — e.g. land value capture, monetary inflation" data-testid="public-ask-input" style="flex:1;min-width:16rem;background:rgba(0,0,0,0.35);border:1px solid var(--stroke);border-radius:4px;color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, serif;font-size:1rem;padding:0.7rem 0.9rem" value=""/><button type="submit" class="mono" disabled="" aria-busy="false" data-testid="public-ask-submit" title="Type at least 3 characters" style="background:var(--amber-dim);border:1px solid var(--amber-dim);border-radius:3px;color:var(--on-amber);font-weight:700;font-size:0.7rem;letter-spacing:0.18em;opacity:0.7;padding:0.7rem 1rem;text-transform:uppercase;cursor:not-allowed">Search</button></form><p class="mono" style="color:var(--parchment-dim);font-size:0.6rem;letter-spacing:0.16em;margin-top:0.6rem;text-transform:uppercase">Press <kbd>/</kbd> to focus · <kbd>↑</kbd>/<kbd>↓</kbd> to navigate · <kbd>Enter</kbd> to open</p></section></section><section aria-label="No public publications yet" style="background:rgba(232, 225, 211, 0.035);border:1px solid var(--stroke);border-radius:3px;margin:0 0 2rem;padding:1.1rem 1.2rem"><p class="mono" style="color:var(--amber-dim);font-size:0.62rem;letter-spacing:0.2em;margin:0;text-transform:uppercase">Public commons</p><p style="color:var(--parchment);font-size:1rem;line-height:1.55;margin:0.4rem 0 0">No publications or Currents opinions are public yet.</p><p style="color:var(--parchment-dim);font-size:0.94rem;line-height:1.55;margin:0.45rem 0 0">Currents will appear here when a real-world post crosses the firm&#x27;s significance and relevance floors. Essays appear here when the firm releases them. Reach the firm at <a href="mailto:hello@theseuscodex.com" style="color:var(--amber);text-decoration:underline;text-decoration-thickness:0.08em;text-underline-offset:0.16em">hello@theseuscodex.com</a>.</p></section><section aria-labelledby="home-articles-title" data-testid="homepage-articles-rail" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><h2 id="home-articles-title" style="color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, &#x27;Iowan Old Style&#x27;, Georgia, serif;font-size:clamp(1.22rem, 2vw, 1.48rem);font-weight:500;letter-spacing:0;line-height:1.18;margin:0 0 0.85rem">Articles</h2><p data-testid="homepage-articles-empty" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.12);color:var(--parchment-dim);font-size:0.95rem;line-height:1.55;margin:0;padding:1rem">Long-form articles will appear here once the firm publishes them.</p></section><section aria-labelledby="home-conclusions-title" data-testid="homepage-conclusions-rail" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><h2 id="home-conclusions-title" style="color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, &#x27;Iowan Old Style&#x27;, Georgia, serif;font-size:clamp(1.22rem, 2vw, 1.48rem);font-weight:500;letter-spacing:0;line-height:1.18;margin:0 0 0.85rem">Conclusions</h2><p data-testid="homepage-conclusions-empty" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.12);color:var(--parchment-dim);font-size:0.95rem;line-height:1.55;margin:0;padding:1rem">Reviewed conclusions will appear here once the firm publishes them.</p></section><section aria-labelledby="home-currents-title" data-testid="homepage-currents-rail" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><div style="align-items:center;display:flex;flex-wrap:wrap;gap:0.8rem;justify-content:space-between;margin-bottom:0.85rem"><h2 id="home-currents-title" style="color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, &#x27;Iowan Old Style&#x27;, Georgia, serif;font-size:clamp(1.22rem, 2vw, 1.48rem);font-weight:500;letter-spacing:0;line-height:1.18;margin:0">Currents from the firm</h2><a href="/currents" class="mono" style="color:var(--amber);font-size:0.62rem;letter-spacing:0.2em;text-decoration:none;text-transform:uppercase;white-space:nowrap">View all currents →</a></div><p data-testid="homepage-currents-empty" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.12);color:var(--parchment-dim);font-size:0.95rem;line-height:1.55;margin:0;padding:1rem">Live opinions will appear here once events cross the firm&#x27;s significance floor.</p></section><section aria-labelledby="home-signal-title" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><h2 class="mono" id="home-signal-title" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;margin:0 0 0.85rem;text-transform:uppercase">LIVE PUBLIC SURFACES</h2><div style="display:grid;gap:0.85rem;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr))"><a href="/currents" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.14);border-radius:6px;color:inherit;display:block;padding:1rem;text-decoration:none"><strong style="color:var(--amber);display:block;font-family:&#x27;Cinzel&#x27;, serif;letter-spacing:0.03em;margin-bottom:0.5rem">Currents</strong><span style="color:var(--parchment-dim);display:block;font-size:0.94rem;line-height:1.5">Real-world X posts and other live signals, with the firm&#x27;s public opinion in response.</span></a><a href="/forecasts" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.14);border-radius:6px;color:inherit;display:block;padding:1rem;text-decoration:none"><strong style="color:var(--amber);display:block;font-family:&#x27;Cinzel&#x27;, serif;letter-spacing:0.03em;margin-bottom:0.5rem">Forecasts</strong><span style="color:var(--parchment-dim);display:block;font-size:0.94rem;line-height:1.5">Prediction-market forecasts with evidence, uncertainty, and eventual calibration.</span></a></div></section><section aria-labelledby="home-manifesto-title" style="border-bottom:1px solid var(--stroke);margin-bottom:1.5rem;padding:0 0 1.75rem"><h2 class="mono" id="home-manifesto-title" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;margin:0 0 0.85rem;text-transform:uppercase">MANIFESTO</h2><p style="color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, serif;font-size:1.18rem;line-height:1.55;margin:0 0 0.85rem;max-width:50rem">Theseus treats intellectual capital as recorded human judgment under pressure: a firm-owned model of reasoning that can consult on decisions, expose assumptions, and carry institutional memory into new work.</p><a href="/about#manifesto" class="mono" style="color:var(--amber);font-size:0.66rem;letter-spacing:0.18em;text-decoration:none;text-transform:uppercase">Read the full manifesto →</a></section><section aria-labelledby="home-follow-title" style="border-bottom:1px solid var(--stroke);margin-bottom:1.5rem;padding:0 0 1.75rem"><h2 class="mono" id="home-follow-title" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;margin:0 0 0.85rem;text-transform:uppercase">FOLLOW THE FIRM</h2><form data-testid="subscribe-form" data-scope="firm" data-scope-key="" style="border:1px solid var(--stroke, rgba(232,225,211,0.18));padding:1rem 1.1rem;border-radius:4px"><h3 style="margin:0 0 0.4rem;font-size:0.95rem;letter-spacing:0.04em">Subscribe to firm-wide digests</h3><p style="color:var(--parchment-dim, #999);font-size:0.82rem;line-height:1.45;margin:0 0 0.8rem">A digest of new publications, revisions, and retractions across every method and domain the firm runs. Double opt-in. One-click unsubscribe in every email. No tracking pixels.</p><div style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center"><label style="flex:1 1 220px;min-width:0"><span style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0">Email</span><input type="email" required="" autoComplete="email" placeholder="you@example.org" data-testid="subscribe-form-email" style="width:100%;padding:0.5rem 0.6rem;font-family:inherit;font-size:0.9rem;border:1px solid var(--stroke, rgba(232,225,211,0.22));background:transparent;color:inherit" value=""/></label><label style="display:inline-flex;align-items:center;gap:0.4rem"><span style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0">Cadence</span><select data-testid="subscribe-form-cadence" style="padding:0.45rem 0.5rem;font-family:inherit;font-size:0.85rem;border:1px solid var(--stroke, rgba(232,225,211,0.22));background:transparent;color:inherit"><option value="weekly" selected="">Weekly</option><option value="monthly">Monthly</option><option value="immediate">Immediate (firm-wide major events)</option></select></label><button type="submit" data-testid="subscribe-form-submit" style="padding:0.5rem 0.9rem;font-family:inherit;font-size:0.78rem;letter-spacing:0.18em;text-transform:uppercase;border:1px solid var(--amber, #d4a017);background:var(--amber, #d4a017);color:var(--on-amber);cursor:pointer">Follow</button></div></form></section><p style="color:var(--parchment-dim);font-size:0.95rem;line-height:1.6;margin:0">Reach the firm at <a href="mailto:hello@theseuscodex.com" style="color:var(--amber);text-decoration:underline;text-decoration-thickness:0.08em;text-underline-offset:0.16em">hello@theseuscodex.com</a>.</p><footer>Transparency footer</footer></div></main>"`;

exports[`PublicHomePage > snapshots the populated public homepage 1`] = `"<main style="min-height:100vh;position:relative"><header data-authed="false">Public header</header><div style="margin:0 auto;max-width:1120px;padding:3.75rem 2rem 6rem;position:relative;z-index:1"><section aria-labelledby="home-identity-title" id="about" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:2rem"><h1 class="mono" id="home-identity-title" style="color:var(--amber);font-size:clamp(1.65rem, 4vw, 3.1rem);font-weight:700;letter-spacing:0.16em;line-height:1.08;margin:0;text-transform:uppercase">THESEUS</h1><p style="color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, serif;font-size:clamp(1.2rem, 2.2vw, 1.7rem);line-height:1.32;margin:1rem 0 0;max-width:44rem">A working system for recording firm reasoning, testing it, and publishing reviewed perspectives.</p><p style="color:var(--parchment-dim);font-size:0.94rem;line-height:1.6;margin:0.7rem 0 0;max-width:42rem">This public surface shows reviewed articles and Currents opinions. The private workspace lives behind /login.</p><div style="align-items:center;display:flex;flex-wrap:wrap;gap:0.85rem;margin-top:1.45rem"><a href="/about" class="mono" style="background:var(--amber);border:1px solid var(--amber);border-radius:3px;color:var(--on-amber);display:inline-flex;font-size:0.68rem;font-weight:700;letter-spacing:0.2em;padding:0.72rem 1rem;text-decoration:none;text-transform:uppercase">About →</a><a href="/login" class="mono" style="color:var(--amber);display:inline-flex;font-size:0.68rem;letter-spacing:0.2em;padding:0.72rem 0;text-decoration:none;text-transform:uppercase">Founder login →</a></div></section><section aria-label="Inquiry search" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><section aria-labelledby="public-ask-heading" data-testid="public-ask-box" style="border:none;padding:0;background:transparent"><h2 class="mono" id="public-ask-heading" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;text-transform:uppercase;margin:0 0 0.85rem">ASK THE FIRM</h2><form style="display:flex;gap:0.5rem;flex-wrap:wrap"><label for="public-ask-input" class="visually-hidden" style="position:absolute;left:-10000px">Ask the firm</label><input id="public-ask-input" type="search" placeholder="Ask anything the firm has reasoned about — e.g. land value capture, monetary inflation" data-testid="public-ask-input" style="flex:1;min-width:16rem;background:rgba(0,0,0,0.35);border:1px solid var(--stroke);border-radius:4px;color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, serif;font-size:1rem;padding:0.7rem 0.9rem" value=""/><button type="submit" class="mono" disabled="" aria-busy="false" data-testid="public-ask-submit" title="Type at least 3 characters" style="background:var(--amber-dim);border:1px solid var(--amber-dim);border-radius:3px;color:var(--on-amber);font-weight:700;font-size:0.7rem;letter-spacing:0.18em;opacity:0.7;padding:0.7rem 1rem;text-transform:uppercase;cursor:not-allowed">Search</button></form><p class="mono" style="color:var(--parchment-dim);font-size:0.6rem;letter-spacing:0.16em;margin-top:0.6rem;text-transform:uppercase">Press <kbd>/</kbd> to focus · <kbd>↑</kbd>/<kbd>↓</kbd> to navigate · <kbd>Enter</kbd> to open</p></section></section><section aria-labelledby="home-articles-title" data-testid="homepage-articles-rail" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><h2 id="home-articles-title" style="color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, &#x27;Iowan Old Style&#x27;, Georgia, serif;font-size:clamp(1.22rem, 2vw, 1.48rem);font-weight:500;letter-spacing:0;line-height:1.18;margin:0 0 0.85rem">Articles</h2><ul style="display:grid;gap:0.85rem;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));list-style:none;margin:0;padding:0"><li style="margin:0"><a href="/c/intellectual-capital-is-recorded-reasoning" data-testid="homepage-article-card" data-source="conclusion" style="border:1px solid rgba(205, 151, 67, 0.22);color:inherit;display:block;height:100%;padding:0.95rem;text-decoration:none"><span class="mono" data-testid="homepage-article-meta" style="color:var(--parchment-dim);display:block;font-size:0.58rem;letter-spacing:0.16em;margin-bottom:0.4rem;text-transform:uppercase">Apr 30, 2026 · Michael Quintin · 4 min read</span><strong style="color:var(--amber);display:block;font-family:&#x27;EB Garamond&#x27;, &#x27;Iowan Old Style&#x27;, Georgia, serif;font-size:1.12rem;font-weight:500;letter-spacing:0;line-height:1.28">Intellectual capital is recorded reasoning under pressure.</strong><span style="color:var(--parchment-dim);display:block;font-size:0.92rem;line-height:1.45;margin-top:0.5rem">The memo argues that intellectual capital is not merely expertise.</span></a></li></ul></section><section aria-labelledby="home-conclusions-title" data-testid="homepage-conclusions-rail" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><h2 id="home-conclusions-title" style="color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, &#x27;Iowan Old Style&#x27;, Georgia, serif;font-size:clamp(1.22rem, 2vw, 1.48rem);font-weight:500;letter-spacing:0;line-height:1.18;margin:0 0 0.85rem">Conclusions</h2><ul style="display:grid;gap:0.85rem;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));list-style:none;margin:0;padding:0"><li style="margin:0"><a href="/c/capital-decisions-need-a-reasoning-ledger" data-testid="homepage-conclusion-card" style="border:1px solid rgba(205, 151, 67, 0.22);color:inherit;display:block;height:100%;padding:0.95rem;text-decoration:none"><span class="mono" style="color:var(--parchment-dim);display:block;font-size:0.58rem;letter-spacing:0.16em;margin-bottom:0.4rem;text-transform:uppercase">Apr 29, 2026 · v1</span><strong style="color:var(--amber);display:block;font-family:&#x27;EB Garamond&#x27;, &#x27;Iowan Old Style&#x27;, Georgia, serif;font-size:1.12rem;font-weight:500;letter-spacing:0;line-height:1.28">Capital decisions need a reasoning ledger.</strong><span style="color:var(--parchment-dim);display:block;font-size:0.92rem;line-height:1.45;margin-top:0.5rem">Recorded reasoning compounds.</span></a></li></ul></section><section aria-labelledby="home-currents-title" data-testid="homepage-currents-rail" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><div style="align-items:center;display:flex;flex-wrap:wrap;gap:0.8rem;justify-content:space-between;margin-bottom:0.85rem"><h2 id="home-currents-title" style="color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, &#x27;Iowan Old Style&#x27;, Georgia, serif;font-size:clamp(1.22rem, 2vw, 1.48rem);font-weight:500;letter-spacing:0;line-height:1.18;margin:0">Currents from the firm</h2><a href="/currents" class="mono" style="color:var(--amber);font-size:0.62rem;letter-spacing:0.2em;text-decoration:none;text-transform:uppercase;white-space:nowrap">View all currents →</a></div><div data-testid="homepage-currents-preview" style="display:grid;gap:0.9rem;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr))"><a href="/currents/opinion-1" data-testid="homepage-current-card" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.14);border-radius:6px;color:inherit;display:block;min-height:11rem;padding:1rem;text-decoration:none"><h3 style="color:var(--amber);font-family:&#x27;EB Garamond&#x27;, &#x27;Iowan Old Style&#x27;, Georgia, serif;font-size:1.35rem;font-weight:500;letter-spacing:0;line-height:1.22;margin:0" data-h3-glyph="off">The market is over-reading the headline risk</h3><p class="mono" style="color:var(--amber-dim);font-size:0.6rem;letter-spacing:0.16em;margin:0.4rem 0 0;text-transform:uppercase"><time dateTime="2026-04-30T15:15:00.000Z">Apr 30, 2026, 3:15 PM UTC</time> · markets</p><p style="color:var(--parchment-dim);display:-webkit-box;font-size:0.92rem;line-height:1.45;margin:0.65rem 0 0;overflow:hidden;-webkit-box-orient:vertical;-webkit-line-clamp:2">The firm sees a real change in tone, but the evidence does not yet support the consensus trade.</p></a><a href="/currents/opinion-2" data-testid="homepage-current-card" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.14);border-radius:6px;color:inherit;display:block;min-height:11rem;padding:1rem;text-decoration:none"><h3 style="color:var(--amber);font-family:&#x27;EB Garamond&#x27;, &#x27;Iowan Old Style&#x27;, Georgia, serif;font-size:1.35rem;font-weight:500;letter-spacing:0;line-height:1.22;margin:0" data-h3-glyph="off">Energy policy is mispriced by timelines</h3><p class="mono" style="color:var(--amber-dim);font-size:0.6rem;letter-spacing:0.16em;margin:0.4rem 0 0;text-transform:uppercase"><time dateTime="2026-04-30T14:10:00.000Z">Apr 30, 2026, 2:10 PM UTC</time> · markets</p><p style="color:var(--parchment-dim);display:-webkit-box;font-size:0.92rem;line-height:1.45;margin:0.65rem 0 0;overflow:hidden;-webkit-box-orient:vertical;-webkit-line-clamp:2">The firm sees a real change in tone, but the evidence does not yet support the consensus trade.</p></a><a href="/currents/opinion-3" data-testid="homepage-current-card" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.14);border-radius:6px;color:inherit;display:block;min-height:11rem;padding:1rem;text-decoration:none"><h3 style="color:var(--amber);font-family:&#x27;EB Garamond&#x27;, &#x27;Iowan Old Style&#x27;, Georgia, serif;font-size:1.35rem;font-weight:500;letter-spacing:0;line-height:1.22;margin:0" data-h3-glyph="off">AI capex risk is second-order, not absent</h3><p class="mono" style="color:var(--amber-dim);font-size:0.6rem;letter-spacing:0.16em;margin:0.4rem 0 0;text-transform:uppercase"><time dateTime="2026-04-30T13:05:00.000Z">Apr 30, 2026, 1:05 PM UTC</time> · markets</p><p style="color:var(--parchment-dim);display:-webkit-box;font-size:0.92rem;line-height:1.45;margin:0.65rem 0 0;overflow:hidden;-webkit-box-orient:vertical;-webkit-line-clamp:2">The firm sees a real change in tone, but the evidence does not yet support the consensus trade.</p></a></div></section><section aria-labelledby="home-signal-title" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><h2 class="mono" id="home-signal-title" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;margin:0 0 0.85rem;text-transform:uppercase">LIVE PUBLIC SURFACES</h2><div style="display:grid;gap:0.85rem;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr))"><a href="/currents" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.14);border-radius:6px;color:inherit;display:block;padding:1rem;text-decoration:none"><strong style="color:var(--amber);display:block;font-family:&#x27;Cinzel&#x27;, serif;letter-spacing:0.03em;margin-bottom:0.5rem">Currents</strong><span style="color:var(--parchment-dim);display:block;font-size:0.94rem;line-height:1.5">Real-world X posts and other live signals, with the firm&#x27;s public opinion in response.</span></a><a href="/forecasts" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.14);border-radius:6px;color:inherit;display:block;padding:1rem;text-decoration:none"><strong style="color:var(--amber);display:block;font-family:&#x27;Cinzel&#x27;, serif;letter-spacing:0.03em;margin-bottom:0.5rem">Forecasts</strong><span style="color:var(--parchment-dim);display:block;font-size:0.94rem;line-height:1.5">Prediction-market forecasts with evidence, uncertainty, and eventual calibration.</span></a></div></section><section aria-labelledby="home-manifesto-title" style="border-bottom:1px solid var(--stroke);margin-bottom:1.5rem;padding:0 0 1.75rem"><h2 class="mono" id="home-manifesto-title" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;margin:0 0 0.85rem;text-transform:uppercase">MANIFESTO</h2><p style="color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, serif;font-size:1.18rem;line-height:1.55;margin:0 0 0.85rem;max-width:50rem">Theseus treats intellectual capital as recorded human judgment under pressure: a firm-owned model of reasoning that can consult on decisions, expose assumptions, and carry institutional memory into new work.</p><a href="/about#manifesto" class="mono" style="color:var(--amber);font-size:0.66rem;letter-spacing:0.18em;text-decoration:none;text-transform:uppercase">Read the full manifesto →</a></section><section aria-labelledby="home-follow-title" style="border-bottom:1px solid var(--stroke);margin-bottom:1.5rem;padding:0 0 1.75rem"><h2 class="mono" id="home-follow-title" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;margin:0 0 0.85rem;text-transform:uppercase">FOLLOW THE FIRM</h2><form data-testid="subscribe-form" data-scope="firm" data-scope-key="" style="border:1px solid var(--stroke, rgba(232,225,211,0.18));padding:1rem 1.1rem;border-radius:4px"><h3 style="margin:0 0 0.4rem;font-size:0.95rem;letter-spacing:0.04em">Subscribe to firm-wide digests</h3><p style="color:var(--parchment-dim, #999);font-size:0.82rem;line-height:1.45;margin:0 0 0.8rem">A digest of new publications, revisions, and retractions across every method and domain the firm runs. Double opt-in. One-click unsubscribe in every email. No tracking pixels.</p><div style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center"><label style="flex:1 1 220px;min-width:0"><span style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0">Email</span><input type="email" required="" autoComplete="email" placeholder="you@example.org" data-testid="subscribe-form-email" style="width:100%;padding:0.5rem 0.6rem;font-family:inherit;font-size:0.9rem;border:1px solid var(--stroke, rgba(232,225,211,0.22));background:transparent;color:inherit" value=""/></label><label style="display:inline-flex;align-items:center;gap:0.4rem"><span style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0">Cadence</span><select data-testid="subscribe-form-cadence" style="padding:0.45rem 0.5rem;font-family:inherit;font-size:0.85rem;border:1px solid var(--stroke, rgba(232,225,211,0.22));background:transparent;color:inherit"><option value="weekly" selected="">Weekly</option><option value="monthly">Monthly</option><option value="immediate">Immediate (firm-wide major events)</option></select></label><button type="submit" data-testid="subscribe-form-submit" style="padding:0.5rem 0.9rem;font-family:inherit;font-size:0.78rem;letter-spacing:0.18em;text-transform:uppercase;border:1px solid var(--amber, #d4a017);background:var(--amber, #d4a017);color:var(--on-amber);cursor:pointer">Follow</button></div></form></section><p style="color:var(--parchment-dim);font-size:0.95rem;line-height:1.6;margin:0">Reach the firm at <a href="mailto:hello@theseuscodex.com" style="color:var(--amber);text-decoration:underline;text-decoration-thickness:0.08em;text-underline-offset:0.16em">hello@theseuscodex.com</a>.</p><footer>Transparency footer</footer></div></main>"`;
