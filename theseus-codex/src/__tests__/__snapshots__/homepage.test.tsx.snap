// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`PublicHomePage > snapshots the empty public homepage 1`] = `"<main style="min-height:100vh;position:relative"><header data-authed="false">Public header</header><div style="margin:0 auto;max-width:1120px;padding:3.75rem 2rem 6rem;position:relative;z-index:1"><section aria-labelledby="home-identity-title" id="about" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:2rem"><h1 class="mono" id="home-identity-title" style="color:var(--amber);font-size:clamp(1.65rem, 4vw, 3.1rem);font-weight:700;letter-spacing:0.16em;line-height:1.08;margin:0;text-transform:uppercase">THESEUS</h1><p style="color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, serif;font-size:clamp(1.2rem, 2.2vw, 1.7rem);line-height:1.32;margin:1rem 0 0;max-width:44rem">A working system for recording firm reasoning, testing it, and publishing reviewed perspectives.</p><p style="color:var(--parchment-dim);font-size:0.94rem;line-height:1.6;margin:0.7rem 0 0;max-width:42rem">This public surface shows reviewed articles and Currents opinions. The private workspace lives behind /login.</p><div style="align-items:center;display:flex;flex-wrap:wrap;gap:0.85rem;margin-top:1.45rem"><a href="/about" class="mono" style="background:var(--amber);border:1px solid var(--amber);border-radius:3px;color:#120d08;display:inline-flex;font-size:0.68rem;font-weight:700;letter-spacing:0.2em;padding:0.72rem 1rem;text-decoration:none;text-transform:uppercase">About →</a><a href="/login" class="mono" style="color:var(--amber);display:inline-flex;font-size:0.68rem;letter-spacing:0.2em;padding:0.72rem 0;text-decoration:none;text-transform:uppercase">Founder login →</a></div></section><section aria-label="No public publications yet" class="ascii-frame" data-label="PUBLIC COMMONS" style="margin:0 0 2rem;padding:1.3rem 1.4rem"><p style="color:var(--parchment);font-size:1rem;line-height:1.55;margin:0">The firm has not yet published anything publicly. Reach out: <a href="mailto:hello@theseuscodex.com" style="color:var(--amber);text-decoration:none">hello@theseuscodex.com</a>.</p></section><section aria-labelledby="home-currents-title" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><div style="align-items:center;display:flex;flex-wrap:wrap;gap:0.8rem;justify-content:space-between;margin-bottom:0.85rem"><h2 class="mono" id="home-currents-title" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;margin:0;text-transform:uppercase">LATEST FROM THE FIRM · CURRENTS</h2><a href="/currents" class="mono" style="color:var(--amber);font-size:0.62rem;letter-spacing:0.2em;text-decoration:none;text-transform:uppercase;white-space:nowrap">View all currents →</a></div><p style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.12);color:var(--parchment-dim);font-size:0.95rem;line-height:1.55;margin:0;padding:1rem">No Currents opinions are public yet.</p></section><section aria-labelledby="home-publications-title" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><div style="align-items:center;display:flex;flex-wrap:wrap;gap:0.8rem;justify-content:space-between;margin-bottom:0.85rem"><h2 class="mono" id="home-publications-title" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;margin:0;text-transform:uppercase">PUBLICATIONS · ESSAYS &amp; MEMOS</h2><a href="/responses?tab=articles" class="mono" style="color:var(--amber);font-size:0.62rem;letter-spacing:0.2em;text-decoration:none;text-transform:uppercase;white-space:nowrap">View all publications →</a></div><p style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.12);color:var(--parchment-dim);font-size:0.95rem;line-height:1.55;margin:0;padding:1rem">No essays or memos are public yet.</p></section><section aria-labelledby="home-signal-title" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><h2 class="mono" id="home-signal-title" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;margin:0 0 0.85rem;text-transform:uppercase">LIVE PUBLIC SURFACES</h2><div style="display:grid;gap:0.85rem;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr))"><a href="/currents" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.14);border-radius:6px;color:inherit;display:block;padding:1rem;text-decoration:none"><strong style="color:var(--amber);display:block;font-family:&#x27;Cinzel&#x27;, serif;letter-spacing:0.03em;margin-bottom:0.5rem">Currents</strong><span style="color:var(--parchment-dim);display:block;font-size:0.94rem;line-height:1.5">Real-world X posts and other live signals, with the firm&#x27;s public opinion in response.</span></a><a href="/forecasts" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.14);border-radius:6px;color:inherit;display:block;padding:1rem;text-decoration:none"><strong style="color:var(--amber);display:block;font-family:&#x27;Cinzel&#x27;, serif;letter-spacing:0.03em;margin-bottom:0.5rem">Forecasts</strong><span style="color:var(--parchment-dim);display:block;font-size:0.94rem;line-height:1.5">Prediction-market forecasts with evidence, uncertainty, and eventual calibration.</span></a></div></section><section aria-labelledby="home-manifesto-title" style="border-bottom:1px solid var(--stroke);margin-bottom:1.5rem;padding:0 0 1.75rem"><h2 class="mono" id="home-manifesto-title" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;margin:0 0 0.85rem;text-transform:uppercase">MANIFESTO</h2><p style="color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, serif;font-size:1.18rem;line-height:1.55;margin:0 0 0.85rem;max-width:50rem">Theseus treats intellectual capital as recorded human judgment under pressure: a firm-owned model of reasoning that can consult on decisions, expose assumptions, and carry institutional memory into new work.</p><a href="/about#manifesto" class="mono" style="color:var(--amber);font-size:0.66rem;letter-spacing:0.18em;text-decoration:none;text-transform:uppercase">Read the full manifesto →</a></section><p style="color:var(--parchment-dim);font-size:0.95rem;line-height:1.6;margin:0">Reach the firm at <a href="mailto:hello@theseuscodex.com" style="color:var(--amber);text-decoration:none">hello@theseuscodex.com</a>.</p><footer>Transparency footer</footer></div></main>"`;

exports[`PublicHomePage > snapshots the populated public homepage 1`] = `"<main style="min-height:100vh;position:relative"><header data-authed="false">Public header</header><div style="margin:0 auto;max-width:1120px;padding:3.75rem 2rem 6rem;position:relative;z-index:1"><section aria-labelledby="home-identity-title" id="about" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:2rem"><h1 class="mono" id="home-identity-title" style="color:var(--amber);font-size:clamp(1.65rem, 4vw, 3.1rem);font-weight:700;letter-spacing:0.16em;line-height:1.08;margin:0;text-transform:uppercase">THESEUS</h1><p style="color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, serif;font-size:clamp(1.2rem, 2.2vw, 1.7rem);line-height:1.32;margin:1rem 0 0;max-width:44rem">A working system for recording firm reasoning, testing it, and publishing reviewed perspectives.</p><p style="color:var(--parchment-dim);font-size:0.94rem;line-height:1.6;margin:0.7rem 0 0;max-width:42rem">This public surface shows reviewed articles and Currents opinions. The private workspace lives behind /login.</p><div style="align-items:center;display:flex;flex-wrap:wrap;gap:0.85rem;margin-top:1.45rem"><a href="/about" class="mono" style="background:var(--amber);border:1px solid var(--amber);border-radius:3px;color:#120d08;display:inline-flex;font-size:0.68rem;font-weight:700;letter-spacing:0.2em;padding:0.72rem 1rem;text-decoration:none;text-transform:uppercase">About →</a><a href="/login" class="mono" style="color:var(--amber);display:inline-flex;font-size:0.68rem;letter-spacing:0.2em;padding:0.72rem 0;text-decoration:none;text-transform:uppercase">Founder login →</a></div></section><section aria-labelledby="home-currents-title" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><div style="align-items:center;display:flex;flex-wrap:wrap;gap:0.8rem;justify-content:space-between;margin-bottom:0.85rem"><h2 class="mono" id="home-currents-title" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;margin:0;text-transform:uppercase">LATEST FROM THE FIRM · CURRENTS</h2><a href="/currents" class="mono" style="color:var(--amber);font-size:0.62rem;letter-spacing:0.2em;text-decoration:none;text-transform:uppercase;white-space:nowrap">View all currents →</a></div><div data-testid="homepage-currents-preview" style="display:grid;gap:0.9rem;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr))"><a href="/currents/opinion-1" data-testid="homepage-current-card" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.14);border-radius:6px;color:inherit;display:block;min-height:11rem;padding:1rem;text-decoration:none"><time class="mono" dateTime="2026-04-30T15:15:00.000Z" style="color:var(--amber-dim);display:block;font-size:0.58rem;letter-spacing:0.16em;margin-bottom:0.55rem;text-transform:uppercase">Apr 30, 2026, 3:15 PM UTC</time><h3 style="color:var(--amber);font-family:&#x27;Cinzel&#x27;, serif;font-size:1.05rem;letter-spacing:0.03em;line-height:1.25;margin:0">The market is over-reading the headline risk</h3><p style="color:var(--parchment-dim);display:-webkit-box;font-size:0.92rem;line-height:1.45;margin:0.65rem 0 0;overflow:hidden;-webkit-box-orient:vertical;-webkit-line-clamp:2">The firm sees a real change in tone, but the evidence does not yet support the consensus trade.</p></a><a href="/currents/opinion-2" data-testid="homepage-current-card" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.14);border-radius:6px;color:inherit;display:block;min-height:11rem;padding:1rem;text-decoration:none"><time class="mono" dateTime="2026-04-30T14:10:00.000Z" style="color:var(--amber-dim);display:block;font-size:0.58rem;letter-spacing:0.16em;margin-bottom:0.55rem;text-transform:uppercase">Apr 30, 2026, 2:10 PM UTC</time><h3 style="color:var(--amber);font-family:&#x27;Cinzel&#x27;, serif;font-size:1.05rem;letter-spacing:0.03em;line-height:1.25;margin:0">Energy policy is mispriced by timelines</h3><p style="color:var(--parchment-dim);display:-webkit-box;font-size:0.92rem;line-height:1.45;margin:0.65rem 0 0;overflow:hidden;-webkit-box-orient:vertical;-webkit-line-clamp:2">The firm sees a real change in tone, but the evidence does not yet support the consensus trade.</p></a><a href="/currents/opinion-3" data-testid="homepage-current-card" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.14);border-radius:6px;color:inherit;display:block;min-height:11rem;padding:1rem;text-decoration:none"><time class="mono" dateTime="2026-04-30T13:05:00.000Z" style="color:var(--amber-dim);display:block;font-size:0.58rem;letter-spacing:0.16em;margin-bottom:0.55rem;text-transform:uppercase">Apr 30, 2026, 1:05 PM UTC</time><h3 style="color:var(--amber);font-family:&#x27;Cinzel&#x27;, serif;font-size:1.05rem;letter-spacing:0.03em;line-height:1.25;margin:0">AI capex risk is second-order, not absent</h3><p style="color:var(--parchment-dim);display:-webkit-box;font-size:0.92rem;line-height:1.45;margin:0.65rem 0 0;overflow:hidden;-webkit-box-orient:vertical;-webkit-line-clamp:2">The firm sees a real change in tone, but the evidence does not yet support the consensus trade.</p></a></div></section><section aria-labelledby="home-publications-title" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><div style="align-items:center;display:flex;flex-wrap:wrap;gap:0.8rem;justify-content:space-between;margin-bottom:0.85rem"><h2 class="mono" id="home-publications-title" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;margin:0;text-transform:uppercase">PUBLICATIONS · ESSAYS &amp; MEMOS</h2><a href="/responses?tab=articles" class="mono" style="color:var(--amber);font-size:0.62rem;letter-spacing:0.2em;text-decoration:none;text-transform:uppercase;white-space:nowrap">View all publications →</a></div><div style="display:grid;gap:0.75rem;grid-template-columns:repeat(auto-fit, minmax(180px, 1fr))"><a href="/c/intellectual-capital-is-recorded-reasoning" style="border:1px solid rgba(205, 151, 67, 0.22);color:inherit;display:block;padding:0.85rem;text-decoration:none"><span class="mono" style="color:var(--parchment-dim);display:block;font-size:0.58rem;letter-spacing:0.16em;margin-bottom:0.35rem;text-transform:uppercase">2026-04-30</span><strong style="color:var(--amber);display:block;font-family:&#x27;Cinzel&#x27;, serif;line-height:1.25">Intellectual capital is recorded reasoning under pressure.</strong><span style="color:var(--parchment-dim);display:block;font-size:0.9rem;line-height:1.45;margin-top:0.45rem">Reasoning compounds only when later decisions can inspect the claims, evidence, and objections that produced it.</span></a><a href="/c/capital-decisions-need-a-reasoning-ledger" style="border:1px solid rgba(205, 151, 67, 0.22);color:inherit;display:block;padding:0.85rem;text-decoration:none"><span class="mono" style="color:var(--parchment-dim);display:block;font-size:0.58rem;letter-spacing:0.16em;margin-bottom:0.35rem;text-transform:uppercase">2026-04-30</span><strong style="color:var(--amber);display:block;font-family:&#x27;Cinzel&#x27;, serif;line-height:1.25">Capital decisions need a reasoning ledger.</strong><span style="color:var(--parchment-dim);display:block;font-size:0.9rem;line-height:1.45;margin-top:0.45rem">Reasoning compounds only when later decisions can inspect the claims, evidence, and objections that produced it.</span></a></div></section><section aria-labelledby="home-signal-title" style="border-bottom:1px solid var(--stroke);margin-bottom:2rem;padding-bottom:1.75rem"><h2 class="mono" id="home-signal-title" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;margin:0 0 0.85rem;text-transform:uppercase">LIVE PUBLIC SURFACES</h2><div style="display:grid;gap:0.85rem;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr))"><a href="/currents" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.14);border-radius:6px;color:inherit;display:block;padding:1rem;text-decoration:none"><strong style="color:var(--amber);display:block;font-family:&#x27;Cinzel&#x27;, serif;letter-spacing:0.03em;margin-bottom:0.5rem">Currents</strong><span style="color:var(--parchment-dim);display:block;font-size:0.94rem;line-height:1.5">Real-world X posts and other live signals, with the firm&#x27;s public opinion in response.</span></a><a href="/forecasts" style="background:rgba(232, 225, 211, 0.035);border:1px solid rgba(232, 225, 211, 0.14);border-radius:6px;color:inherit;display:block;padding:1rem;text-decoration:none"><strong style="color:var(--amber);display:block;font-family:&#x27;Cinzel&#x27;, serif;letter-spacing:0.03em;margin-bottom:0.5rem">Forecasts</strong><span style="color:var(--parchment-dim);display:block;font-size:0.94rem;line-height:1.5">Prediction-market forecasts with evidence, uncertainty, and eventual calibration.</span></a></div></section><section aria-labelledby="home-manifesto-title" style="border-bottom:1px solid var(--stroke);margin-bottom:1.5rem;padding:0 0 1.75rem"><h2 class="mono" id="home-manifesto-title" style="color:var(--amber-dim);font-size:0.72rem;letter-spacing:0.3em;margin:0 0 0.85rem;text-transform:uppercase">MANIFESTO</h2><p style="color:var(--parchment);font-family:&#x27;EB Garamond&#x27;, serif;font-size:1.18rem;line-height:1.55;margin:0 0 0.85rem;max-width:50rem">Theseus treats intellectual capital as recorded human judgment under pressure: a firm-owned model of reasoning that can consult on decisions, expose assumptions, and carry institutional memory into new work.</p><a href="/about#manifesto" class="mono" style="color:var(--amber);font-size:0.66rem;letter-spacing:0.18em;text-decoration:none;text-transform:uppercase">Read the full manifesto →</a></section><p style="color:var(--parchment-dim);font-size:0.95rem;line-height:1.6;margin:0">Reach the firm at <a href="mailto:hello@theseuscodex.com" style="color:var(--amber);text-decoration:none">hello@theseuscodex.com</a>.</p><footer>Transparency footer</footer></div></main>"`;
