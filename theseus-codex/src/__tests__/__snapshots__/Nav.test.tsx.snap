// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Nav > snapshots the consolidated top nav for a non-admin founder 1`] = `"<nav style="border-bottom:1px solid var(--border);background:var(--stone);position:sticky;top:0;z-index:50"><div style="max-width:1200px;margin:0 auto;padding:1.25rem 1rem;display:flex;align-items:center;justify-content:space-between;min-height:88px;flex-wrap:wrap;gap:0.5rem"><a href="/" aria-label="Theseus Codex — home" style="display:inline-flex;align-items:center;gap:0.55rem;font-family:&#x27;Cinzel&#x27;, serif;font-size:1rem;letter-spacing:0.24em;color:var(--amber);text-decoration:none;font-weight:600;text-shadow:var(--glow-sm)"><span aria-hidden="true">LABYRINTH</span>THESEUS</a><div style="display:flex;flex-wrap:wrap;gap:1rem 1.75rem;justify-content:center"><a href="/dashboard" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);text-decoration:none;transition:color 0.2s">Dashboard</a><a href="/upload" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;transition:color 0.2s">Upload</a><a href="/knowledge" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;transition:color 0.2s">Knowledge</a><a href="/ask" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;transition:color 0.2s">Ask</a><a href="/currents" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;transition:color 0.2s">Currents</a><a href="/forecasts/portfolio" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;transition:color 0.2s">Forecasts</a><a href="/social" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;transition:color 0.2s">Social</a><a href="/ops" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;transition:color 0.2s">Ops</a></div><div style="display:flex;gap:1rem;align-items:center"><a href="/Theseus_Codex_User_Guide.pdf" target="_blank" rel="noopener noreferrer" title="User guide (PDF, 10 pages)" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;border-bottom:1px dotted var(--parchment-dim)">Help</a><a href="/account" title="Account settings" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.65rem;letter-spacing:0.1em;color:var(--gold-dim);text-decoration:none;border-bottom:1px dotted transparent;transition:border-color 0.15s, color 0.15s">Ada Quint<span style="margin-left:0.5rem;color:var(--parchment-dim)">· theseus-local</span></a><button aria-label="Theme toggle" type="button"></button><button class="btn" style="font-size:0.65rem;padding:0.3rem 0.8rem">Sign Out</button></div></div></nav>"`;

exports[`Nav > snapshots the consolidated top nav for an admin 1`] = `"<nav style="border-bottom:1px solid var(--border);background:var(--stone);position:sticky;top:0;z-index:50"><div style="max-width:1200px;margin:0 auto;padding:1.25rem 1rem;display:flex;align-items:center;justify-content:space-between;min-height:88px;flex-wrap:wrap;gap:0.5rem"><a href="/" aria-label="Theseus Codex — home" style="display:inline-flex;align-items:center;gap:0.55rem;font-family:&#x27;Cinzel&#x27;, serif;font-size:1rem;letter-spacing:0.24em;color:var(--amber);text-decoration:none;font-weight:600;text-shadow:var(--glow-sm)"><span aria-hidden="true">LABYRINTH</span>THESEUS</a><div style="display:flex;flex-wrap:wrap;gap:1rem 1.75rem;justify-content:center"><a href="/dashboard" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);text-decoration:none;transition:color 0.2s">Dashboard</a><a href="/upload" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;transition:color 0.2s">Upload</a><a href="/knowledge" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;transition:color 0.2s">Knowledge</a><a href="/ask" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;transition:color 0.2s">Ask</a><a href="/currents" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;transition:color 0.2s">Currents</a><a href="/forecasts/portfolio" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;transition:color 0.2s">Forecasts</a><a href="/social" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;transition:color 0.2s">Social</a><a href="/ops" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;transition:color 0.2s">Ops</a><a href="/founders/manage" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;transition:color 0.2s">Manage</a></div><div style="display:flex;gap:1rem;align-items:center"><a href="/Theseus_Codex_User_Guide.pdf" target="_blank" rel="noopener noreferrer" title="User guide (PDF, 10 pages)" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--parchment-dim);text-decoration:none;border-bottom:1px dotted var(--parchment-dim)">Help</a><a href="/account" title="Account settings" style="font-family:&#x27;Cinzel&#x27;, serif;font-size:0.65rem;letter-spacing:0.1em;color:var(--gold-dim);text-decoration:none;border-bottom:1px dotted transparent;transition:border-color 0.15s, color 0.15s">Ada Quint<span style="margin-left:0.5rem;color:var(--parchment-dim)">· theseus-local</span></a><button aria-label="Theme toggle" type="button"></button><button class="btn" style="font-size:0.65rem;padding:0.3rem 0.8rem">Sign Out</button></div></div></nav>"`;
