// ── Founders (portal users) — maps to FounderProfile in noosphere/models.py ─

model Founder {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  name                    String
  username                String
  email                   String
  passwordHash            String
  // Role ladder — see src/lib/roles.ts for the predicate helpers and
  // the full description of each tier:
  //   admin   → full read + write + can change other founders' roles
  //   founder → full read + write
  //   viewer  → read-only; every write API returns 403 and every UI
  //              affordance for writes is hidden
  // Default "founder" preserves prior behaviour: anyone added via
  // scripts/add-founder.ts is read+write unless explicitly seeded
  // with ADD_FOUNDER_ROLE=viewer or =admin. Validation lives at the
  // application layer; the column stays TEXT so adding a future tier
  // is a docstring + helper change, not a migration.
  role                    String    @default("founder") // admin | founder | viewer
  bio                     String?
  displayName             String?
  roleTitle               String?
  publicUrl               String?
  avatar                  String?
  accountNudgeDismissedAt DateTime?

  /// Maps to FounderProfile.id in Noosphere
  noosphereId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions                   Session[]
  uploads                    Upload[]
  auditEvents                AuditEvent[]
  deletionRequests           DeletionRequest[]
  attributedConclusions      Conclusion[]                @relation("ConclusionFounder")
  researchSuggestions        ResearchSuggestion[]
  reviewResolutions          ReviewItem[]                @relation("ReviewResolver")
  publicationReviews         PublicationReview[]         @relation("PublicationReviewer")
  recalibrationOverrides     RecalibrationOverride[]
  apiKeys                    ApiKey[]
  conclusionDeletionRequests ConclusionDeletionRequest[]
  dashboardDismissals        DashboardDismissal[]
  resolvedContradictions     Contradiction[]             @relation("ContradictionResolver")
  contradictionDisputes      ContradictionDispute[]      @relation("ContradictionDisputeAuthor")
  revisionEvents             RevisionEvent[]
  publicReplies              PublicReply[]               @relation("PublicReplyFounder")
  attentionActions           AttentionAction[]
  decidedCritiques           CritiqueSubmission[]        @relation("CritiqueDecidedBy")
  confirmedBountyPayouts     CritiqueBountyPayout[]      @relation("CritiqueBountyConfirmedBy")
  resolvedClusterReindexes   ClusterReindexProposal[]    @relation("ClusterReindexResolver")

  /// Opt-in flag for the daily morning digest email summarising open
  /// high-severity attention items. Default `false` — silent until the
  /// founder explicitly opts in. See `src/lib/dailyDigestEmail.ts`.
  dailyDigestOptIn Boolean @default(false)

  // Round-18 audit: the @@unique([organizationId, email]) below already
  // creates a btree whose leading column is organizationId, so any
  // equality query on organizationId alone is served by the unique
  // index. The previously-present @@index([organizationId]) was
  // redundant and was dropped in migrations/round18_consolidation.
  @@unique([organizationId, email])
  @@unique([organizationId, username])
}

/// Browser session (server-side row; cookie carries signed opaque token)
model Session {
  id             String   @id @default(cuid())
  organizationId String
  founderId      String
  token          String   @unique
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  founder      Founder      @relation(fields: [founderId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([founderId])
}

// ── Uploads ────────────────────────────────────────────────────────────────

model Upload {
  id             String @id @default(cuid())
  organizationId String
  founderId      String

  title            String
  description      String?
  sourceType       String   @default("written") // written | annotation | external | transcript
  originalName     String
  mimeType         String
  filePath         String
  fileSize         Int
  textContent      String?
  blurb            String?
  // Status ladder (see src/lib/uploadStatus.ts for the canonical
  // vocabulary + UI labels). `pending | processing | ingested | failed`
  // are load-bearing strings from the init migration; `extracting` and
  // `awaiting_ingest` were added alongside the Wave-1 audio/PDF
  // extractors so founders can see which stage of the pipeline a row is
  // in (Whisper/pypdf vs. claim extraction) instead of a single opaque
  // "processing".
  status           String   @default("pending") // pending | extracting | awaiting_ingest | processing | ingested | failed
  processLog       String   @default("") // streamed CLI stdout/stderr
  claimsCount      Int?
  methodCount      Int?
  substCount       Int?
  principleCount   Int?
  errorMessage     String?
  // How the text was obtained for this upload, set by the noosphere
  // extractor dispatcher on success. Free-form string — e.g.
  // "passthrough", "faster-whisper", "openai-whisper-1", "pypdf",
  // "ocrmypdf". Rendered in the dashboard detail row so the founder
  // knows whether a transcript/PDF extract was reliable.
  extractionMethod String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // ── Public blog fields ─────────────────────────────────────────────
  // An Upload becomes a public blog post when `publishedAt IS NOT NULL`.
  // Default is null → the upload remains a private founder artifact.
  // `slug` is the URL-safe identifier used for `/post/:slug`; it's
  // generated from `title` at publish time and guaranteed unique across
  // the whole table (not per-org — the blog is a single public surface).
  // `blogExcerpt` is the card/list summary shown on the index; if null
  // we derive one from the first ~280 chars of `textContent`.
  // `authorBio` lets the founder override the displayed byline (e.g.
  // for guest posts or co-authored work); otherwise we show
  // Founder.name.
  publishedAt DateTime?
  slug        String?   @unique
  blogExcerpt String?
  authorBio   String?

  // ── Soft delete ────────────────────────────────────────────────────
  // `deletedAt` is the single source of truth for "this upload has
  // been removed". Every query that surfaces uploads to the UI must
  // filter by `deletedAt IS NULL`; we keep the row around so the audit
  // trail (AuditEvent pointing at this upload) stays intact, and so a
  // DB-level restore is possible if a deletion turns out to be a
  // mistake. Only the uploader can set this directly; peers must go
  // through a DeletionRequest, which the owner accepts (setting
  // `deletedAt=now`) or declines.
  deletedAt DateTime?

  // ── Visibility inside the firm ─────────────────────────────────────
  // Three-level visibility ladder. Every value still lets Noosphere
  // run ingestion — conclusions, contradictions, open questions, and
  // research suggestions are always extracted. The levels only
  // control *who reads the upload's metadata and contents*.
  //
  // "org"          → visible to every founder in the organization AND
  //                   eligible for blog publication. The default;
  //                   library, dashboard, peer deletion requests, and
  //                   the blog's publishAsPost toggle all apply.
  //
  // "semi-private" → visible to every founder in the organization,
  //                   but never publishable to the public blog. The
  //                   intermediate level, for material the firm wants
  //                   to discuss internally but that must never leak
  //                   outside. /api/publish rejects the flip; the
  //                   public blog index + /post/[slug] both filter
  //                   it out; /library and /dashboard render it with
  //                   a "semi-private" badge so peers know the
  //                   constraint.
  //
  // "private"      → only the uploader can see the row anywhere in
  //                   the UI; Noosphere still ingests it so the owner
  //                   gets their own conclusions/contradictions, but
  //                   nobody else can see the file, read it, or open
  //                   a deletion request against it. Blog-publishing
  //                   a private upload is rejected at the API layer
  //                   — flip visibility first.
  //
  // Column stays TEXT with default "org" so no migration is needed
  // when new levels are introduced; validation happens at the API
  // layer.
  visibility String @default("org")

  // ── Provenance demarcation (prompt 09) ─────────────────────────────
  // Distinct from `visibility` (who-can-see-this) — `provenance`
  // answers WHO AUTHORED the source material. Founder picks one of
  // four at upload time; external choices require `provenanceRationale`
  // (the API rejects an empty rationale for non-PROPRIETARY rows).
  // The synthesizer / Oracle layer weights proprietary 2× by default
  // and gates contradiction tests so STUDIED / OPPOSING aren't pitted
  // against firm material by default (those are *expected* to differ).
  // Existing rows default to PROPRIETARY at migration time; the
  // founder reviews via `/library/triage` and retags as needed.
  provenance          ProvenanceKind @default(PROPRIETARY)
  provenanceRationale String?

  // ── Podcast / audio playback ───────────────────────────────────────
  // When an audio upload is stored in a public CDN-addressable
  // location (Supabase Storage in our case), we persist the public
  // URL here so /post/[slug] can render a <audio controls> player
  // alongside the transcript. `audioDurationSec` is optional
  // metadata derived from ffprobe / client-side duration detection
  // when available; the UI falls back to the player's own duration
  // readout if it's null. Both fields are null for non-audio rows
  // and for audio rows uploaded before Supabase Storage was
  // configured — the blog post still renders, just text-only.
  audioUrl         String?
  audioDurationSec Int?

  founder             Founder              @relation(fields: [founderId], references: [id])
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  chunks              UploadChunk[]
  auditEvents         AuditEvent[]
  deletionRequests    DeletionRequest[]
  // ── Provenance back-refs ─────────────────────────────────────────
  // Derived entities (Conclusions via the M:N join, Contradictions,
  // OpenQuestions, ResearchSuggestions directly) point back here so
  // the delete path can cascade-clean any artifact whose source has
  // been removed. `conclusionSources` is the many-to-many bridge —
  // the same text can be extracted from multiple uploads, and each
  // upload holds its own row in the bridge. The direct sourceUpload
  // relations on the other three entities are one-per-row: a
  // contradiction / open-question / research suggestion is an output
  // of exactly one ingestion run, even when it references claims from
  // multiple uploads.
  conclusionSources   ConclusionSource[]
  methodologyProfiles MethodologyProfile[]
  contradictions      Contradiction[]      @relation("ContradictionSourceUpload")
  openQuestions       OpenQuestion[]       @relation("OpenQuestionSourceUpload")
  researchSuggestions ResearchSuggestion[] @relation("ResearchSuggestionSourceUpload")

  @@index([organizationId])
  @@index([founderId])
  @@index([publishedAt])
  @@index([deletedAt])
  @@index([visibility])
  // Dashboard filters by status constantly (ingested rows on the main
  // panel, failed/pending counts on the banner). A plain btree index
  // is enough — the org-scope is already covered by organizationId.
  @@index([status])
  // Homepage articles rail: `WHERE organizationId AND publishedAt IS
  // NOT NULL AND deletedAt IS NULL AND visibility='org' AND slug IS NOT
  // NULL ORDER BY publishedAt DESC`. The four existing single-column
  // indexes are individually unselective enough that the planner
  // falls back to a seq scan; this composite serves the exact predicate
  // and ordering used by `listUploadArticles` in
  // `src/lib/publicSurface.ts`. The partial WHERE keeps the index tiny
  // (only published, non-deleted rows). Sort:Desc on `publishedAt`
  // lets the planner walk the index in order and stop at LIMIT N.
  @@index([organizationId, publishedAt(sort: Desc), id])
  // Dashboard "recent uploads" panel orders by `createdAt DESC` over
  // the org; without this, every dashboard render sorted 3k+ rows in
  // memory. Same shape, different timestamp than the public rail.
  @@index([organizationId, createdAt(sort: Desc)])
  // Prompt 09 — Oracle / synthesis filter and the library page both
  // scope by `organizationId AND provenance` and order by `createdAt
  // DESC`. The composite keeps the planner from falling back to a seq
  // scan when only the endorsed-external bucket is requested.
  @@index([organizationId, provenance, createdAt(sort: Desc)])
}

model UploadChunk {
  id           String   @id @default(cuid())
  uploadId     String
  index        Int
  text         String
  startMs      Int?
  endMs        Int?
  speakerLabel String?
  headingHint  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  upload Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@unique([uploadId, index])
  @@index([uploadId])
}

// ── DeletionRequest ───────────────────────────────────────────────────
// Peer-to-peer "please delete this" workflow. A founder who doesn't own
// an upload but wants it removed opens a request against that upload;
// the owner reviews it (accept → soft-delete the upload, decline → log
// reason and keep). The requester can cancel their own request at any
// time before the owner responds.
//
// Enforcement:
//   * Requester.organizationId must equal Upload.organizationId (done
//     at route-handler level, not schema — cross-org requests are
//     structurally unreachable via UI anyway).
//   * Requester.id MUST NOT equal Upload.founderId (an owner deletes
//     their own upload directly via DELETE /api/uploads/:id; opening
//     a request against yourself is noise).
//   * At most one ACTIVE (status=pending) request per (upload, requester)
//     pair — the unique partial-index is added in the migration SQL.

model DeletionRequest {
  id          String    @id @default(cuid())
  uploadId    String
  requesterId String
  status      String    @default("pending") // pending | accepted | declined | cancelled
  reason      String?
  decision    String? // optional note from the owner when accepting/declining
  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  upload    Upload  @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  requester Founder @relation(fields: [requesterId], references: [id])

  @@index([uploadId])
  @@index([requesterId])
  @@index([status])
}

// ── Conclusion — mirrors noosphere.models.Conclusion ───────────────────────

model Conclusion {
  id             String @id @default(cuid())
  organizationId String

  /// Stable id if synced from / produced for Noosphere
  noosphereId String? @unique
  text        String

  // ── Dedup key ──────────────────────────────────────────────────────
  // `normalizedText` is `LOWER(TRIM(REGEXP_REPLACE(text, '\s+', ' ')))`
  // computed once at ingest time. The ingest pipeline checks for an
  // existing Conclusion in the same org with a matching normalizedText;
  // if one exists, it adds the current upload as an ADDITIONAL source
  // via ConclusionSource rather than inserting a duplicate row. That's
  // what makes deletion correct: when two uploads produced the same
  // claim and we delete one, the conclusion stays — it's still
  // supported by the other source.
  //
  // Nullable so the column can be added to an existing DB without a
  // rewrite; the migration back-fills every existing row. Indexed
  // `(organizationId, normalizedText)` because every lookup is scoped
  // to a single org.
  normalizedText         String?
  confidenceTier         String // firm | founder | open (ConfidenceTier)
  rationale              String   @default("")
  supportingPrincipleIds String   @default("[]") // JSON string[]
  evidenceChainClaimIds  String   @default("[]")
  dissentClaimIds        String   @default("[]")
  confidence             Float    @default(0)
  topicHint              String   @default("") // UI filter / display
  createdAt              DateTime @default(now())

  /// JSON-serialized float[] embedding produced by Noosphere's sentence
  /// encoder at ingest time. Null for conclusions ingested before this
  /// column was added; the semantic explorer backfills on demand.
  embeddingJson String?

  // ── Principle-shape contract (prompt 56, 2026-05-13) ───────────────
  // Populated by the rewritten principle extractor in
  // `noosphere.claim_extractor.PrincipleExtractor`. Legacy rows leave
  // these null until they pass through the founder-confirmable
  // re-extraction queue at `/extractor/re-extract`.
  /// One of RULE | CRITERION | MECHANISM | HEURISTIC | DEFINITION |
  /// FORMULA | ALGORITHM. Null on legacy conclusions.
  principleKind         String?
  /// ≤ 300 chars: where the rule applies, where it does not. Null on
  /// legacy conclusions.
  domainOfApplicability String?
  /// JSON string[] of metric / dataset names that could
  /// operationalise the principle. Feeds the quantitative-bridge
  /// pipeline (prompts 57 + 64). Defaults to "[]".
  quantifiableProxies   String  @default("[]")
  /// JSON string[] of ≤ 3 example decisions the principle would
  /// inform. Defaults to "[]".
  decisionExamples      String  @default("[]")
  /// Verbatim substring of the source span the principle was lifted
  /// from. Preserved end-to-end so the re-extraction review page can
  /// show the founder the original context. Null on legacy rows.
  sourceSpan            String?

  attributedFounderId     String?
  attributedFounder       Founder?                    @relation("ConclusionFounder", fields: [attributedFounderId], references: [id])
  organization            Organization                @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  publicationReviews      PublicationReview[]
  sources                 ConclusionSource[]
  methodologyProfiles     MethodologyProfile[]
  /// Optional MQS row (1:1). Built by `noosphere mqs backfill`; re-runnable
  /// without rewriting the underlying methodology profile.
  methodologyQualityScore MethodologyQualityScore?
  conclusionMethods       ConclusionMethod[]
  domainBoundVerdicts     DomainBoundVerdict[]
  recalibrationOverride   RecalibrationOverride?
  deletionRequests        ConclusionDeletionRequest[]
  dashboardDismissals     DashboardDismissal[]

  /// Conclusion edit timestamp; the public MQS pill is only shown when the
  /// MQS row's `scoredAt` is at least this recent.
  updatedAt DateTime? @updatedAt

  @@index([organizationId])
  @@index([organizationId, normalizedText])
  // Dashboard "recent conclusions" panel orders by `createdAt DESC`
  // over the org and takes 8. ~12k Conclusion rows per org in
  // production means the prior plan (index scan on organizationId →
  // in-memory sort) hit ~400 ms p95. This composite serves the
  // ORDER BY directly so the LIMIT short-circuits.
  @@index([organizationId, createdAt(sort: Desc)])
}

/// Many-to-many bridge Conclusion ↔ Upload.
///
/// Every conclusion that came out of the ingest pipeline has at least
/// one row here tying it back to the upload it was extracted from.
/// When the SAME normalized text appears in multiple uploads, the
/// ingest pipeline reuses the existing Conclusion row and adds a new
/// ConclusionSource row per additional upload, so the upstream count
/// can drop from 2 → 1 → 0 as uploads are deleted.
///
/// Delete semantics (enforced by the app-side delete handlers, NOT by
/// FK cascade — we soft-delete uploads, so the FK's ON DELETE CASCADE
/// would not fire anyway):
///
///   * When an upload is soft-deleted, every ConclusionSource row
///     with that uploadId is hard-deleted.
///   * After that, any Conclusion with zero remaining rows is
///     hard-deleted too (the claim's last source is gone).
///   * Conclusions with sources from other uploads remain, just
///     with one fewer row.
///
/// The FK cascade below still serves as a safety net for the rare
/// case of a hard-delete (org takedown, privacy-law purge).
model ConclusionSource {
  conclusionId String
  uploadId     String
  createdAt    DateTime @default(now())

  conclusion Conclusion @relation(fields: [conclusionId], references: [id], onDelete: Cascade)
  upload     Upload     @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@id([conclusionId, uploadId])
  @@index([conclusionId])
  @@index([uploadId])
}

// ── Publication (SP10) — review queue + versioned public snapshots ───────────

/// Internal gate before a conclusion may appear on the public site.
model PublicationReview {
  id             String @id @default(cuid())
  organizationId String
  conclusionId   String

  /// queued | in_review | needs_revision | declined | published
  status        String @default("queued")
  /// JSON: { metaAnalysisOk, adversarialEngagedOk, clarityOk, noLeakageOk }
  checklistJson String @default("{}")
  reviewerNotes String @default("")
  declineReason String @default("")
  revisionAsk   String @default("")

  reviewerFounderId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  target       Conclusion   @relation(fields: [conclusionId], references: [id], onDelete: Cascade)
  reviewer     Founder?     @relation("PublicationReviewer", fields: [reviewerFounderId], references: [id])

  @@index([organizationId])
  @@index([conclusionId])
  @@index([status])
}

/// Immutable-ish public snapshot (new row per material revision).
model PublishedConclusion {
  id                 String @id @default(cuid())
  organizationId     String
  sourceConclusionId String

  slug    String
  version Int    @default(1)
  /// CONCLUSION for reviewed firm conclusions; ARTICLE for generated longform essays.
  kind    String @default("CONCLUSION")

  /// Headline discounted confidence (SP05); stated founder/model confidence alongside in JSON.
  discountedConfidence      Float
  statedConfidence          Float  @default(0)
  calibrationDiscountReason String @default("")

  /// Full page payload: evidence, exit conditions, adversarial, voice map, timeline, citations.
  payloadJson String @default("{}")

  /// Zenodo DOI for this revision (minted on first publish of revision).
  doi            String @default("")
  zenodoRecordId String @default("")

  publishedAt DateTime @default(now())

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  responses    PublicResponse[]
  signature    PublicationSignature?

  // Natural key for the public surface: a slug + revision integer
  // identifies one immutable snapshot. Republishing a conclusion bumps
  // version; the (slug, version) tuple is the URL-stable identity.
  @@unique([slug, version])
  @@index([organizationId])
  @@index([slug])
  @@index([kind, publishedAt])
  // Homepage conclusions rail does a `DISTINCT ON (slug)` after
  // `WHERE organizationId AND kind='CONCLUSION'`, ordering by
  // `slug, version DESC`. The existing `(kind, publishedAt)` composite
  // has the wrong leading column and doesn't serve the slug-ordered
  // DISTINCT ON; this one is the exact access path used by
  // `listHomepageConclusions` and `listPublishedArticles` in
  // `src/lib/publicSurface.ts` + `src/lib/conclusionsRead.ts`.
  @@index([organizationId, kind, slug, version(sort: Desc)])
  // Articles list reads `WHERE organizationId AND kind='ARTICLE' ORDER
  // BY publishedAt DESC LIMIT N`. Same leading-org+kind pair, ordered
  // by publishedAt so the LIMIT short-circuits on the index walk.
  @@index([organizationId, kind, publishedAt(sort: Desc)])
}

/// Cryptographic signature for a PublishedConclusion.
///
/// Generated by the noosphere CLI (`noosphere ledger sign-publication`) at
/// the publish moment. Private signing keys NEVER live in the web app; the
/// web app stores the signature artifact and serves it via
/// /api/public/signature/[slug]. Readers can re-verify with
/// `noosphere ledger verify-publication <slug>`.
model PublicationSignature {
  id                    String @id @default(cuid())
  publishedConclusionId String @unique
  slug                  String
  version               Int

  /// Hex-encoded SHA-256 of the canonicalized inputs (see noosphere.ledger.canonicalize).
  canonicalHash  String
  /// Hex-encoded Ed25519 signature over the canonical hash bytes.
  signatureHex   String
  /// Short fingerprint (sha256[:16]) of the verify key used to sign.
  keyFingerprint String
  /// ISO-8601 UTC timestamp at the moment of signing.
  signedAt       String

  /// Full PublicationSignature artifact as JSON (canonicalInput + signature),
  /// served verbatim to the public verifier.
  payloadJson String @default("{}")

  createdAt DateTime @default(now())

  publishedConclusion PublishedConclusion @relation(fields: [publishedConclusionId], references: [id], onDelete: Cascade)

  @@index([slug, version])
  @@index([keyFingerprint])
}

// ── Self-critique addenda ──────────────────────────────────────────────────
//
// Quarterly self-critique (see `noosphere/peer_review/self_critique.py`)
// can recommend that a published article carry a dated addendum block —
// "On <date> the firm re-reviewed this article and found <summary>".
// The addendum is visibly later content; the original article body is
// never edited through this path. Only `publishedAt` is shown publicly;
// `pending` and `dismissed` rows are operator-only.
model Addendum {
  id             String @id @default(cuid())
  organizationId String

  /// Slug of the article the addendum attaches to. We key by slug (not
  /// publishedConclusionId) so a generated-article post and its
  /// matching `PublishedConclusion` row can share addenda without
  /// having to be linked through the same id.
  articleSlug String

  /// Optional pointer at the noosphere-side article id, kept for audit
  /// trails so the founder can correlate an addendum with the upstream
  /// run.
  noosphereArticleId String?

  /// The self-critique finding that produced this addendum (free-form
  /// — used only for cross-referencing).
  findingId String @default("")

  /// One-sentence summary shown in the public block ("the firm
  /// re-reviewed this article and found …").
  summary String @db.Text
  /// Full body of the addendum. Markdown is allowed; the public page
  /// renders it inside a dated block below the original article.
  body    String @default("") @db.Text

  /// pending | published | dismissed. Only `published` rows surface on
  /// the public page; `dismissed` carries `dismissedReason`.
  status String @default("pending")

  /// Free-form label of the reviewer configuration that produced the
  /// finding (e.g. `self-critique:v1`). Recorded so the firm can prove
  /// the self-critique pass used a configuration distinct from the
  /// original publication's swarm.
  reviewerConfig String @default("")

  createdAt       DateTime  @default(now())
  publishedAt     DateTime?
  dismissedAt     DateTime?
  dismissedReason String    @default("") @db.Text

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId, articleSlug, status])
  @@index([articleSlug, status, publishedAt])
}

// ── Open critique invitation (challenge-this) ──────────────────────────────
//
// Outside experts critique a specific firm conclusion through a
// structured form (see `src/components/ChallengeThisCta.tsx`). The
// submission lands in `CritiqueSubmission` (distinct from
// `PublicResponse` so general inbox traffic does not hide invited
// expert critique). The founder routes the row through the moderation
// states `pending → accepted | partial | rejected`. Accepted critiques
// are signed alongside the article and appear on the public
// `/critiques` hall-of-fame.
//
// Bounty: when the founder marks an accepted critique as severity
// `high` (per `noosphere.peer_review.severity`), the system queues a
// `CritiqueBountyPayout` row in `pending_founder_confirmation`. No
// payout fires until the founder explicitly confirms — the payouts
// pipeline is the eventual sender, not the codex.
model CritiqueSubmission {
  id             String @id @default(cuid())
  organizationId String

  /// Article this critique is aimed at — keyed by slug so the
  /// challenge form on a generated-article post and a
  /// `PublishedConclusion` row can both file critiques against the
  /// same target.
  articleSlug           String
  /// Optional pointer at the underlying `PublishedConclusion.id` when
  /// the article is a reviewed firm conclusion.
  publishedConclusionId String?

  /// Specific claim the critic challenges (free-form text — the
  /// canonical claim id is not exposed publicly).
  targetClaim      String @db.Text
  /// Counter-evidence presented by the critic.
  counterEvidence  String @db.Text
  /// Method used to derive the counter-evidence ("how did you arrive
  /// at this?" — replication, audit, lit review, expert opinion).
  derivationMethod String @db.Text
  /// Citations supporting the counter-evidence (one URL per line).
  citations        String @default("") @db.Text

  /// Critic identity / display preferences. Email is required so the
  /// founder can contact the critic about bounty / partial discussion.
  /// `displayName` and `publicUrl` are what the public hall-of-fame
  /// renders when the critique is accepted.
  submitterEmail String
  displayName    String @default("")
  publicUrl      String @default("")
  bio            String @default("") @db.Text
  orcid          String @default("")

  /// pending | accepted | partial | rejected | archived
  status        String @default("pending")
  /// Reason recorded by the founder when status moves out of `pending`.
  /// For partial: explains why it's a private discussion. For rejected:
  /// shown to the critic in the rejection email.
  moderatorNote String @default("") @db.Text

  /// Round-17 prompt 44 open-critique pilot tag. Empty for ordinary
  /// inbound critique; set to the pilot identifier (e.g.
  /// `round17_pilot_2026Q2`) when the row arrived via a per-reviewer
  /// pre-shared link. The founder queue routes pilot rows to the top
  /// while the pilot window is open (see
  /// `noosphere.social.critique_routing.pilot_priority_sort`).
  pilotTag          String  @default("")
  /// Slug of the specific pilot reviewer who filed this critique
  /// (e.g. `peer-reviewer-a`). Maps to the per-reviewer pre-shared
  /// link defined in `src/lib/critiquePilot.ts`. Empty for non-pilot.
  pilotReviewerSlug String  @default("")
  /// Explicit consent for the critic's name / URL to appear on the
  /// public hall-of-fame at `/critiques`. Off by default — the
  /// pilot intake form requires the critic to opt in before any
  /// public attribution.
  hallOfFameConsent Boolean @default(false)

  /// Severity label assigned at acceptance time per the rubric in
  /// `noosphere.peer_review.severity` — "low" | "medium" | "high".
  /// Only `high` makes the critique bounty-eligible.
  severityLabel String @default("")
  /// Cached severity value in [0, 1].
  severityValue Float  @default(0)

  /// Founder who acted on the row (accepted/rejected). Null while
  /// pending.
  decidedById String?
  decidedAt   DateTime?

  /// Set when the critique materially changed an article — points at
  /// the `RevisionEvent.id` produced by routing through prompt 16.
  triggeredRevisionId String?
  /// Set when the critique drove an `Addendum` row (prompt 43).
  addendumId          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  decidedBy    Founder?              @relation("CritiqueDecidedBy", fields: [decidedById], references: [id])
  bounty       CritiqueBountyPayout?

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, articleSlug, status])
  @@index([severityValue])
  @@index([organizationId, pilotTag, status])
}

/// Queued bounty payout for an accepted high-severity critique.
///
/// The codex never sends money. It records intent (`amountUsd`,
/// `payoutMode`, `destination`) and waits in
/// `pending_founder_confirmation` until the founder explicitly confirms
/// in the queue UI. Confirmation flips the row to `confirmed`, which is
/// what the firm's external payouts pipeline picks up.
///
/// Critics may direct the bounty to a charity instead of accepting it
/// personally — `payoutMode = "charity"` carries the chosen charity in
/// `destination`.
model CritiqueBountyPayout {
  id             String @id @default(cuid())
  organizationId String

  critiqueSubmissionId String @unique

  /// Default 500 (USD); configurable per-org via the queue UI before
  /// the founder confirms.
  amountUsd   Int    @default(500)
  /// "self" — paid to the critic's email of record. "charity" —
  /// donated to the charity captured in `destination`.
  payoutMode  String @default("self")
  /// For payoutMode=self: "" (use submitter email). For
  /// payoutMode=charity: the charity name / URL the critic chose.
  destination String @default("")

  /// pending_founder_confirmation | confirmed | cancelled
  status           String @default("pending_founder_confirmation")
  /// Reason recorded if cancelled.
  cancellationNote String @default("")

  /// `confirmed`-state metadata — set only after the founder confirms.
  confirmedById String?
  confirmedAt   DateTime?
  /// External payouts-pipeline reference id (set by the off-codex job
  /// that actually disburses funds; the codex only stores it for the
  /// audit trail).
  externalRef   String    @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  critiqueSubmission CritiqueSubmission @relation(fields: [critiqueSubmissionId], references: [id], onDelete: Cascade)
  confirmedBy        Founder?           @relation("CritiqueBountyConfirmedBy", fields: [confirmedById], references: [id])

  @@index([organizationId])
  @@index([organizationId, status])
}

// ── Methodology profiles ───────────────────────────────────────────────────

/// A durable description of how a piece of material reasons, not merely what it
/// concludes. Noosphere writes these from transcripts/uploads and reanalysis
/// scripts; publication review can attach them to public conclusions.
model MethodologyProfile {
  id             String  @id @default(cuid())
  organizationId String
  uploadId       String?
  conclusionId   String?

  /// UPLOAD when derived from a transcript/artifact; CONCLUSION when derived
  /// from a conclusion/publication review; MANUAL for founder-authored method
  /// summaries.
  sourceKind String @default("UPLOAD")

  patternType String
  title       String
  summary     String @db.Text

  reasoningMoves  Json
  transferTargets Json
  assumptions     Json
  failureModes    Json
  evidenceAnchors Json

  confidence Float  @default(0.5)
  dedupeKey  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  upload       Upload?      @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  conclusion   Conclusion?  @relation(fields: [conclusionId], references: [id], onDelete: Cascade)

  @@unique([organizationId, dedupeKey])
  @@index([organizationId, createdAt])
  @@index([organizationId, patternType])
  @@index([uploadId])
  @@index([conclusionId])
}

// ── Methodology Quality Score (MQS) ─────────────────────────────────────────

/// Operational form of the five working criteria from `THE_META_METHOD.md`:
/// progressivity, severity, aim-method fit, compressibility, domain sensitivity.
///
/// One row per Conclusion. The score is additive — it never silently mutates a
/// MethodologyProfile — and re-runnable: `noosphere mqs backfill` overwrites
/// the existing row in place using the conclusion id as the unique key.
///
/// The composite is intentionally not a simple mean. Domain Sensitivity acts
/// as a multiplicative gate; the canonical formula is documented in
/// `docs/methods/MQS_Specification.md` and verified by
/// `scripts/check_mqs_doc_consistency.py`.
model MethodologyQualityScore {
  id             String @id @default(cuid())
  organizationId String

  /// 1:1 with Conclusion. The unique constraint enforces the relation.
  conclusionId String @unique

  progressivity     Float
  severity          Float
  aimMethodFit      Float
  compressibility   Float
  domainSensitivity Float
  composite         Float

  /// JSON blob with one entry per sub-score plus the composite formula and
  /// schema version, so a human reviewer can inspect and contest the score.
  evidence Json

  /// Identity of the producer so re-runs can be reasoned about (e.g.
  /// "anthropic/claude-opus-4-7" + "mqs-prompt-v1.0").
  modelName     String @default("stub")
  promptVersion String @default("mqs-prompt-v1.0")

  scoredAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  conclusion   Conclusion   @relation(fields: [conclusionId], references: [id], onDelete: Cascade)

  @@index([organizationId, scoredAt])
  @@index([organizationId, composite])
}

// ── Currents — observed external events + source-grounded opinions ──────────

model CurrentEvent {
  id              String             @id @default(cuid())
  organizationId  String
  source          CurrentEventSource
  externalId      String
  authorHandle    String?
  text            String             @db.Text
  url             String?
  capturedAt      DateTime           @default(now())
  observedAt      DateTime
  topicHint       String?
  isNearDuplicate Boolean            @default(false)
  embedding       Bytes?
  metrics         Json?
  status          CurrentEventStatus @default(OBSERVED)
  dedupeHash      String             @unique
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  opinions     EventOpinion[]

  @@index([organizationId, observedAt])
  @@index([organizationId, status])
}

model EventOpinion {
  id               String            @id @default(cuid())
  organizationId   String
  eventId          String
  stance           OpinionStance
  confidence       Float
  headline         String            @db.VarChar(140)
  bodyMarkdown     String            @db.Text
  uncertaintyNotes String[]
  topicHint        String?
  modelName        String
  promptTokens     Int               @default(0)
  completionTokens Int               @default(0)
  abstentionReason AbstentionReason?
  generatedAt      DateTime          @default(now())
  revokedAt        DateTime?
  revokedReason    String?

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  event            CurrentEvent      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  citations        OpinionCitation[]
  followUpSessions FollowUpSession[]

  @@index([organizationId, generatedAt])
  @@index([eventId])
}

model OpinionCitation {
  id                    String    @id @default(cuid())
  opinionId             String
  sourceKind            String
  conclusionId          String?
  claimId               String?
  quotedSpan            String    @db.Text
  retrievalScore        Float
  justificationMetadata Json      @default("{}")
  isRevoked             Boolean   @default(false)
  revokedAt             DateTime?
  revokedReason         String?

  opinion EventOpinion @relation(fields: [opinionId], references: [id], onDelete: Cascade)

  @@index([opinionId])
  @@index([conclusionId])
  @@index([claimId])
}

model FollowUpSession {
  id                String   @id @default(cuid())
  opinionId         String
  clientFingerprint String
  createdAt         DateTime @default(now())
  lastActivityAt    DateTime @default(now())

  opinion  EventOpinion      @relation(fields: [opinionId], references: [id], onDelete: Cascade)
  messages FollowUpMessage[]

  @@index([opinionId, lastActivityAt])
  @@index([clientFingerprint, createdAt])
}

model FollowUpMessage {
  id        String       @id @default(cuid())
  sessionId String
  role      FollowUpRole
  content   String       @db.Text
  citations Json?
  createdAt DateTime     @default(now())

  session FollowUpSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// ── Social publishing — held outbound posts with a hard human gate ─────────

model SocialPost {
  id             String    @id @default(cuid())
  organizationId String
  createdAt      DateTime  @default(now())
  source         String
  sourceId       String?
  platform       String
  bundleId       String?   @db.Uuid
  body           String    @db.Text
  markdownBody   String?   @db.Text
  subject        String?
