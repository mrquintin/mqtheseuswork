/// Structured reader responses — moderation queue (SP10).
model PublicResponse {
  id             String @id @default(cuid())
  organizationId String

  publishedConclusionId String

  /// counter_evidence | counter_argument | clarification | agreement_extension
  kind           String
  body           String
  citationUrl    String  @default("")
  submitterEmail String  @default("")
  orcid          String  @default("")
  pseudonymous   Boolean @default(false)

  /// Did the responder consent to having their response published if
  /// the firm decides to reply publicly? Captured per-response on the
  /// submission form (Round 17 prompt 31). When false, the founder
  /// queue suppresses the "Promote to PublicReply" affordance and the
  /// public-article appendix never renders this row.
  publishConsent Boolean @default(false)

  /// pending | approved | rejected | engaged | archived
  status        String @default("pending")
  moderatorNote String @default("")

  createdAt DateTime  @default(now())
  seenAt    DateTime?

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  published    PublishedConclusion @relation(fields: [publishedConclusionId], references: [id], onDelete: Cascade)
  triage       ResponseTriage?
  publicReply  PublicReply?

  @@index([organizationId])
  @@index([publishedConclusionId])
  @@index([status])
  @@index([seenAt])
}

// ── Round 17 prompt 31: response triage + dialog loop ──────────────────────
//
// `ResponseTriage` is a 1:1 sidecar to `PublicResponse` written by the
// Python classifier in `noosphere/literature/response_triage.py`. The
// triage row is the queue's source of priority (substantive vs noise);
// the founder retains the override via `manualLabel` / `manualReason`.
//
// The plaintext submitter email is NEVER duplicated here; we only keep
// the SHA-256 hash so the queue can flag repeat-spam senders without
// expanding the PII surface.
model ResponseTriage {
  id               String @id @default(cuid())
  organizationId   String
  publicResponseId String @unique

  /// SUBSTANTIVE_OBJECTION | CLARIFICATION_REQUEST | GENERAL_ENGAGEMENT | SPAM_NOISE
  label       String
  /// Founder override of `label`. Empty string = honour the classifier label.
  manualLabel String @default("")

  /// "" | too_short | promotional_link | off_topic | abusive_language | repeat_sender | low_information
  spamReason   String @default("")
  /// Founder override of `spamReason` (audit trail; e.g. when un-spamming).
  manualReason String @default("")

  confidence       Float
  /// One-sentence reduction of the implied objection. Empty unless
  /// label == SUBSTANTIVE_OBJECTION. Feeds the severity rubric.
  impliedObjection String  @default("") @db.Text
  rationale        String  @default("") @db.Text
  usedLlm          Boolean @default(false)

  /// SHA-256 of the lowercased submitter email; "" for pseudonymous.
  senderHash         String  @default("")
  elevatedSenderFlag Boolean @default(false)

  /// Severity input snapshot from the cascade graph at triage time —
  /// stored so the queue can sort by potential severity without a
  /// fresh cascade traversal on every page render. JSON shape mirrors
  /// `SeverityInputs` in `noosphere/peer_review/severity.py`.
  severityInputsJson String @default("{}")
  /// Cached numeric severity in [0, 1] derived from the snapshot.
  severityValue      Float  @default(0)

  createdAt   DateTime  @default(now())
  /// Set when the founder archives the row (spam path or
  /// substantive-but-handled). Archived rows drop out of the queue.
  archivedAt  DateTime?
  archiveNote String    @default("")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  publicResponse PublicResponse @relation(fields: [publicResponseId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, label])
  @@index([organizationId, archivedAt, severityValue])
  @@index([senderHash])
}

// `PublicReply` is the founder's reply, attached to a single
// `PublicResponse`. The founder can mark it `private` (emailed back to
// the responder; never published) or `public` (rendered in the article
// appendix). Public replies require BOTH the responder's
// `publishConsent` AND the founder's confirmation here — symmetric
// double opt-in, so neither side can publish unilaterally.
model PublicReply {
  id               String @id @default(cuid())
  organizationId   String
  publicResponseId String @unique
  founderId        String

  /// private | public
  visibility String @default("private")
  body       String @db.Text

  /// True only when the founder explicitly confirmed the publish step
  /// AND the underlying PublicResponse.publishConsent was true at the
  /// time of confirmation. Snapshotted here so a later consent-revoke
  /// does not change the audit record.
  publishConfirmed   Boolean   @default(false)
  publishConfirmedAt DateTime?

  /// Whether this reply also opened a review-queue item for the
  /// implied objection. Track here so the queue UI can show "already
  /// promoted" without a join.
  promotedToReview    Boolean @default(false)
  /// Whether the reply triggered a revision-engine (prompt 16) input.
  /// Stores the RevisionEvent.id when set.
  triggeredRevisionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  publicResponse PublicResponse @relation(fields: [publicResponseId], references: [id], onDelete: Cascade)
  // Round-18 audit: relation FK left at the Prisma default
  // (ON DELETE RESTRICT). The reply carries consent attribution that
  // must not be lost if a founder is removed — Founder rows are
  // deactivated, not deleted, by firm policy.
  founder        Founder        @relation("PublicReplyFounder", fields: [founderId], references: [id])

  @@index([organizationId])
  @@index([organizationId, visibility, publishConfirmed])
}

model ContactSubmission {
  id             String    @id @default(cuid())
  createdAt      DateTime  @default(now())
  fromName       String
  fromEmail      String
  subject        String?
  body           String
  organizationId String?
  ipHash         String
  userAgent      String?
  triagedAt      DateTime?
  triagedBy      String?
  notes          String?

  @@index([createdAt])
  @@index([fromEmail])
  @@index([ipHash, createdAt])
  @@index([triagedAt, createdAt])
}

// ── ContradictionFinding + scores — mirrors pipeline outputs ────────────────

model Contradiction {
  id             String @id @default(cuid())
  organizationId String

  claimAId     String
  claimBId     String
  severity     Float
  sixLayerJson String?
  narrative    String   @default("")
  createdAt    DateTime @default(now())

  // ── Canonical contradiction engine (R19/p06) ──────────────────────
  // New rows written by `ContradictionEngine` carry these fields. Old
  // rows produced by the six-heuristic vote leave them null / defaulted
  // until the deletion pass (prompt 16) drops the legacy path. The
  // engine writes ONE detection per pair per `detectionMethod` so
  // `detectionMethod` participates in analytics groupings; older rows
  // keep the default empty string so the column index stays useful.
  score            Float?
  confidenceLow    Float?
  confidenceHigh   Float?
  axis             String?
  humanExplanation String?
  detectionMethod  String    @default("")
  disputeCount     Int       @default(0)
  lastDisputeAt    DateTime?

  // ── Source tracking ───────────────────────────────────────────────
  // The upload whose ingestion run produced this contradiction row.
  // Nullable so the column can be backfilled from `noosphereId` patterns
  // on existing rows; the ingest pipeline sets it on every new row.
  // When the source upload is deleted the contradiction is hard-deleted
  // in the same transaction (see src/app/api/upload/[id]/delete/route.ts);
  // cross-upload contradictions (where claimA and claimB come from
  // different uploads) additionally die if EITHER of their referenced
  // Conclusions has already been orphan-deleted.
  sourceUploadId String?
  sourceUpload   Upload? @relation("ContradictionSourceUpload", fields: [sourceUploadId], references: [id])

  // ── Resolution tracking ────────────────────────────────────────────
  // A contradiction starts "active". A founder can resolve it
  // (acknowledged + addressed with a note) or dismiss it (false
  // positive). Non-active rows are hidden from the main view by
  // default but preserved for audit.
  status       String    @default("active") // active | resolved | dismissed
  resolution   String?
  resolvedById String?
  resolvedAt   DateTime?
  resolvedBy   Founder?  @relation("ContradictionResolver", fields: [resolvedById], references: [id])

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  disputes     ContradictionDispute[]
  lifecycle    ContradictionLifecycle?
  testTasks    ContradictionTestTask[] @relation("ContradictionTestTaskResult")

  @@index([organizationId])
  @@index([sourceUploadId])
  @@index([status])
  // Dashboard operational signals filter `WHERE organizationId AND
  // status='active' ORDER BY severity DESC, createdAt DESC`. The
  // existing `(organizationId)` and `(status)` indexes are each
  // unselective alone; this composite serves both the equality and
  // the leading sort column, so the ORDER BY collapses to an index
  // walk + LIMIT.
  @@index([organizationId, status, severity(sort: Desc)])
  @@index([detectionMethod])
}

// ── ContradictionDispute ──────────────────────────────────────────────
// Founder DISPUTE on a row produced by ContradictionEngine. Multiple
// disputes on the same `detectionMethod` trigger a calibration review
// (the threshold lives in the operator UI, not in the schema). Disputes
// are append-only; the parent Contradiction's `disputeCount` /
// `lastDisputeAt` columns mirror this table for cheap reads.

model ContradictionDispute {
  id              String   @id @default(cuid())
  contradictionId String
  organizationId  String
  detectionMethod String   @default("")
  disputedById    String?
  reason          String   @default("")
  createdAt       DateTime @default(now())

  contradiction Contradiction @relation(fields: [contradictionId], references: [id], onDelete: Cascade)
  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  disputedBy    Founder?      @relation("ContradictionDisputeAuthor", fields: [disputedById], references: [id])

  @@index([contradictionId])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([detectionMethod, createdAt(sort: Desc)])
}

// ── ContradictionLifecycle ────────────────────────────────────────────
// Source-driven lifecycle of a Contradiction (Round 19 prompt 19).
// The manual "resolve" path was removed: contradictions persist as
// first-class entities until new source ingestion either weakens one
// side, fully resolves the disagreement in favour of one side, or the
// synthesis engine flags a candidate principle that subsumes both
// (founder-confirmed).
//
// ``eventsJson`` is an append-only event log; every transition adds
// one record but earlier ones are never overwritten. The denormalised
// ``currentStatus`` / ``lastTransitionAt`` columns mirror the tail of
// the log so the queue is a cheap range scan.

model ContradictionLifecycle {
  id                            String   @id @default(cuid())
  contradictionId               String   @unique
  organizationId                String
  // DETECTED | STANDING | WEAKENED | RESOLVED_BY_SOURCE
  // | DISPUTED_AS_ERROR | SUBSUMED_BY_SYNTHESIS
  currentStatus                 String   @default("DETECTED")
  lastTransitionAt              DateTime @default(now())
  // JSON list of LifecycleEvent objects. Append-only.
  eventsJson                    String   @default("[]")
  supportedPrincipleId          String?
  subsumingPrincipleId          String?
  // Set when the synthesis engine flags a candidate that supersedes
  // both sides. The founder triages from the subsumption queue and
  // either accepts (→ SUBSUMED_BY_SYNTHESIS) or rejects (clears this
  // field; status stays STANDING).
  pendingSubsumptionPrincipleId String?

  contradiction Contradiction @relation(fields: [contradictionId], references: [id], onDelete: Cascade)
  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId, currentStatus, lastTransitionAt(sort: Desc)])
  @@index([currentStatus])
  @@index([pendingSubsumptionPrincipleId])
}

// ── ConclusionDeletionRequest ─────────────────────────────────────────
// Peer-to-peer "please delete this conclusion" workflow, mirroring
// DeletionRequest for uploads. A founder opens a request; the
// conclusion's attributed founder (or an admin) accepts or declines.
// On accept: hard-delete the Conclusion (and its ConclusionSource rows
// via FK cascade) so it's purged from the model.

model ConclusionDeletionRequest {
  id           String    @id @default(cuid())
  conclusionId String
  requesterId  String
  status       String    @default("pending") // pending | accepted | declined | cancelled
  reason       String?
  decision     String?
  createdAt    DateTime  @default(now())
  respondedAt  DateTime?

  conclusion Conclusion @relation(fields: [conclusionId], references: [id], onDelete: Cascade)
  requester  Founder    @relation(fields: [requesterId], references: [id])

  @@index([conclusionId])
  @@index([requesterId])
  @@index([status])
}

// ── DashboardDismissal ─────────────────────────────────────────────────
// Per-founder UI preference. Dismissing a conclusion from the dashboard
// hides it from *this* founder's homepage only — other founders in the
// same org still see it. Not a deletion.

model DashboardDismissal {
  id           String   @id @default(cuid())
  founderId    String
  conclusionId String
  createdAt    DateTime @default(now())

  founder    Founder    @relation(fields: [founderId], references: [id])
  conclusion Conclusion @relation(fields: [conclusionId], references: [id], onDelete: Cascade)

  @@unique([founderId, conclusionId])
  @@index([founderId])
  @@index([conclusionId])
}

// ── DriftEvent — mirrors noosphere.models.DriftEvent ───────────────────────
//
// Two distinct kinds of drift event share this table:
//
// 1. `targetKind = "principle"` (the historical use): an embedding /
//    semantic drift event for a Principle. `targetId` references the
//    principle id; the method-* fields are empty.
//
// 2. `targetKind = "method"` (added with the Method Drift work):
//    nightly per-method calibration drift. `methodName`, `methodVersion`,
//    `methodDomain`, `windowDays` are required and `targetId` is set to
//    `method:<name>@<version>` so existing consumers see *some* id even
//    if they do not understand the new kind.
//
// The deterministic id for method drift events is a UUID-v5 of the
// (organization, method, version, domain, window, window_end) tuple,
// so re-running the nightly evaluator is idempotent.

model DriftEvent {
  id             String @id @default(cuid())
  organizationId String

  noosphereId                 String?  @unique
  targetId                    String
  targetKind                  String   @default("principle")
  episodeId                   String   @default("")
  observedAt                  DateTime
  driftScore                  Float    @default(0)
  notes                       String   @default("")
  claimSequenceIdsJson        String   @default("[]")
  naturalLanguageSummary      String   @default("")
  earliestInconsistentClaimId String   @default("")
  authorTopicKey              String   @default("")
  topicId                     String   @default("")

  // ── Method drift fields (null/empty for principle drift) ────────────
  methodName       String?
  methodVersion    String?
  methodDomain     String?
  windowDays       Int?
  severity         String? // "ok" | "warn" | "escalate" | "insufficient"
  sigma            Float?
  pValue           Float?
  seed             Int?
  sampleSize       Int?
  calibrationSlope Float?
  baselineSlope    Float?
  brierMean        Float?
  baselineBrier    Float?
  directionalBias  Float?
  evidence         Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([organizationId, methodName, methodVersion, methodDomain, observedAt])
  @@index([targetKind, observedAt])
}

// ── ResearchSuggestion — mirrors noosphere.models.ResearchSuggestion ───────

model ResearchSuggestion {
  id             String @id @default(cuid())
  organizationId String

  noosphereId  String?  @unique
  title        String
  summary      String   @default("")
  rationale    String   @default("")
  readingUris  String   @default("[]") // JSON string[]
  sessionLabel String   @default("")
  createdAt    DateTime @default(now())

  // ── Source tracking ───────────────────────────────────────────────
  // The upload whose ingestion run generated this suggestion. Unlike
  // Conclusion, ResearchSuggestion is NOT deduplicated across uploads
  // — if two uploads both happen to prompt the same "read X" suggestion
  // they each get their own row. When the source upload is deleted
  // the suggestion goes with it.
  sourceUploadId String?
  sourceUpload   Upload? @relation("ResearchSuggestionSourceUpload", fields: [sourceUploadId], references: [id])

  suggestedForFounderId String?
  suggestedForFounder   Founder?     @relation(fields: [suggestedForFounderId], references: [id])
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([sourceUploadId])
}

// ── ReviewItem — mirrors noosphere.models.ReviewItem (+ portal resolution) ─

model ReviewItem {
  id             String @id @default(cuid())
  organizationId String

  noosphereId       String?   @unique
  claimAId          String
  claimBId          String
  reason            String    @default("")
  layerVerdictsJson String    @default("{}") // dict str -> str
  severity          Float     @default(0)
  status            String    @default("open") // open | done | dismissed
  aggregatorVerdict String?
  priorScoresJson   String?
  humanVerdict      String?
  humanOverrule     Boolean   @default(false)
  resolutionNote    String    @default("")
  createdAt         DateTime  @default(now())
  resolvedAt        DateTime?

  resolvedByFounderId String?
  resolvedByFounder   Founder?     @relation("ReviewResolver", fields: [resolvedByFounderId], references: [id])
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId])
}

// ── OpenQuestionCandidate — mirrors conclusions.OpenQuestionCandidate ───────

model OpenQuestion {
  id             String @id @default(cuid())
  organizationId String

  noosphereId              String?  @unique
  summary                  String
  claimAId                 String
  claimBId                 String
  unresolvedReason         String   @default("")
  layerDisagreementSummary String   @default("")
  createdAt                DateTime @default(now())

  // ── Source tracking ───────────────────────────────────────────────
  // The upload whose ingestion produced this open question. Cascaded
  // with the upload's soft-delete; also disappears if either of its
  // referenced Conclusions has been orphan-deleted (a question about
  // a claim that no longer exists in the Codex has no meaning).
  sourceUploadId String?
  sourceUpload   Upload? @relation("OpenQuestionSourceUpload", fields: [sourceUploadId], references: [id])

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([sourceUploadId])
}

model AuditEvent {
  id             String   @id @default(cuid())
  organizationId String
  founderId      String
  uploadId       String?
  action         String
  detail         String?
  createdAt      DateTime @default(now())

  founder      Founder      @relation(fields: [founderId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  upload       Upload?      @relation(fields: [uploadId], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

// ── Belief revision audit ledger ─────────────────────────────────────────
//
// Every committed revision (founder marks new evidence on a claim and
// confirms the propagation preview) appends one row here. The
// `preConfidenceSnapshot` is what makes time-replay work: replaying the
// ledger up to but not including a given event reconstructs the prior
// belief state exactly. `revertedAt` is the soft-delete: the public
// "/revisions/<id>" page renders an event regardless, but conclusion
// readers fall through to the previous non-reverted event.
model RevisionEvent {
  id             String @id @default(cuid())
  organizationId String
  /// Plan id from the noosphere engine (sha256 over inputs+thresholds);
  /// duplicates indicate idempotent re-submits and are allowed.
  planId         String
  /// Founder who confirmed the revision in the preview modal.
  founderId      String

  /// JSON: [{ claim_id, weight, new_evidence }] — the RevisionInput batch.
  inputsJson            String
  /// JSON: full RevisionPlan.to_dict() — frozen at commit time.
  planJson              String
  /// JSON: { conclusion_id: confidence_before } — the before-snapshot.
  preConfidenceSnapshot String
  /// Conclusions whose confidence changed by > δ at commit time. Stored
  /// as a denormalised JSON array of conclusion ids so the UI can build
  /// the "updated" pill query without parsing planJson on every page
  /// render. Source of truth is still planJson.
  affectedConclusionIds String @default("[]")

  /// `true` when the founder typed the K-cap confirmation phrase. Always
  /// `false` for revisions whose affected_count <= K; informational only.
  typedConfirmation Boolean @default(false)

  createdAt  DateTime  @default(now())
  revertedAt DateTime?

  // Round-18 audit: relation FK left at the Prisma default
  // (ON DELETE RESTRICT). The revision ledger is the audit record for
  // every committed belief revision; it must outlive the founder row
  // that produced it.
  founder      Founder      @relation(fields: [founderId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([planId])
}

// ── API keys for machine-to-machine auth (Dialectic auto-sync, scripts, etc.) ─
//
// Store the *hash* of the key, never the plaintext. The plaintext is returned
// once at creation time. Revocation = set `revokedAt`. The key plaintext
// should look like `tcx_<founderId>_<64-hex-random>` so the client can send
// the founderId bits without a DB lookup for routing, and the random tail is
// the secret. `authenticateApiKey()` in src/lib/apiKeyAuth.ts implements
// the verification (bcrypt compare against `keyHash`).
model ApiKey {
  id             String @id @default(cuid())
  organizationId String
  /// Founder the key acts on behalf of — uploads are attributed to them.
  founderId      String

  /// Human label shown in the management UI (e.g. "Dialectic on laptop").
  label   String
  /// Short prefix of the plaintext (first 12 chars) — shown in UI for identification.
  prefix  String
  /// bcrypt hash of the full plaintext key. Never store plaintext.
  keyHash String
  /// Comma-separated scopes (e.g. "upload:write"). Empty = full founder scope.
  scopes  String @default("")

  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  founder      Founder      @relation(fields: [founderId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([founderId])
  @@index([prefix])
}

// ── Method ↔ Conclusion linkage ───────────────────────────────────────────
//
// Bridge table: which registered methods produced this conclusion, and at
// what relative weight. A single conclusion may compose several methods
// (e.g. "empirical_calibration" + "adversarial_revision"), so the weights
// are not constrained to sum to 1 — they're independent contributions in
// [0, 1]. The `domain` column lets the track-record aggregator group by
// the conclusion's topical domain so we don't smooth across forecasting,
// policy design, etc.
//
// Idempotent: the linker upserts on (conclusionId, methodName, methodVersion)
// rather than appending.
model ConclusionMethod {
  id             String @id @default(cuid())
  organizationId String
  conclusionId   String

  /// Reference into the in-process method registry. Stored as
  /// (name, version) rather than a foreign key because the registry is a
  /// Python decorator catalog, not a DB table.
  methodName    String
  methodVersion String

  /// In [0, 1]. How much this method contributed to the conclusion. The
  /// linker is allowed to assign multiple methods weight 1.0 — this is
  /// not a softmax over methods.
  weight Float @default(1.0)

  /// Domain the conclusion sits in (e.g. "forecasting", "policy"). Empty
  /// string when unknown. Track records are computed per-domain.
  domain String @default("")

  /// Free-form rationale from the linker (LLM judge or stub). Useful for
  /// audit; not load-bearing.
  rationale String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  conclusion   Conclusion   @relation(fields: [conclusionId], references: [id], onDelete: Cascade)

  @@unique([conclusionId, methodName, methodVersion])
  @@index([organizationId, methodName, methodVersion])
  @@index([methodName, methodVersion])
}

// ── Versioned method snapshots (content-addressed) ───────────────────────
//
// Every method release is captured as a `MethodVersion` row keyed by a
// stable content hash. The hash is computed in
// `noosphere/methods/version_snapshot.py` over the normalized source,
// RATIONALE, FAILURES.yaml, and registered DomainBound — line endings
// collapsed and trailing whitespace stripped so the same checkout
// produces the same digest on any machine. Two transitions to the
// same hash collide on purpose (e.g. revert).
//
// The codex web app reads this table to render
// `/methodology/[method]/changelog` and to feed the per-method
// digest hook (see `noosphere/social/digest_builder.py`).
//
// Re-analysis on version change is OPT-IN — see
// `scripts/reanalyze-codex.sh`. The presence of a new MethodVersion
// row never silently rewrites historic conclusions.
model MethodVersion {
  id             String @id @default(cuid())
  organizationId String

  /// (name, version) is the registry key. We keep it denormalized
  /// rather than referencing `Method` because the registry is a
  /// Python decorator catalog, not a DB table.
  methodName    String
  methodVersion String

  /// Content-addressed identifier. Same checkout → same hash, on any
  /// machine. Stable URL anchor for the public changelog is the
  /// short prefix (`v-<first 12 chars>`).
  contentHash String

  /// Public-visible portions of the snapshot. The raw source and
  /// rationale are public; the failures view is filtered to only
  /// `public: true` modes so private framings never leak. Kept
  /// alongside the row rather than re-derived on the fly so the
  /// changelog is reproducible even if the on-disk file changes.
  source             String
  rationale          String
  failuresPublicYaml String @default("")
  domainBoundJson    String @default("")

  /// Wall-clock capture time. Used only for ordering on the
  /// changelog; the hash is what makes a version unique.
  capturedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([organizationId, methodName, contentHash])
  @@index([methodName, capturedAt])
  @@index([organizationId, methodName, methodVersion])
}

// ── Materialized per-method track record ─────────────────────────────────
//
// Rolled up from resolved ForecastPredictions linked to each method through
// ConclusionMethod, weighted by `ConclusionMethod.weight`. Materialized
// rather than computed on every page load because the join goes through a
// chain of three tables and the aggregation includes a bootstrap CI on the
// calibration slope. The materialization job (`noosphere methods
// track-record --rebuild`) is idempotent: it upserts on
// (organizationId, methodName, methodVersion, domain).
model MethodTrackRecord {
  id             String @id @default(cuid())
  organizationId String

  methodName    String
  methodVersion String

  /// Empty string for "no domain label". Track records are NEVER smoothed
  /// across domains — one row per domain.
  domain String @default("")

  /// Number of resolved ForecastPredictions feeding this row. Hard filter:
  /// unresolved predictions are excluded entirely.
  sampleSize Int

  /// Σ(weight·brier) / Σ(weight). Null when sampleSize == 0.
  weightedBrier Float?

  /// OLS slope of outcome ~ probability over resolved predictions, with a
  /// non-parametric bootstrap CI. Null when the slope is undefined
  /// (sampleSize < 2 or zero variance in probabilities).
  calibrationSlope       Float?
  calibrationSlopeCiLow  Float?
  calibrationSlopeCiHigh Float?

  /// Fraction of source conclusions whose MQS severity sub-score is at
  /// or above the published threshold (0.5). Null when no MQS data.
  severityPassRate Float?

  /// Audit blob: bootstrap iterations, threshold used, source ids, etc.
  evidence Json

  computedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([organizationId, methodName, methodVersion, domain])
  @@index([methodName, methodVersion])
  @@index([organizationId, computedAt])
}

// ── Method retirement workflow ───────────────────────────────────────────
//
// Mirrors the operational retirement state owned by
// `noosphere/noosphere/methods/retirement.py`. The durable source of
// truth on the noosphere side is the founder review memo at
// `docs/methods/retirement/<method>.md` (its YAML frontmatter); this
// table is the Codex web app's read model, so the methods registry page
// and the public methodology page can render retirement state without
// shelling out to the filesystem.
//
// Keyed on (organization, methodName) — retirement is about method
// IDENTITY, not a pinned version. A RETIRED method is refused across
// every version; the registry does not keep a "still-good" version of a
// retired method.
//
// Rows are NEVER deleted: a retired method's record is part of the
// firm's permanent history, the same way the memo file is never
// deleted and the method's source is never deleted.
model MethodRetirement {
  id             String @id @default(cuid())
  organizationId String

  methodName String

  /// One of {active, under_review, deprecated, retired} — see
  /// `RetirementState` in retirement.py. `active` means the method has
  /// a memo on record (e.g. a rejected review) but is fully in service.
  state String @default("active")

  /// Method that takes over this one's responsibility. Empty until a
  /// review names one; a retired method MAY have no replacement (its
  /// conclusions are then under review for revision/retraction).
  replacement String @default("")

  /// Rationale captured when the review opened — which criteria fired.
  rationale String @default("")

  /// Path to the founder review memo (the durable source of truth).
  memoPath String @default("")

  /// Timeline. Null until the corresponding transition happens.
  reviewOpenedAt DateTime?
  deprecatedAt   DateTime?
  retiredAt      DateTime?
  /// Sunset deadline shown on banners — reanalysis should complete by here.
  sunsetAt       DateTime?

  /// Permanent transition ledger. JSON array of
  /// `{ at, fromState, toState, actor, reason }`.
  transitionsJson String @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([organizationId, methodName])
  @@index([methodName])
  @@index([organizationId, state])
}

// ── Domain Bounds: per-method declarative applicability gates ───────────
//
// Each method registers a `DomainBound` (see
// noosphere/methods/domain_bounds.py) declaring the embedding region
// and/or topic-tag set in which it is allowed to operate. When a
// conclusion is run through a method, the orchestrator records the
// resulting verdict on `DomainBoundVerdict` so the UI can render an
// in-domain / edge / out badge and so MQS can gate the composite.
//
// Anchors are versioned. Re-curating produces a NEW `AnchorRevision`
// row rather than mutating the prior one — older `DomainBoundVerdict`
// rows continue to point at the revision that was active when they
// were emitted. Cross-model comparisons are refused: the
// `embeddingModel` on AnchorRevision must match the embedding model
// of the conclusion being checked.

model AnchorRevision {
  id             String @id @default(cuid())
  organizationId String

  /// Method this revision belongs to. Stored as (name, version) rather
  /// than a foreign key for the same reason `ConclusionMethod` does:
  /// the registry is a Python decorator catalog, not a DB table.
  methodName    String
  methodVersion String

  /// Stable content-hash id, e.g. `rev_8f...`. Used by
  /// `DomainBoundVerdict.anchorRevisionId` to pin a verdict to the
  /// exact anchors that were active when it ran.
  revisionId String

  /// Embedding model identifier these anchors were curated under.
  /// Cross-model comparisons are refused at check time.
  embeddingModel String

  /// k-medoid centroid vectors. JSON array of arrays: each inner array
  /// is one anchor of length `dim`.
  anchors Json

  /// Angular cosine thresholds. `inRadius` defines the in-domain
  /// region; `edgeRadius` (>= inRadius) the soft edge-case zone.
  inRadius   Float
  edgeRadius Float

  /// Free-form curator notes (which medoid IDs were inspected, why a
  /// radius was widened, etc.). Not load-bearing.
  notes String @default("")

  /// True when the revision is the active one for this method. Older
  /// revisions are kept (verdicts point at them) but never new
  /// verdicts. Exactly zero or one revision per method should be
  /// active at any time.
  active Boolean @default(false)

  createdAt DateTime @default(now())

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  verdicts     DomainBoundVerdict[]

  @@unique([organizationId, methodName, methodVersion, revisionId])
  @@index([organizationId, methodName, methodVersion, active])
}

model DomainBoundVerdict {
  id             String @id @default(cuid())
  organizationId String
  conclusionId   String

  methodName    String
  methodVersion String

  /// One of `in_bounds`, `edge_case`, `out_of_bounds`. Treated as the
  /// source of truth for `MethodologyQualityScore.domainSensitivity`.
  status String

  /// Signed margin: positive when in-bounds, negative when out. Units
  /// are angular cosine distance for anchor-driven verdicts and the
  /// binary {-1, +1} for pure tag verdicts.
  margin Float

  /// Free-form reason from the bound check. Hover text on the badge.
  reason String @default("")

  /// Optional pin: when the verdict came from an anchor bound, this
  /// links to the exact `AnchorRevision` that was active at run time.
  /// Null for tag-only verdicts.
  anchorRevisionId String?

  /// Tags that matched (when the tag side participated). Empty for
  /// pure anchor verdicts.
  matchedTags String[] @default([])

  /// Embedding model the verdict was computed under. Stored so a
  /// future model migration can detect verdicts that need to be
  /// recomputed.
  embeddingModel String?

  evidence Json?

  createdAt DateTime @default(now())

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  conclusion     Conclusion      @relation(fields: [conclusionId], references: [id], onDelete: Cascade)
  anchorRevision AnchorRevision? @relation(fields: [anchorRevisionId], references: [id], onDelete: SetNull)

  @@unique([conclusionId, methodName, methodVersion])
  @@index([organizationId, methodName, methodVersion])
  @@index([status])
}

// ── Recalibration: per-domain isotonic mapping raw → calibrated ──────────
//
// The firm's stated confidence (a probability on a forecast, a confidence
// score on a conclusion) is what the producing model actually believes.
// `CalibrationModel` lets the public render that number conditionally on
// the firm's track record: each row is a domain-scoped isotonic
// regression fit over resolved binary forecasts, with a fit timestamp,
// sample size, and a SHA-256 hash of the canonicalized resolution set so
// a reader can pinpoint exactly which fit produced a displayed number.
//
// Lifecycle:
//   * Re-fit weekly by `_tick_recalibration` in
//     `noosphere/forecasts/scheduler.py`.
//   * The fitter inserts a NEW row each cycle and flips the previous
//     active row's `active` flag to false. Older rows are kept (audit)
//     but never become the source for a new render.
//   * Display path queries the active row for `(organizationId, domain)`;
//     when no row exists OR `sampleSize < threshold`, the conclusion /
//     forecast is rendered uncalibrated with a "small sample" tag.

model CalibrationModel {
  id             String @id @default(cuid())
  organizationId String

  /// Domain key (matches `ForecastMarket.category` / `ConclusionMethod.domain`).
  /// Calibration models are NEVER smoothed across domains: a strong-domain
  /// track record must not flatter a weak-domain confidence.
  domain String

  /// Monotonically increasing per (organizationId, domain). New fits get
  /// `MAX(version)+1`. The combination is unique so a re-fit cannot
  /// silently overwrite a prior model.
  version Int

  /// When the fit was computed.
  fitAt DateTime @default(now())

  /// Resolved binary forecasts that fed the fit. Below
  /// `THESEUS_RECALIBRATION_MIN_SAMPLES` the fitter does not write a row
  /// at all; the absence is the conservative-by-default signal.
  sampleSize Int

  /// SHA-256 hex over the canonicalized resolution set the fit was
  /// trained on. Lets the UI link a displayed calibrated number back to
  /// the exact training rows.
  resolutionHash String

  /// Piecewise-linear knots: `{"x": [...], "y": [...]}` with `x` ascending
  /// and `y` non-decreasing. The TS apply path interpolates linearly
  /// between knots and clamps outside.
  knots Json

  /// True for the row currently used to render. Exactly zero or one row
  /// per `(organizationId, domain)` should be active at any time.
  active Boolean @default(true)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([organizationId, domain, version])
  @@index([organizationId, domain, active])
  @@index([organizationId, domain, fitAt])
}

// ── Recalibration override ─────────────────────────────────────────────
//
// A founder can opt a specific conclusion out of the recalibration
// display layer — useful when the conclusion is itself the subject of a
// methodology change (the firm is *deliberately* repricing how it
// calibrates), and applying the prior calibration would obscure rather
// than clarify what changed.
//
// The override row IS the audit trail: founder, timestamp, free-form
// reason. There is at most one override per conclusion (`@unique`); a
// later founder can edit the row to update the reason. Removing the
// override = deleting the row.

model RecalibrationOverride {
  id             String @id @default(cuid())
  organizationId String
  conclusionId   String @unique
  founderId      String

  /// Free-form reason (e.g. "methodology change in flight; raw is the
  /// signal we want readers to evaluate").
  reason String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  conclusion   Conclusion   @relation(fields: [conclusionId], references: [id], onDelete: Cascade)
  // Round-18 audit: relation FK left at the Prisma default
  // (ON DELETE RESTRICT). Founder rows are deactivated, not deleted, by
  // firm policy; we never want a founder removal to silently flip a
  // conclusion's calibration display.
  founder      Founder      @relation(fields: [founderId], references: [id])

  @@index([organizationId])
  @@index([founderId])
}

// ── Source standing — append-only ledger for retraction / withdrawal ─────
//
// External pollers (Retraction Watch, arXiv withdrawals, generic URL
// resolvers) write a row here every time a cited source's standing
// changes. The row of record is the *latest* row per `sourceId`; older
// rows stay around so the audit trail can reconstruct the timeline.
//
// `sourceId` is the canonical id from
// `noosphere.literature.standing.canonical_source_id` — a `doi:`,
// `arxiv:`, or `url:` prefix string. Two URLs that point at the same
// DOI collapse to one row.
//
// `noticeSourceId` (when present) is the canonical id of the
// retraction/correction notice itself; we keep the chain of provenance
// so a reader can audit who issued the standing change.
enum SourceStandingStatus {
  ACTIVE
  RETRACTED
  CORRECTED
  DISPUTED
  EXPIRED
}

model SourceStanding {
  id             String @id @default(cuid())
  organizationId String

  /// Canonical source id — see `canonical_source_id`. Multiple rows per
  /// id are expected: each row is a transition.
  sourceId String
  status   SourceStandingStatus
  reason   String               @default("") @db.Text
  poller   String

  /// Canonical id of the retraction/correction notice. A retraction
  /// notice IS a source, so we record its provenance here too.
  noticeSourceId String?

  /// Whatever the poller observed — feed row, HTTP status, page hash.
  /// JSON for forward compatibility with new poller types.
  rawPayload Json?

  observedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId, sourceId, observedAt])
  @@index([organizationId, status, observedAt])
  @@index([sourceId])
}

// ── Source triage queue — founder confirms each propagation ──────────────
//
// When a SourceStanding flips to a propagating status (RETRACTED /
// CORRECTED / EXPIRED), the cascade hook enqueues one row here per
// affected conclusion. The founder must explicitly confirm or override
// the proposed revision before it commits — silent propagation would
// be a credibility risk in the other direction.
//
// `decision` is null until acted on; `decidedAt` carries the timestamp.
// The cascade engine only applies the revision when
// `decision = "confirmed"`.
model SourceTriageItem {
  id             String @id @default(cuid())
  organizationId String

  /// What surfaced this row: "standing" (default — a SourceStanding
  /// transition fired the cascade revision) or "citation_verdict"
  /// (citation-chain validator found a textual entailment failure).
  /// Citation-verdict rows leave standingId empty and set verdictId.
  trigger String @default("standing")

  /// The standing event that caused this triage row. Empty string when
  /// trigger="citation_verdict".
  standingId   String @default("")
  /// The verdict row that caused this triage row. Empty when
  /// trigger="standing".
  verdictId    String @default("")
  /// Canonical source id (denormalised for fast UI rendering).
  sourceId     String
  /// Conclusion whose evidence weight is being challenged.
  conclusionId String

  /// Status copied from SourceStanding at enqueue time so the queue UI
  /// doesn't have to join. For citation-verdict rows this carries the
  /// verdict label as a string in the `notes` field rather than an
  /// enum value — but we keep ACTIVE here so the column stays
  /// non-null without inventing a new enum case.
  status SourceStandingStatus @default(ACTIVE)

  /// "pending" | "confirmed" | "overridden" | "dismissed"
  decision     String  @default("pending")
  decisionNote String? @db.Text
  decidedById  String?

  createdAt DateTime  @default(now())
  decidedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId, decision, createdAt])
  @@index([conclusionId])
  @@index([sourceId])
  @@index([standingId])
  @@index([verdictId])
  @@index([organizationId, trigger, decision])
}

// ── Source credibility ledger ────────────────────────────────────────────
//
// Time-series of credibility updates per canonical source. Each row is
// a single observation: a forecast resolution, a retraction, a
// peer-review verdict on the conclusion that cited the source. The
// row also carries the *running* posterior (alpha, beta, weighted
// counts) computed by folding all prior updates plus this one into
// the source-type prior — denormalised so the UI doesn't have to
// replay the log on every render. The log is the source of truth; if
// the running totals ever disagree with a fold of the rows, the rows
// win.
//
// `current_credibility` is a view: select the latest row for a
// `sourceId` ordered by `observedAt`.
//
// `sourceId` follows the same canonicalization as SourceStanding (see
// `noosphere.literature.standing.canonical_source_id`). `sourceType`
// is one of the values in `noosphere.literature.source_priors.SourceType`;
// it is denormalised on every row so a UI can render the prior label
// without joining to a separate table.
//
// Idempotence: pollers and resolvers are expected to filter on
// `(sourceId, conclusionId, kind, outcome)` before appending — the
// in-memory ledger does this; the Prisma row layer should rely on the
// index below for the same lookup.
enum CredibilityOutcome {
  CONFIRMATION
  FAILURE
}

enum CredibilityEventKind {
  FORECAST_RESOLUTION
  RETRACTION
  PEER_REVIEW_VERDICT
  MANUAL_OVERRIDE
}

model SourceCredibilityUpdate {
  id             String @id @default(cuid())
  organizationId String

  /// Canonical source id — see `canonical_source_id`.
  sourceId   String
  /// Source type — one of `SourceType` values from source_priors.py.
  /// Denormalised so the UI can render without a join.
  sourceType String

  /// Conclusion whose resolution drove this update.
  conclusionId String

  outcome CredibilityOutcome
  kind    CredibilityEventKind

  /// Load-bearing weight in (0, 1] — 1.0 means the source was
  /// indispensable to the conclusion; smaller values down-weight
  /// tangential cites so they don't move the posterior much.
  weight Float

  /// Running posterior after this update is folded in. The UI reads
  /// these directly to render the 0–100 strip.
  posteriorAlpha Float
  posteriorBeta  Float

  /// Cumulative counts including this row.
  nUpdates       Int
  nConfirmations Int
  nFailures      Int

  note       String @default("") @db.Text
  rawPayload Json?

  observedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId, sourceId, observedAt])
  @@index([sourceId, observedAt])
  @@index([organizationId, sourceId, conclusionId, kind, outcome])
  @@index([conclusionId])
}

// ── Citation chain verdicts ──────────────────────────────────────────────
//
// One row per (citation, computation). The cited *text* of a source must
// support the firm's stated claim — paraphrasing drift is a credibility
// failure mode that source-standing and source-credibility do not catch.
// See `noosphere.literature.citation_chain`.
//
// `relation` is the firm-declared relation type. `relationHolds` is the
// NLI judge's verdict on whether the recorded `excerptUsed` actually
// supports `statedClaim`. The excerpt and claim are persisted verbatim
// so an audit can re-derive the verdict even if the live source text
// has since changed.
//
// `cascadeWeight` is the load-bearing weight of the citation at
// computation time. An ambiguous verdict only escalates to triage when
// the weight clears the threshold (default 0.6) — below it the
// ambiguous verdict is recorded but not surfaced.
//
// Override semantics: founder confirms a flagged verdict via the
// triage queue; the override row stamps `overriddenById` and
// `overrideReason`. Once overridden, the verdict no longer blocks
// publication.
enum CitationRelation {
  SUPPORTS
  CONTRADICTS
  QUALIFIES
  MENTIONS
}

enum CitationVerdictLabel {
  ENTAILS
  CONTRADICTS
  NEUTRAL
  AMBIGUOUS
}

model CitationVerdict {
  id             String @id @default(cuid())
  organizationId String

  /// One of "opinion" (OpinionCitation), "forecast" (ForecastCitation),
  /// or "conclusion_source" (ConclusionSource). Not a hard FK because
  /// the three citation tables have different keys.
  citationKind String
  /// Foreign id within `citationKind`. Composite-keyed citation rows
  /// (ConclusionSource: conclusionId+uploadId) encode as
  /// "conclusionId:uploadId".
  citationId   String

  /// Canonical source id — matches SourceStanding.sourceId.
  sourceId String

  relation      CitationRelation
  relationHolds CitationVerdictLabel
  confidence    Float

  /// Excerpt actually fed to the NLI judge — recorded verbatim.
  excerptUsed String @db.Text
  /// Firm's stated claim about the source (the hypothesis side of NLI).
  statedClaim String @db.Text

  /// Identifier for the NLI head used to compute this verdict.
  /// Re-running with a different head produces a new row rather than
  /// updating the old one.
  modelVersion String

  /// Cascade load-bearing weight at validation time. Drives the
  /// ambiguous-verdict triage threshold; not used by publication gate.
  cascadeWeight Float @default(0.0)

  /// Founder override — populated when the founder confirmed the
  /// verdict from triage and accepted publication anyway.
  overriddenById String?
  overrideReason String?
  overriddenAt   DateTime?

  /// Raw NLI probability triple, JSON-encoded for forward compat.
  rawPayload Json?

  computedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId, sourceId])
  @@index([organizationId, citationKind, citationId, computedAt])
  @@index([organizationId, relationHolds, computedAt])
  @@index([sourceId, computedAt])
}

// ── AttentionAction — founder-side snooze/dismiss audit log ──────────────
//
// Append-only ledger of actions a founder has taken on items in the
// unified attention queue surfaced on the dashboard. The queue itself
// is computed at request time from many backing tables (DriftEvent,
// PublicResponse, ResponseTriage, SourceTriageItem, CitationVerdict,
// Contradiction, OpenQuestion, ConclusionDeletionRequest, …); this
// table records the *founder-side* state for each surfaced item:
//
//   * action="snooze"   — hide until snoozedUntil. Snooze windows are
//                          capped at 14 days at the API layer; longer
//                          requests are rewritten as "dismiss" with
//                          reason="deferred indefinitely".
//   * action="dismiss"  — hide indefinitely; reason is required.
//   * action="unsnooze" — explicit re-surface (cancels a prior snooze).
//
// We keep history rather than upserting because a high rate of
// dismissals on a particular queue is itself a signal that the queue
// needs tuning. The current state of an item is the latest row for
// (founderId, queue, itemId) by createdAt; helpers in
// `src/lib/attention.ts` enforce that read.
model AttentionAction {
  id             String @id @default(cuid())
  organizationId String
  founderId      String

  /// Stable queue identifier — see `AttentionQueueId` in
  /// `src/lib/attention.ts` for the canonical vocabulary.
  queue  String
  /// Identifier of the underlying row inside that queue. Composite ids
  /// (e.g. citation verdicts keyed by kind+id) collapse into a single
  /// string here.
  itemId String

  /// "snooze" | "dismiss" | "unsnooze"
  action       String
  snoozedUntil DateTime?
  reason       String    @default("") @db.Text

  createdAt DateTime @default(now())

  founder      Founder      @relation(fields: [founderId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([founderId, queue, itemId, createdAt])
  @@index([organizationId, queue, action, createdAt])
  @@index([organizationId, founderId, createdAt])
}

// ── Public follow / digest subscriptions ───────────────────────────────────
//
// A Subscriber is an outside reader following one slice of the firm's
// public output: a methodology, a domain tag, a single conclusion, or
// the firm at large. Double opt-in: rows start status=pending with a
// confirm token; activation requires the reader to click the emailed
// link, after which status flips to active and confirmedAt is set.
//
// Telemetry-free by design — no open/click tracking. The unsubscribe
// link in every digest carries a stable, sufficiently-random token; it
// is the only way a reader leaves the list. Reasons (free-text) are
// optional and stored locally for the firm's signal, never shared.
model Subscriber {
  id             String @id @default(cuid())
  organizationId String

  /// Lowercased, trimmed email. Re-subscribing reuses the row.
  email String

  /// Subscription scope. One of:
  ///   firm           — every published surface the firm emits
  ///   methodology    — `scopeKey` is the method name (matches MethodologyProfile)
  ///   domain         — `scopeKey` is the domain tag (e.g. "biology", "ml-safety")
  ///   conclusion     — `scopeKey` is the publishedConclusion slug
  scope    String
  /// Empty string for `firm`; otherwise the per-scope key (see above).
  scopeKey String @default("")

  /// pending | active | unsubscribed | paused
  /// `paused` is set automatically when repeated bounces cross the
  /// SUBSCRIBER_BOUNCE_PAUSE_THRESHOLD; the founder can resume from
  /// the subscribers dashboard after investigating.
  status String @default("pending")

  /// Cadence of digests: weekly (default) | immediate | monthly. Immediate
  /// only fires on firm-wide major events (revisions/retractions); other
  /// items still aggregate into the next weekly window.
  cadence String @default("weekly")

  /// URL-safe random token for the double-opt-in confirm link. Cleared on confirm.
  confirmToken     String @default("")
  /// URL-safe random token for one-click unsubscribe; embedded in every digest.
  unsubscribeToken String @unique

  /// Set when the reader clicks the confirm link.
  confirmedAt       DateTime?
  /// Set when the reader unsubscribes; row is retained as a tombstone so
  /// re-subscribing the same email cannot bypass another opt-in step.
  unsubscribedAt    DateTime?
  /// Free-text reason captured at unsubscribe time. Empty if not given.
  unsubscribeReason String    @default("")

  /// Timestamp of the most recent digest sent to this subscriber. Drives
  /// the per-subscriber "since" window the digest builder reads from.
  lastSentAt DateTime?

  /// Rolling count of recent delivery failures (bounces/blocks). Reset
  /// to 0 on the next successful delivery. When this crosses
  /// SUBSCRIBER_BOUNCE_PAUSE_THRESHOLD (see lib/subscribers.ts) the row
  /// is paused (status="paused") rather than dropped, so the founder
  /// can investigate.
  bounceCount  Int       @default(0)
  lastBounceAt DateTime?
  /// Set when repeated bounces auto-pause the subscriber. Paused
  /// subscribers are excluded from digest builds but kept on the books
  /// so the founder can review the bounce trail and resume them.
  pausedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  digestSends DigestSend[]
  bounces     SubscriberBounce[]

  @@unique([organizationId, email, scope, scopeKey])
  @@index([organizationId, status, cadence])
  @@index([scope, scopeKey])
}

// ── Follow-digest delivery ledger ─────────────────────────────────────────
//
// One row per rendered digest the firm hands to the mailer. We capture
// the *fact* of a send (subscriber, item count, transport id) but not
// the rendered body — the email itself goes through the existing
// sendMail path and is not re-stored.
//
// `ackTokenHash` is the SHA-256 of a one-time token embedded in the
// "I read this" link. The raw token never leaves the email; the server
// hashes the incoming token and looks up the matching send. This gives
// the firm a voluntary, opt-in open-rate signal without tracking pixels
// or any per-recipient identifier the recipient cannot delete by
// unsubscribing.
model DigestSend {
  id             String @id @default(cuid())
  organizationId String
  subscriberId   String

  /// SHA-256 hex of the ack token for this send. Empty if no ack link
  /// was rendered (e.g. for early dry-run sends).
  ackTokenHash String @default("")

  /// Number of digest items in the rendered email.
  itemCount   Int       @default(0)
  /// Subject line as rendered. Useful for the founder dashboard.
  subject     String    @default("")
  /// Mailer's message id, if returned. Empty for SMTP transports that
  /// do not surface one.
  messageId   String    @default("")
  /// pending | delivered | bounced | blocked
  ///   pending   — handed to transport, no terminal status yet
  ///   delivered — transport accepted the message
  ///   bounced   — hard/soft bounce; see SubscriberBounce for detail
  ///   blocked   — transport rejected before send (suppression, policy)
  status      String    @default("pending")
  sentAt      DateTime  @default(now())
  deliveredAt DateTime?
  bouncedAt   DateTime?

  /// Set when the recipient clicks the "I read this" link. Stored only
  /// as a timestamp; the link is hashed-token, not email-keyed.
  ackedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  subscriber   Subscriber   @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  acks         DigestAck[]

  @@index([organizationId, sentAt])
  @@index([subscriberId, sentAt])
  @@index([ackTokenHash])
}

// One row per "I read this" click. We retain the digest send id and
// the timestamp; we never retain the recipient's email here. The same
// send can be acked more than once (e.g. forwarded to a colleague who
// also clicked); we keep all clicks for an honest count.
model DigestAck {
  id             String @id @default(cuid())
  organizationId String
  digestSendId   String

  /// SHA-256 hex of the ack token actually received (matches the
  /// DigestSend.ackTokenHash on the parent row). Stored alongside the
  /// FK so a stray ack to a deleted send still has a record.
  receivedHash String

  ackedAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  digestSend   DigestSend   @relation(fields: [digestSendId], references: [id], onDelete: Cascade)

  @@index([organizationId, ackedAt])
  @@index([digestSendId])
}

// One row per delivery failure. The transport (Resend / SMTP) calls
// `recordSubscriberBounce` with the bounce class; after
// SUBSCRIBER_BOUNCE_PAUSE_THRESHOLD failures the subscriber row is
// auto-paused rather than continuing to spam an invalid address. The
// founder reviews these from the subscribers dashboard.
model SubscriberBounce {
  id             String @id @default(cuid())
  organizationId String
  subscriberId   String

  /// hard | soft | block | other
  kind      String @default("soft")
  /// Provider-supplied reason / diagnostic. Trimmed to a reasonable
  /// upper bound; long DSN bodies are clipped.
  reason    String @default("")
  /// Provider message id, if any.
  messageId String @default("")

  occurredAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  subscriber   Subscriber   @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([organizationId, occurredAt])
  @@index([subscriberId, occurredAt])
}

// ── Principles (cross-domain distillations) ────────────────────────────────
//
// Output of the corpus-level distillation pipeline. A Principle is a
// single-sentence claim the firm is willing to defend, derived from
// the embedding-space neighborhood of its conclusions.
//
// Lifecycle:
//   draft           — surfaced by the pipeline; awaiting founder triage
//   accepted        — founder approved (with edits); shown publicly when
//                     `publicVisible = true`
//   rejected        — founder declined (`triageReason` records why)
//   merged          — folded into another principle (`mergedIntoId`)
//   needs_rereview  — the underlying cluster has shifted; founder must
//                     re-validate before it stays accepted
//
// Conviction scoring is conservative: a single high-centrality
// conclusion does not produce conviction; convergence across domains
// does. See noosphere/distillation/principle_distillation.py.
model Principle {
  id             String @id @default(cuid())
  organizationId String

  text        String
  /// JSON string[] of domain tags the firm is willing to attach.
  /// Public principles must declare their domain; surfaces refuse to
  /// publish if this is empty.
  domainsJson String @default("[]")

  /// JSON string[] of Conclusion ids in the cluster that produced
  /// the principle. The full cluster — not just the LLM-cited subset.
  clusterConclusionIds String @default("[]")
  /// JSON string[] of Conclusion ids the LLM explicitly cited.
  citedConclusionIds   String @default("[]")

  /// status ladder — see model docstring.
  status       String  @default("draft")
  /// draft | accepted | rejected | merged | needs_rereview source.
  triageReason String  @default("")
  /// Set on `merged`: target principle id this row was folded into.
  mergedIntoId String?

  /// Conservative score in [0, 1]. Conviction-weighted ordering on the
  /// public methodology page reads this column.
  convictionScore           Float @default(0.0)
  /// Distinct domains in the cluster — proxy for cross-domain
  /// convergence. Zero unless the cluster spans multiple disciplines.
  domainBreadth             Int   @default(0)
  /// Mean cosine similarity of cluster members to the cluster centroid.
  clusterCentroidSimilarity Float @default(0.0)

  /// Whether the firm is willing to publish this principle on the
  /// public methodology surface. Acceptance does not imply publication.
  publicVisible Boolean @default(false)

  /// The diff reason emitted by `redistill` when an existing principle's
  /// cluster has shifted: cluster_grew | cluster_shrunk |
  /// cluster_added_and_retracted | cluster_dissolved. Cleared when the
  /// founder re-accepts.
  driftReason String?

  /// Founder who last accepted/edited this row.
  reviewedByFounderId String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  reviewedAt  DateTime?
  publishedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  quantitativeFormalisations QuantitativeFormalisation[] @relation("PrincipleFormalisations")

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, publicVisible])
}

/// Quantitative-formalisation spec for a principle.
///
/// Bridges the firm's logical principles to numerical, falsifiable
/// tests. Each row carries a null hypothesis, structured metric specs,
/// statistical tests, named data sources, and decision thresholds
/// (what numerical reading would update the firm's confidence).
///
/// Status ladder mirrors the Pydantic `FormalisationStatus`:
///   DRAFT          — drafter has proposed; not yet in the queue.
///   PENDING_REVIEW — promoted to the founder triage queue.
///   APPROVED       — founder accepted; surfaces on the public
///                    principle page. Never set by the drafter.
///   RETIRED        — superseded or invalidated; kept for audit.
///   UNFORMALISABLE — drafter declined to formalise (e.g. pure-
///                    normative; no accessible dataset). Carries a
///                    structured `unformalisableReason`.
///
/// Columns are duplicated as JSON strings (`metricsJson`, `testsJson`,
/// etc.) so the Codex UI does not have to parse `payloadJson` for the
/// public surface; `payloadJson` is the authoritative round-trip of
/// the Pydantic payload from noosphere.
model QuantitativeFormalisation {
  id             String @id @default(cuid())
  organizationId String
  principleId    String

  status                 String  @default("DRAFT")
  nullHypothesis         String  @default("")
  /// JSON-encoded list of MetricSpec.
  metricsJson            String  @default("[]")
  /// JSON-encoded list of StatisticalTestSpec.
  testsJson              String  @default("[]")
  /// JSON-encoded list of DataSourceSpec.
  dataSourcesJson        String  @default("[]")
  /// JSON-encoded list of decision-threshold strings.
  decisionThresholdsJson String  @default("[]")
  /// Set when status = UNFORMALISABLE.
  unformalisableReason   String?
  drafterModel           String  @default("")
  drafterNotes           String  @default("")
  /// Authoritative round-trip of the noosphere Pydantic payload.
  payloadJson            String  @default("{}")

  reviewedByFounderId String?
  reviewedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  principle    Principle                @relation("PrincipleFormalisations", fields: [principleId], references: [id], onDelete: Cascade)
  testResults  QuantitativeTestResult[] @relation("FormalisationTestResults")

  @@index([principleId])
  @@index([organizationId, status])
}

/// Prompt 63 runner output: one row per QuantitativeRunner pass over an
/// APPROVED QuantitativeFormalisation. The full Pydantic payload is
/// round-tripped in `payloadJson`; the duplicated JSON columns power
/// the public principle detail page without re-parsing payloadJson.
model QuantitativeTestResult {
  id                     String  @id @default(cuid())
  organizationId         String
  formalisationId        String
  principleId            String  @default("")
  runStamp               String
  status                 String  @default("RAN")
  /// JSON-encoded { metric name → { value, as_of } }.
  metricValuesJson       String  @default("{}")
  /// JSON-encoded list of QuantitativeTestOutput.
  testOutputsJson        String  @default("[]")
  decisionSummary        String  @default("")
  artifactsPath          String  @default("")
  /// JSON-encoded list of decision-threshold strings the run crossed.
  thresholdCrossingsJson String  @default("[]")
  error                  String?
  payloadJson            String  @default("{}")

  createdAt DateTime @default(now())

  formalisation QuantitativeFormalisation @relation("FormalisationTestResults", fields: [formalisationId], references: [id], onDelete: Cascade)

  @@unique([formalisationId, runStamp])
  @@index([formalisationId])
  @@index([principleId])
}

/// Founder-confirmable queue: when a quantitative test crosses any
/// configured decision threshold, the runner enqueues a row here
/// rather than auto-updating the principle's conviction score. Same
/// recommend-then-accept pattern as the prompt-58 triage UI.
model PrincipleConvictionUpdateQueue {
  id                  String    @id @default(cuid())
  organizationId      String?
  principleId         String
  formalisationId     String
  runStamp            String
  crossingsJson       String    @default("[]")
  summary             String    @default("")
  status              String    @default("PENDING")
  resolvedByFounderId String?
  resolvedAt          DateTime?
  createdAt           DateTime  @default(now())

  @@index([principleId])
  @@index([status])
}

// ── Cluster index for contradiction-test scheduling (R19/p07) ───────────────
//
// Sits BETWEEN the principle add event and the canonical contradiction
// engine (prompt 06). The engine is authoritative for verdicts; these
// tables decide WHICH pairs the engine looks at. Solves the O(N²) cost
// concern: a new principle is tested against principles in the same
// semantic cluster, plus a small cross-cluster sample to catch surprise
// links (founder caveat — "language is not ideas, but it tracks for
// semantic").
//
// Versioning: every row carries `assignmentMethod` so a replay query
// ("which cluster was P in on date Y?") is a range scan.

model PrincipleCluster {
  principleId      String   @id
  organizationId   String
  clusterId        String
  assignmentMethod String   @default("incremental/v1")
  assignedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId, clusterId])
  @@index([clusterId, assignedAt(sort: Desc)])
}

model PrincipleClusterCentroid {
  clusterId        String   @id
  organizationId   String
  /// Float32-packed centroid bytes. Length == 4 * `dim`.
  centroidVec      Bytes    @default("")
  dim              Int      @default(0)
  memberCount      Int      @default(0)
  assignmentMethod String   @default("incremental/v1")
  updatedAt        DateTime @default(now()) @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId])
}

/// Work queue. `pairKey` is the deterministic stable_pair_id over sorted
/// (A, B), so (A,B) and (B,A) collide on dedupe. Priority orders the
/// drain; status tracks lifecycle. `resultId` points to the Contradiction
/// row written by the engine once detection runs.
model ContradictionTestTask {
  id             String    @id @default(cuid())
  organizationId String
  principleAId   String
  principleBId   String
  pairKey        String    @default("")
  priority       String    @default("NORMAL") // HIGH | NORMAL | LOW
  status         String    @default("PENDING") // PENDING | RUNNING | DONE | FAILED
  enqueuedAt     DateTime  @default(now())
  startedAt      DateTime?
  finishedAt     DateTime?
  resultId       String?
  lastError      String?

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  result       Contradiction? @relation("ContradictionTestTaskResult", fields: [resultId], references: [id], onDelete: SetNull)

  @@index([status, priority, enqueuedAt])
  @@index([pairKey, enqueuedAt(sort: Desc)])
  @@index([organizationId, status])
}

/// Resweep drift proposal. Inserted when the nightly k-means resweep
/// disagrees with the incremental assignment by more than
/// `CLUSTER_DRIFT_THRESHOLD` (default 0.15). Operator must explicitly
/// accept the proposal — the incremental assignment is what the system
/// runs on.
model ClusterReindexProposal {
  id                  String    @id @default(cuid())
  organizationId      String
  proposedAt          DateTime  @default(now())
  drift               Float     @default(0.0)
  clusterCountBefore  Int       @default(0)
  clusterCountAfter   Int       @default(0)
  summaryJson         String    @default("{}")
  status              String    @default("PENDING") // PENDING | ACCEPTED | REJECTED
  resolvedByFounderId String?
  resolvedAt          DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  resolvedBy   Founder?     @relation("ClusterReindexResolver", fields: [resolvedByFounderId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
}

/// One unit of observable work in the noosphere pipeline. Spans nest
/// under `traceId` so an upload can be followed end-to-end (ingester →
/// classifier → distiller → publication). Older spans roll up to
/// `MethodMetricRollup` and may be archived after 30 days; the rollup
/// is the durable record.
model Span {
  id             String    @id
  traceId        String
  parentSpanId   String?
  name           String
  status         String    @default("ok")
  startedAt      DateTime
  endedAt        DateTime?
  durationMs     Float?
  errorKind      String?
  errorMessage   String?
  /// Sanitised attributes — never raw user text or credentials.
  attrs          Json      @default("{}")
  costUsd        Float     @default(0.0)
  organizationId String?

  createdAt DateTime @default(now())

  @@index([traceId])
  @@index([name, startedAt])
  @@index([startedAt])
  @@index([status, startedAt])
}

/// Per-method per-window rollup. Materialised by the same nightly job
/// that computes track record. Survives span retention so the dashboard
/// keeps long-horizon trendlines without scanning raw spans.
model MethodMetricRollup {
  id          String   @id @default(cuid())
  method      String
  windowStart DateTime
  windowEnd   DateTime
  count       Int
  errorCount  Int
  p50Ms       Float
  p95Ms       Float
  errorRate   Float
  costUsd     Float

  createdAt DateTime @default(now())

  // One row per (method, time-window). The materialiser upserts on
  // this triple so re-runs of the rollup job are idempotent.
  @@unique([method, windowStart, windowEnd])
  @@index([method, windowStart])
  @@index([windowStart])
}

/// Threshold-based alerts (e.g. error rate > 5% sustained 15 min).
/// `metric` matches a field of `MethodMetrics` (error_rate, p95_ms,
/// cost_usd, count). `webhookUrl` is optional — when null the rule
/// only writes to the unified attention queue.
model AlertRule {
  id            String  @id @default(cuid())
  name          String  @unique
  metric        String
  threshold     Float
  method        String  @default("*")
  windowMinutes Int     @default(15)
  minSamples    Int     @default(5)
  webhookUrl    String?
  enabled       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// One firing of an `AlertRule`. The unified attention queue (prompt 34)
/// reads from here.
model AlertEvent {
  id             String    @id @default(cuid())
  ruleName       String
  method         String
  metric         String
  value          Float
  threshold      Float
  firedAt        DateTime
  acknowledgedAt DateTime?
  acknowledgedBy String?
  deliveredTo    Json      @default("[]")

  @@index([firedAt])
  @@index([ruleName, firedAt])
  @@index([acknowledgedAt])
}

// ── Methodology Review Week ───────────────────────────────────────────────
//
// The firm holds a quarterly Methodology Review Week (Round 17–18 follow-on)
// — five working days, mid-quarter, with a fixed day-by-day focus: drift
// events, failure modes, domain bounds, retirement candidates, then the
// methodology section of the seasonal review (prompt 46). The schedule is
// generated from the Python module `noosphere.inquiry.methodology_review_week`
// and mirrored into these tables for the web app to triage and present.
//
// Opt-in policy: a `status="postponed"` or `status="skipped"` week is
// logged, not punished. The public methodology page reads the most recent
// completed week and the next scheduled week from these rows.
model MethodologyReviewWeek {
  id             String @id @default(cuid())
  organizationId String

  /// Calendar year and quarter (1..4). Together they identify the week
  /// regardless of postponement.
  year    Int
  quarter Int

  /// Day-1 (Monday) and day-5 (Friday) of the five-working-day window.
  /// On a postponed week these reflect the new dates.
  startDate DateTime
  endDate   DateTime

  /// scheduled | active | completed | postponed | skipped
  /// Defaults to `scheduled`. The agent never flips this on the founder's
  /// behalf — opt-in per founder.
  status String @default("scheduled")

  /// Set when the founder postpones the week. Carries the new Monday
  /// and a free-text reason. The public hint surfaces the new date.
  postponedTo    DateTime?
  postponeReason String    @default("") @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization                  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  daySummaries MethodologyReviewDaySummary[]

  @@unique([organizationId, year, quarter])
  @@index([organizationId, startDate])
  @@index([organizationId, status])
}

// One day-end summary inside a Methodology Review Week. Days 1..4 are
// triage notes against the day's filtered attention queue; day 5 is the
// methodology section that feeds the seasonal review.
//
// The founder writes the body; the agent may produce a `draftBody` based
// on the day's queue and the founder edits or replaces it (drafts are
// clearly labelled). Once `signature` and `signedAt` are set the row is
// immutable — subsequent body changes must clear the signature first
// (matching the Python module's `apply_founder_edit` → re-sign workflow).
model MethodologyReviewDaySummary {
  id             String @id @default(cuid())
  organizationId String
  weekId         String

  /// 1..5. Pairs with the focus vocabulary below.
  dayIndex Int
  /// drift_events | failure_modes | domain_bounds | retirement_candidates
  /// | methodology_section — must match the Python module's DAY_FOCUS.
  focus    String

  /// Agent-generated draft (clearly labelled with the DRAFT banner) and
  /// the founder's submitted body. The draft is never auto-promoted to
  /// the body.
  draftBody        String    @default("") @db.Text
  draftGeneratedAt DateTime?
  body             String    @default("") @db.Text

  /// Number of founder edits applied since the first draft landed.
  /// The audit trail itself (per-edit timestamps + prior bodies) is held
  /// in the JSON sidecar on disk; this column is the inexpensive summary
  /// the queue page needs.
  editCount Int @default(0)

  /// Ed25519 signature over the canonical bytes of (weekSlug, dayIndex,
  /// focus, body). Hex-encoded. Empty until the founder signs the day.
  signature             String    @default("")
  signedAt              DateTime?
  signingKeyFingerprint String    @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  week         MethodologyReviewWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([weekId, dayIndex])
  @@index([organizationId, signedAt])
}

// ── VC firm preset: deals + principle-alignment runs ────────────────────────
//
// A Deal models an investment opportunity. Source documents and notes
// are append-only; the principle-alignment table is a denormalised
// snapshot of the latest noosphere run (see
// noosphere/noosphere/vc/principle_alignment.py). The agent's job is
// to surface which firm principles apply — the partner makes the
// decision.

enum DealDecisionStatus {
  EXPLORING
  NEXT_MEETING
  COMMITTED
  PASSED
  EXITED
}

enum PrincipleAlignmentVerdict {
  MATCH
  CONFLICT
  UNCLEAR
}

model Deal {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  name        String
  description String @default("") @db.Text
  /// Free-form: seed, series-A, pre-seed, etc. — kept TEXT so adding a
  /// new stage is a UI change, not a migration.
  stage       String @default("")
  sector      String @default("")
  geo         String @default("")

  decisionStatus DealDecisionStatus @default(EXPLORING)

  /// JSON-encoded list of {label, uri, kind} pointers to uploaded
  /// pitch decks, founder bios, market reports, and the firm's own
  /// notes. The actual blobs live in object storage; this column is
  /// the manifest the UI renders.
  sourceDocumentsJson String @default("[]") @db.Text

  /// Append-only memo body; auto-promoted draft from MemoDrafter sits
  /// in `memoDraft` until the partner edits/signs and copies it here.
  memoDraft             String    @default("") @db.Text
  memoFinal             String    @default("") @db.Text
  memoSignedAt          DateTime?
  /// Founder id who signed; references Founder via app-level join.
  memoSignedByFounderId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alignments DealPrincipleAlignment[]
  notes      DealNote[]

  @@index([organizationId])
  @@index([organizationId, decisionStatus])
  @@index([organizationId, sector])
}

/// One row per (Deal, Principle) verdict produced by the alignment
/// runner. Persisted so the UI can render the table without re-running
/// the LLM, and so re-runs are idempotent — the runner upserts on
/// (dealId, principleId).
model DealPrincipleAlignment {
  id             String @id @default(cuid())
  organizationId String
  dealId         String
  principleId    String

  verdict       PrincipleAlignmentVerdict
  rationale     String                    @default("") @db.Text
  /// JSON-encoded list of citation objects:
  ///   {conclusion_id?, source_uri?, quote, locator}
  citationsJson String                    @default("[]") @db.Text
  /// Score in [0, 1] reflecting the runner's confidence. Conservative:
  /// unclear verdicts cap at 0.5.
  confidence    Float                     @default(0.0)
  /// Identifier of the alignment run that produced this row. Used to
  /// distinguish re-runs and to GC stale rows when principles are
  /// retired.
  runId         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, principleId])
  @@index([organizationId, dealId])
  @@index([organizationId, principleId])
}

/// Partner-meeting note. Append-only by convention — edits create a
/// new row that links to the predecessor via `supersedesId` rather
/// than mutating in place.
model DealNote {
  id             String @id @default(cuid())
  organizationId String
  dealId         String

  authorFounderId       String
  body                  String  @default("") @db.Text
  /// JSON-encoded list of Principle ids this note explicitly cites.
  /// The UI auto-links each citation to the principle detail page.
  citedPrincipleIdsJson String  @default("[]")
  supersedesId          String?

  createdAt DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([organizationId, dealId, createdAt])
}

// ── Round 19 — Logical Algorithm layer (prompt 01) ─────────────────────────
//
// An algorithm is a logical function: named inputs, a structured
// output, and a structured reasoning body that invokes one or more
// principles to derive the output. Algorithms sit above principles
// the way principles sit above conclusions.
//
// The full Pydantic payload round-trips through ``payloadJson`` so
// the schema can evolve without per-field migrations. Indexed
// columns are the access keys the founder triage queue and the
// runtime hit hardest: (organizationId, status), (organizationId,
// name). The (organizationId, name) compound unique key prevents
// accidental duplicate definitions across re-extraction passes.

enum AlgorithmStatus {
  DRAFT
  UNDER_REVIEW
  ACTIVE
  PAUSED
  RETIRED
}

enum AlgorithmCorrectness {
  CORRECT
  INCORRECT
  PARTIALLY_CORRECT
  INDETERMINATE
}

model LogicalAlgorithm {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  name        String
  description String @default("") @db.Text

  /// JSON-encoded list of Principle ids the algorithm builds on.
  /// At least one is required by the noosphere validator stack.
  sourcePrincipleIdsJson String @default("[]") @db.Text
  /// JSON-encoded list of AlgorithmInput dicts:
  ///   {name, type, description, observability_source, ...}
  inputsJson             String @default("[]") @db.Text
  /// JSON-encoded AlgorithmOutput dict:
  ///   {name, type, description, units?, range?}
  outputJson             String @default("{}") @db.Text
  /// JSON-encoded list of ReasoningStep dicts:
  ///   {step_kind, principle_id?, predicate?, derived_fact?}
  reasoningChainJson     String @default("[]") @db.Text
  /// Sandboxed predicate expression over input.<name> identifiers.
  /// Validated at promotion time so the runtime can ``eval`` it later.
  triggerPredicate       String @default("") @db.Text

  status        AlgorithmStatus @default(DRAFT)
  retiredReason String?

  /// Earned weighting in the synthesizer. Default 1.0; capped at 2.0
  /// by the calibration loop (prompt 05). The synthesizer (prompt 10)
  /// reads this when combining outputs across multiple algorithms.
  weightingMultiplier Float @default(1.0)

  /// When True, every successful invocation of this algorithm enqueues
  /// a synthesis task (prompt 10). Defaults to False so existing
  /// algorithms are not retroactively wired to the synthesizer; the
  /// founder flips this in the triage UI.
  triggersSynthesis Boolean @default(false)

  /// Authoritative round-trip of the noosphere Pydantic payload.
  payloadJson String @default("{}") @db.Text

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastInvokedAt DateTime?

  invocations           AlgorithmInvocation[]
  calibrationSnapshots  AlgorithmCalibrationSnapshot[]
  triageRecommendations AlgorithmTriageRecommendation[]
  synthesizerTasks      SynthesizerTask[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([organizationId, status])
}

/// One row per algorithm firing. Persisted at the moment the trigger
/// predicate matches; resolution columns are backfilled when reality
/// is observed at ``predictedHorizon`` past ``invokedAt``.
model AlgorithmInvocation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  algorithmId String
  algorithm   LogicalAlgorithm @relation(fields: [algorithmId], references: [id], onDelete: Cascade)

  invokedAt DateTime @default(now())

  /// JSON dict of {input_name: observed_value} captured at fire time.
  triggerInputsJson  String @default("{}") @db.Text
  /// JSON dict matching the algorithm's output schema.
  derivedOutputJson  String @default("{}") @db.Text
  /// JSON list of human-readable step strings; each names the
  /// principle invoked and the intermediate fact derived. Founders
  /// read this directly in the audit log.
  reasoningTraceJson String @default("[]") @db.Text

  confidenceLow    Float   @default(0.0)
  confidenceHigh   Float   @default(1.0)
  /// Horizon in seconds — how far ahead the prediction looks.
  predictedHorizon Float   @default(0.0)
  /// Structured bet recommendation if the algorithm implies one,
  /// otherwise null. Loose JSON until prompt 15 ships the canonical
  /// polymorphic bet abstraction.
  betImpliedJson   String?

  resolvedAt        DateTime?
  /// JSON dict of the realised outcome; null until resolution.
  actualOutcomeJson String?
  correctness       AlgorithmCorrectness?
  brierEquivalent   Float?

  /// Authoritative round-trip of the noosphere Pydantic payload.
  payloadJson String @default("{}") @db.Text

  observations     AlgorithmInputObservation[]
  synthesizerTasks SynthesizerTask[]

  @@index([algorithmId, invokedAt(sort: Desc)])
  @@index([organizationId, invokedAt(sort: Desc)])
}

/// Audit row: which observability source produced which value for an
/// invocation. One row per (invocation, input). Founders consult
/// these to answer "where did this number come from?" without
/// re-running the runtime.
model AlgorithmInputObservation {
  id           String              @id @default(cuid())
  invocationId String
  invocation   AlgorithmInvocation @relation(fields: [invocationId], references: [id], onDelete: Cascade)

  inputName        String
  /// JSON-encoded observed value (number, string, bool, list, or
  /// dict — whatever the input's type allows).
  valueJson        String   @default("") @db.Text
  observedAt       DateTime @default(now())
  /// Nullable FK pointer (app-level join) to the artifact / current /
  /// upload row that produced the value. Operator-entered values
  /// have no source artifact.
  sourceArtifactId String?
  sourceUrl        String?

  @@index([invocationId])
  @@index([inputName])
  @@index([sourceArtifactId])
}

// ── Round 19 prompt 05 — Algorithm calibration loop ─────────────────────────
//
// Each ACTIVE algorithm earns its life: every invocation resolves,
// the resolution updates the algorithm's track record, bad algorithms
// retire (founder-confirmed via the triage queue) and good ones earn
// higher weighting in the synthesizer.
//
// AlgorithmCalibrationSnapshot is append-only — re-running the
// calibration tick produces a new row rather than mutating the
// latest one. The public algorithm detail page reads the time-series
// to render the calibration chart.

enum AlgorithmTriageAction {
  NONE
  RETIRE
  PROMOTE
}

enum AlgorithmTriageStatus {
  PENDING
  ACCEPTED
  REJECTED
  DEFERRED
}

model AlgorithmCalibrationSnapshot {
  id             String           @id @default(cuid())
  algorithmId    String
  algorithm      LogicalAlgorithm @relation(fields: [algorithmId], references: [id], onDelete: Cascade)
  organizationId String
  snapshotAt     DateTime         @default(now())

  totalInvocations           Int    @default(0)
  resolvedInvocations        Int    @default(0)
  accuracy                   Float?
  meanBrier                  Float?
  meanHorizonError           Float?
  directionalAccuracy        Float?
  confidenceCalibrationDrift Float?
  last30dAccuracy            Float?
  last30dResolved            Int    @default(0)

  probabilisticResolved  Int @default(0)
  directionalResolved    Int @default(0)
  confidenceBandResolved Int @default(0)

  @@index([algorithmId, snapshotAt(sort: Desc)])
  @@index([organizationId, snapshotAt(sort: Desc)])
}

model AlgorithmTriageRecommendation {
  id             String           @id @default(cuid())
  algorithmId    String
  algorithm      LogicalAlgorithm @relation(fields: [algorithmId], references: [id], onDelete: Cascade)
  organizationId String
  recommendedAt  DateTime         @default(now())

  recommendedAction     AlgorithmTriageAction @default(NONE)
  /// JSON-encoded list of TriggerReason strings that fired.
  triggerReasonsJson    String                @default("[]") @db.Text
  recommendedMultiplier Float                 @default(1.0)
  narrative             String                @default("") @db.Text

  status         AlgorithmTriageStatus @default(PENDING)
  resolvedBy     String?
  resolvedAt     DateTime?
  resolutionNote String?               @db.Text

  @@index([organizationId, status])
  @@index([algorithmId, recommendedAt(sort: Desc)])
}

// ── Round 19 prompt 10 — Synthesizer engine ──────────────────────────────────
//
// The synthesizer is the firm's reasoning organ: it consumes a question,
// retrieves principles + algorithm invocations + currents, identifies
// governing principles, walks a reasoning chain grounded in those
// principles, checks for unresolved STANDING contradictions, and emits
// a structured conclusion. The portfolio agent (prompt 12) acts on the
// memo; the synthesizer NEVER places a bet.

enum SynthesizerTaskTrigger {
  OPERATOR
  ALGORITHM
  CURRENT
}

enum SynthesizerTaskStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

/// Queue row for one synthesis task. Operator queries typically run
/// inline and bypass the queue; algorithm- and currents-triggered
/// requests enqueue here so the producing tick is not blocked by the
/// synthesizer's LLM round-trip.
model SynthesizerTask {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  trigger SynthesizerTaskTrigger @default(OPERATOR)
  status  SynthesizerTaskStatus  @default(PENDING)

  enqueuedAt DateTime  @default(now())
  startedAt  DateTime?
  finishedAt DateTime?

  /// Pointer to the algorithm invocation that triggered this task
  /// (when trigger == ALGORITHM). Loose FK; the noosphere row owns
  /// the authoritative payload.
  invocationId   String?
  invocation     AlgorithmInvocation? @relation(fields: [invocationId], references: [id], onDelete: SetNull)
  algorithmId    String?
  algorithm      LogicalAlgorithm?    @relation(fields: [algorithmId], references: [id], onDelete: SetNull)
  /// Pointer to the Currents event that triggered this task (when
  /// trigger == CURRENT). Stored as plain string; the Currents table
  /// is owned by the noosphere side.
  currentEventId String?

  memoId    String?
  outcome   String?
  reasoning String? @db.Text

  /// Authoritative round-trip of the noosphere Pydantic payload.
  payloadJson String @default("{}") @db.Text

  @@index([organizationId, status])
  @@index([status, enqueuedAt])
  @@index([invocationId])
  @@index([currentEventId])
}

/// Persisted synthesizer memo — the audit-shaped conclusion the
/// portfolio agent reads. Prompt 11 will replace the inline memo body
/// with the full investment-memo format; both shapes share this row's
/// ``id`` and the JSON payload's ``conclusion`` key so consumers don't
/// need to be rewritten when prompt 11 lands.
model SynthesizerMemo {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt          DateTime @default(now())
  synthesizerVersion String   @default("synthesizer/v1")

  question    String @default("") @db.Text
  /// Authoritative round-trip of the noosphere Pydantic payload (the
  /// full conclusion including reasoning chain and citations).
  payloadJson String @default("{}") @db.Text

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([synthesizerVersion])
}

// ── Round 19 prompt 11: InvestmentMemo ─────────────────────────────────
//
// The canonical 10-section memo artifact, emitted by the synthesizer
// and consumed by the portfolio agent (prompt 12). Distinct from
// SynthesizerMemo (the raw, audit-shaped conclusion); InvestmentMemo
// carries the rendered body + lifecycle status the operator drives.

enum MemoStatus {
  DRAFT
  UNDER_REVIEW
  SENT
  ARCHIVED
  PUBLIC
}

enum MemoQuestionType {
  INVESTMENT_DECISION
  FORECAST
  EXPLANATORY
  STRATEGIC
}

model InvestmentMemo {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  /// Loose FK back to the synthesizer's raw memo row that produced
  /// this investment memo. The authoritative payload is on the
  /// noosphere side.
  synthesizerResultId String?

  title String @default("") @db.Text
  slug  String @default("")

  status       MemoStatus       @default(DRAFT)
  questionType MemoQuestionType @default(EXPLANATORY)
  addressee    String           @default("")

  /// Project-relative paths under docs/memos/<yyyy>/<mm>/. The
  /// markdown body is the editable source; the PDF is a derived
  /// artifact.
  mdPath  String?
  pdfPath String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sentAt         DateTime?
  acknowledgedAt DateTime?
  publishedAt    DateTime?
  archivedAt     DateTime?

  synthesizerVersion String @default("synthesizer/v1")

  /// Authoritative round-trip of the noosphere Pydantic payload —
  /// full memo body, governing-principle ids, observed-input ids,
  /// reasoning chain, eight-gate readiness, provenance audit.
  payloadJson String @default("{}") @db.Text

  @@index([organizationId, status])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([slug])
}

// ── Round 19 prompt 12: PortfolioAgent + MemoDispatch ──────────────

enum PortfolioAgentKind {
  HUMAN
  AUTO_PAPER
  AUTO_LIVE
}

enum PortfolioAgentStatus {
  ACTIVE
  PAUSED
  RETIRED
}

enum MemoDispatchOutcome {
  PENDING
  ACCEPTED_AND_BET
  ACCEPTED_NO_BET
  REJECTED
  DEFERRED
  AUTO_PAPERED
  AUTO_LIVE_QUEUED
  DISPATCH_FAILED
}

enum MemoDispatchBetKind {
  FORECAST_BET
  EQUITY_POSITION
}

model PortfolioAgent {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  name        String
  description String @default("") @db.Text

  kind   PortfolioAgentKind   @default(HUMAN)
  status PortfolioAgentStatus @default(ACTIVE)

  /// Per-memo soft ceiling in USD applied by AUTO_PAPER / AUTO_LIVE
  /// modes. Live bets still go through the eight-gate safety
  /// contract (which has its own stake ceiling); this is the
  /// agent-level guardrail applied before the gates.
  defaultBetCeilingUsd Float @default(50.0)

  /// JSON list of `{ topic, question_type, mode }` subscriptions.
  /// Memos whose (topic, question_type) matches ANY entry flow to
  /// this agent. Mode is optional — when absent, the agent's `kind`
  /// is used. Stored as JSON so the Pydantic shape can evolve.
  subscriptionsJson String @default("[]") @db.Text

  /// Round-trip of the full noosphere Pydantic payload, including
  /// any fields not modeled at the SQL level.
  payloadJson String @default("{}") @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memoDispatches MemoDispatch[]

  @@index([organizationId, status])
  @@index([organizationId, kind])
}

model MemoDispatch {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  /// FK to InvestmentMemo.id — kept as a loose reference rather than
  /// a hard FK so memos can be archived without cascading dispatches.
  memoId String

  agentId String
  agent   PortfolioAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  dispatchedAt  DateTime            @default(now())
  outcomeAction MemoDispatchOutcome @default(PENDING)

  /// Foreign id of the bet row this dispatch produced (or null for
  /// PENDING / REJECTED / failed dispatches). Discriminated by
  /// betLinkKind which table the id lives in — we deliberately
  /// avoid a hard FK because the dispatch can outlive the bet's
  /// settlement archive.
  betLink     String?
  betLinkKind MemoDispatchBetKind?

  acknowledgedBy String    @default("")
  acknowledgedAt DateTime?
  rationale      String    @default("") @db.Text
  deferredUntil  DateTime?
  failureReason  String    @default("") @db.Text

  /// JSON snapshot of the memo's eight-gate readiness at dispatch
  /// time. Informational — the live bet engine re-evaluates the
  /// gates at submission. Operator inboxes display this snapshot so
  /// the founder can see which gates were passing when the memo
  /// landed.
  eightGateStatusJson String @default("{}") @db.Text

  /// Round-trip of the full noosphere Pydantic payload.
  payloadJson String @default("{}") @db.Text

  @@index([agentId, outcomeAction])
  @@index([organizationId, dispatchedAt(sort: Desc)])
  @@index([memoId])
}

// ── Round 19 prompt 13: Knowledge graph ────────────────────────────

/// One append-only snapshot of an org's knowledge graph. The graph is
/// a *projection* over Principle / LogicalAlgorithm / InvestmentMemo /
/// source artifact / contradiction rows — those remain
/// authoritative. Snapshots are versioned so the public
/// `/knowledge-graph` view can serve the latest pre-computed shape at
/// low latency, and so an operator can audit how the graph evolved.
model GraphSnapshot {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  snapshotAt DateTime @default(now())
  version    String   @default("kg/v1")

  /// JSON-serialized list of nodes. Each node carries id, kind, ref,
  /// label, attrs, provenance.
  nodesJson String @default("[]") @db.Text
  /// JSON-serialized list of edges. Each edge carries id, src, dst,
  /// kind, weight, attrs.
  edgesJson String @default("[]") @db.Text

  nodeCount Int    @default(0)
  edgeCount Int    @default(0)
  notes     String @default("") @db.Text

  @@index([organizationId, snapshotAt(sort: Desc)])
}

/// Cached agent-reasoning output for one edge — populated by the
/// operator's "warm the top-N edges" job so public clicks are
/// instant. Keyed by (organizationId, src, dst, kind) so a public
/// lookup is O(1).
model GraphEdgeReasoning {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  src  String
  dst  String
  kind String

  /// JSON round-trip of `EdgeReasoning` — short_answer, reasoning
  /// chain, citations, confidence band, weak-connection flag.
  payloadJson String @default("{}") @db.Text

  generatedAt DateTime @default(now())

  @@index([organizationId, src, dst, kind])
}

/// Round 19 prompt 14 — Dialectic live recording mode.
///
/// One recorded conversation (podcast, meeting). Mirrors
/// `dialectic_session` in noosphere/store.py.
model DialecticSession {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  title            String    @default("") @db.Text
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  /// JSON list of `{ speaker_id, display_name, voice_profile_ref,
  /// consented, consented_at }`.
  participantsJson String    @default("[]") @db.Text
  audioPath        String    @default("") @db.Text
  transcriptPath   String    @default("") @db.Text

  /// RECORDING | PROCESSING | COMPLETE | FAILED | ARCHIVED.
  status     String @default("RECORDING")
  /// PRIVATE | PUBLIC. Public sessions show on /dialectic/sessions/[id].
  visibility String @default("PRIVATE")

  liveContradictionsDetected Int     @default(0)
  principlesExtracted        Int     @default(0)
  summaryMemoId              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  utterances DialecticUtterance[]

  @@index([organizationId, status])
  @@index([startedAt])
}

/// One transcribed speaker-turn inside a session.
model DialecticUtterance {
  id        String           @id @default(cuid())
  sessionId String
  session   DialecticSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  speakerId String
  startTime Float  @default(0)
  endTime   Float  @default(0)
  text      String @default("") @db.Text

  extractedClaimIdsJson      String @default("[]") @db.Text
  derivedPrincipleIdsJson    String @default("[]") @db.Text
  liveContradictionFlagsJson String @default("[]") @db.Text

  createdAt DateTime @default(now())

  flags DialecticContradictionFlag[]

  @@index([sessionId, startTime])
  @@index([speakerId])
}

/// Contradiction event fired during a live recording.
model DialecticContradictionFlag {
  id          String             @id @default(cuid())
  utteranceId String
  utterance   DialecticUtterance @relation(fields: [utteranceId], references: [id], onDelete: Cascade)

  /// INTRA_SESSION | HISTORICAL_SELF | HISTORICAL_OTHER | HISTORICAL_FIRM.
  flagKind String @default("INTRA_SESSION")

  priorUtteranceId String?
  priorPrincipleId String?
  priorSpeakerId   String?

  contradictionScore Float   @default(0)
  axis               String?
  humanExplanation   String? @db.Text
  detectionMethod    String  @default("")

  acknowledgedAt     DateTime?
  acknowledgedBy     String?
  acknowledgmentNote String?   @db.Text

  detectedAt DateTime @default(now())

  @@index([utteranceId])
  @@index([flagKind])
}

// ── Round 19 prompt 15: Polymorphic bet abstraction ──────────────────

enum BetKind {
  MARKET_BET
  ADVISORY_BET
  STRATEGIC_BET
  SCIENTIFIC_BET
}

enum BetStatus {
  PROPOSED
  AUTHORIZED
  OPEN
  RESOLVED
  CANCELLED
  EXPIRED
}

enum BetOutcome {
  CORRECT
  INCORRECT
  PARTIALLY_CORRECT
  UNDETERMINED
}

/// Polymorphic bet — the abstract claim made by a memo. The
/// kind-specific sub-spec lives inside `payloadJson` (round-trip of
/// the authoritative noosphere Pydantic shape). MARKET bets gate on
/// the eight-gate safety contract; non-financial bets skip
/// authorization. See `noosphere/bets/spec.py`.
model BetSpec {
  id             String @id
  organizationId String @default("")

  kind   BetKind   @default(MARKET_BET)
  status BetStatus @default(PROPOSED)

  proposition         String   @default("") @db.Text
  resolutionCriterion String   @default("") @db.Text
  horizonAt           DateTime

  createdByMemoId        String?
  originatingAlgorithmId String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  resolvedAt  DateTime?
  outcome     BetOutcome?
  outcomeNote String?     @db.Text

  /// Authoritative round-trip of the noosphere Pydantic payload —
  /// kind-specific sub-spec lives here.
  payloadJson String @default("{}") @db.Text

  resolutions BetResolution[]

  @@index([organizationId, kind, status])
  @@index([horizonAt])
  @@index([createdByMemoId])
  @@map("bet_spec")
}

/// Append-only resolution record. One row per BetSpec resolution.
model BetResolution {
  id           String     @id
  betSpecId    String
  resolvedAt   DateTime   @default(now())
  outcome      BetOutcome @default(UNDETERMINED)
  evidenceNote String     @default("") @db.Text
  resolvedBy   String     @default("agent")

  /// Kind-specific outcome metrics. The lifecycle fills whichever
  /// applies; the others stay NULL.
  pnlUsd           Float?
  costRealized     Float?
  accuracyScore    Float?
  audienceResponse String? @db.Text

  payloadJson String @default("{}") @db.Text

  betSpec BetSpec @relation(fields: [betSpecId], references: [id], onDelete: Cascade)

  @@index([betSpecId])
  @@index([resolvedAt])
  @@map("bet_resolution")
}
