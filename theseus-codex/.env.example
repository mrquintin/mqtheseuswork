# Database (Prisma — Theseus Codex). Postgres everywhere.
# Supabase (recommended for prod + cloud dev):
#   DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Neon:
#   DATABASE_URL="postgresql://<user>:<pw>@<project>-pooler.<region>.aws.neon.tech/<db>?sslmode=require"
# Local Docker Postgres (see docker-compose.dev.yml at repo root):
#   DATABASE_URL="postgresql://theseus:theseus@localhost:5432/theseus"
DATABASE_URL="postgresql://theseus:theseus@localhost:5432/theseus"

# Multi-tenant login default when the browser omits organizationSlug (see /api/auth/login)
DEFAULT_ORGANIZATION_SLUG="theseus-local"

# Optional: expose default org slug to the login page (NEXT_PUBLIC_* is inlined at build time)
# NEXT_PUBLIC_DEFAULT_ORG_SLUG="theseus-local"

# Public About page
# NEXT_PUBLIC_THESEUS_CONTACT_EMAIL="hello@theseuscodex.com"
# NEXT_PUBLIC_ABOUT_HIDE_MEMBERS="false"

# Redis job queue — set USE_JOB_QUEUE=1 and run `npm run worker:ingest` in a separate process/container
# REDIS_URL="redis://127.0.0.1:6379"
# USE_JOB_QUEUE="0"
# NOOSPHERE_JOB_QUEUE_KEY="noosphere:jobs"

# Session signing (openssl rand -hex 32)
SESSION_SECRET="change-me-to-a-random-hex-string"

# Seed credentials — only needed ONCE when running `npm run db:seed` against
# a fresh database. After the DB is seeded, manage founder accounts via
# `scripts/add-founder.ts` and `scripts/remove-founder.ts`; don't leave
# SEED_FOUNDER_* in your real `.env` long-term.
# SEED_FOUNDER_A_EMAIL="alpha@theseus.local"
# SEED_FOUNDER_A_PASSWORD="replace-me-alpha"
# SEED_FOUNDER_B_EMAIL="beta@theseus.local"
# SEED_FOUNDER_B_PASSWORD="replace-me-beta"

# Noosphere Python (ingest / synthesize from upload pipeline)
NOOSPHERE_PYTHON="python3"
# Directory that contains the `noosphere` package (parent of `noosphere/noosphere/`)
NOOSPHERE_SRC_ROOT="../noosphere"
# SQLite URL for the Noosphere store (optional; enables review-queue sync)
NOOSPHERE_DATABASE_URL="sqlite:///../noosphere_data/noosphere.db"

# Dialectic live session reflection JSON (SP09). Copy `session_*_reflection.json` from Dialectic recordings here.
# DIALECTIC_REFLECTIONS_DIR="/absolute/path/to/dialectic/recordings"

# Legacy / optional
OPENAI_API_KEY=""

# Public knowledge site (SP10)
# Canonical base URL used in generated citation blocks (BibTeX / APA / RIS).
# THESEUS_PUBLIC_SITE_URL="https://public.theseus.invalid"
# Zenodo access token for DOI minting on publish (optional; without it, preview DOIs are stored).
# THESEUS_ZENODO_TOKEN=""
# THESEUS_ZENODO_CREATOR_NAME="Theseus"
# Comma-separated browser origins allowed to POST structured responses to `/api/public/responses`.
# THESEUS_PUBLIC_CORS_ORIGINS="http://localhost:3001"

# --- Currents feature (live news) ---
# URL of the current_events_api FastAPI service (server-side only — never
# exposed to the browser; the Codex's /api/currents/* routes proxy here).
CURRENTS_API_URL=http://127.0.0.1:8088

# Currents-specific secrets are NOT set in theseus-codex's env. They live on
# the host running current_events_api + the noosphere scheduler:
#   X_BEARER_TOKEN, ANTHROPIC_API_KEY, NOOSPHERE_DATA_DIR
# Document them in current_events_api/.env.example, NOT here.

# --- Social outbound (X bot account) ---
# Default is disabled. Set true only for a running operator-approved posting
# environment; every post still requires a founder click in /social.
THESEUS_X_POSTING_ENABLED="false"
X_POSTS_PER_DAY_MAX="3"
# OAuth 2.0 user-context token with tweet.write + offline.access scopes.
# Never use the read-only app bearer token for posting.
# X_BOT_OAUTH_CLIENT_ID=""
# X_BOT_OAUTH_REFRESH_TOKEN=""
# Optional for confidential OAuth clients:
# X_BOT_OAUTH_CLIENT_SECRET=""
# Comma-separated phrases blocked by the content gate.
# X_FORBIDDEN_PHRASES=""
# Test/rehearsal only: bypasses live X network calls and returns mock tweet ids.
# THESEUS_X_CLIENT_MOCK="0"

# --- Social outbound (Substack email-to-post) ---
# Default is disabled. Substack publishing still requires a founder-approved
# SocialPost and uses email-to-post rather than undocumented internal endpoints.
THESEUS_SUBSTACK_POSTING_ENABLED="false"
# SUBSTACK_SMTP_HOST=""
# SUBSTACK_SMTP_PORT="587"
# SUBSTACK_SMTP_USER=""
# SUBSTACK_SMTP_PASS=""
# SUBSTACK_PUBLISH_EMAIL=""
# SUBSTACK_FROM_EMAIL=""
# Test/rehearsal only: bypasses live SMTP and returns mock sent ids.
# THESEUS_SUBSTACK_CLIENT_MOCK="0"
# Dry-run only: renders the email envelope/body without sending.
# THESEUS_SUBSTACK_DRY_RUN="0"
